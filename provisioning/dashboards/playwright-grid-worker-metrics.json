  "panels": [
    {
      "type": "timeseries",
      "title": "Disk usage ratio by node",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "refId": "A",
          "expr": "worker_disk_usage_ratio{node=~\"$node\"}",
          "legendFormat": "{{node}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Disk bytes (used/total/free) by node",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "min": 0 },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "refId": "A",
          "expr": "worker_disk_bytes_used{node=~\"$node\"}",
          "legendFormat": "used {{node}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "refId": "B",
          "expr": "worker_disk_bytes_free{node=~\"$node\"}",
