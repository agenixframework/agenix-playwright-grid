    private async Task SubmitGenerateApiKey()
    {
        if (IsGeneratingApiKey) return;
        ApiKeyError = string.Empty;
        var name = (ApiKeyName ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(UserId))
        {
            ApiKeyError = "Unable to resolve current user id.";
            return;
        }

        if (string.IsNullOrWhiteSpace(name) || name.Length > 40)
        {
            ApiKeyError = "Please provide a valid API key name (1–40 characters).";
            return;
        }

        IsGeneratingApiKey = true;
        try
        {
            var client = Http.CreateClient(HttpClientNames.Hub);
            using var resp = await client.PostAsJsonAsync($"/admin/users/{Uri.EscapeDataString(UserId)}/api-keys", new { name });
            var text = await resp.Content.ReadAsStringAsync();
            if ((int)resp.StatusCode == 201 || resp.IsSuccessStatusCode)
            {
                string apiKey;
                try
                {
                    using var doc = JsonDocument.Parse(text);
                    apiKey = doc.RootElement.TryGetProperty("apiKey", out var k) ? k.GetString() ?? string.Empty : string.Empty;
                }
                catch
                {
                    apiKey = text;
                }

                if (string.IsNullOrWhiteSpace(apiKey)) apiKey = "<generated>";
                GeneratedApiKey = apiKey;
                ApiKeyGenerated = true;
                try
                {
                    Toasts.Success("API key has been generated.");
                }
                catch
                {
                }
            }
            else if (resp.StatusCode == HttpStatusCode.Conflict)
            {
                ApiKeyError = "Duplicate API key name";
                try
                {
                    Toasts.Warning(ApiKeyError);
                }
                catch
                {
                }
            }
            else
            {
                string msg;
                try
                {
                    using var doc = JsonDocument.Parse(text);
                    msg = doc.RootElement.TryGetProperty("error", out var e) ? e.GetString() ?? resp.ReasonPhrase ?? "Generation failed" : resp.ReasonPhrase ?? "Generation failed";
                }
                catch
                {
                    msg = resp.ReasonPhrase ?? "Generation failed";
                }

                ApiKeyError = msg;
                try
                {
                    Toasts.Error(msg);
                }
                catch
                {
                }
            }
        }
        catch (Exception ex)
        {
            ApiKeyError = ex.Message;
            try
            {
                Toasts.Error(ex.Message);
            }
            catch
            {
            }
        }
        finally
        {
            IsGeneratingApiKey = false;
        }
    }

