@page "/profile"
@using System.ComponentModel.DataAnnotations
@using System.Net
@using System.Net.Http.Headers
@using System.Security.Claims
@using System.Security.Cryptography
@using System.Text
@using System.Text.Json
@using System.Text.RegularExpressions
@using Agenix.PlaywrightGrid.Domain
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@inject IHttpClientFactory Http
@inject NavigationManager Nav
@inject IHttpContextAccessor Accessor
@inject IConfiguration Configuration
@inject AvatarState AvatarState
@inject ToastService Toasts
@inject IJSRuntime JS

@if (!string.IsNullOrEmpty(Error))
{
    <Dashboard.Shared.ValidationPanel Error="@Error"/>
}

@if (!Loaded)
{
    <div class="text-muted">Loading…</div>
}
else
{
    <div class="pageLayout__page-layout--xB5hn">
        <div class="profilePage__container--krCcS">
            <div class="page-header">
                <div class="header-content">
                    <div class="header-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true">
                            <path
                                d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
                        </svg>
                    </div>
                    <div>
                        <h3>User Profile</h3>
                        <div class="subtitle">Manage your profile information and settings</div>
                    </div>
                </div>
            </div>

            <!-- Header strip: avatar + identity + actions (styled like the screenshot) -->
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="d-flex align-items-start gap-2">
                    <!-- Avatar -->
                    <img src="@AvatarUrl" alt="Avatar" class="rounded"
                         style="width:96px;height:96px;object-fit:cover;border:1px solid #e0e0e0;"/>

                    <!-- Identity details -->
                    <div>
                        <div class="text-uppercase fw-semibold mb-1 d-inline-flex align-items-center gap-2">
                            <span>@DisplayName</span>
                            <button class="btn btn-link btn-sm p-0 text-decoration-none" title="Edit user name"
                                    @onclick="OpenEditModal" style="line-height:1;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                     viewBox="0 0 16 16" aria-hidden="true">
                                    <path
                                        d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-9.5 9.5a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l9.5-9.5zM11.207 2 14 4.793 14.793 4 12 1.207 11.207 2zM13.5 5.293 10.707 2.5 4 9.207V10h.793L13.5 5.293z"/>
                                </svg>
                            </button>
                        </div>
                        <div class="mb-1">
                            @if (!string.IsNullOrWhiteSpace(RoleLabel))
                            {
                                <span class="badge rounded-pill role-badge @GetRoleClass()"
                                      title="Your access level">@RoleLabel</span>
                            }
                        </div>
                        <div class="mb-2 d-inline-flex align-items-center gap-2">
                            <span>@EmailDisplay</span>
                            <button class="btn btn-link btn-sm p-0 text-decoration-none" title="Edit email"
                                    @onclick="OpenEditModal" style="line-height:1;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                     viewBox="0 0 16 16" aria-hidden="true">
                                    <path
                                        d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-9.5 9.5a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l9.5-9.5zM11.207 2 14 4.793 14.793 4 12 1.207 11.207 2zM13.5 5.293 10.707 2.5 4 9.207V10h.793L13.5 5.293z"/>
                                </svg>
                            </button>
                        </div>

                        <div class="d-flex align-items-center gap-2">
                            <label class="btn btn-sm btn-primary mb-0">
                                Upload Photo
                                <Microsoft.AspNetCore.Components.Forms.InputFile OnChange="OnAvatarFileSelected"
                                                                                 accept="image/*" class="d-none"/>
                            </label>
                            <button class="btn btn-sm btn-outline-primary" type="button"
                                    @onclick="OpenDeleteAvatarModal">Remove Photo
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Change password on the far right -->
                <div class="ms-auto" style="min-width: 200px;">
                    <button class="btn btn-primary btn-sm w-100" @onclick="OpenChangePasswordModal">Change Password
                    </button>
                </div>
            </div>

            <!-- Tabs like in the screenshot (only Project Assignment enabled) -->
            <ul class="nav nav-tabs mb-2">
                <li class="nav-item">
                    <button
                        class="nav-link text-uppercase fw-semibold @(ActiveTab == Tab.ProjectAssignment ? "active" : null)"
                        @onclick="() => ActiveTab = Tab.ProjectAssignment">Project Assignment
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link text-uppercase @(ActiveTab == Tab.ApiKeys ? "active" : null)"
                            @onclick="() => ActiveTab = Tab.ApiKeys">API Keys
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link text-uppercase @(ActiveTab == Tab.ConfigurationExamples ? "active" : null)"
                            disabled>Configuration Examples
                    </button>
                </li>
            </ul>

            <style>
                .nav-tabs {
                    border-bottom: 2px solid #e9ecef;
                }

                .nav-tabs .nav-link {
                    border: none;
                    border-bottom: 3px solid transparent;
                    color: #6c757d;
                    font-weight: 600;
                    padding: 0.75rem 1.5rem;
                    background: transparent;
                    cursor: pointer;
                    transition: all 0.2s ease;
                    font-size: 0.8125rem;
                    letter-spacing: 0.3px;
                }

                .nav-tabs .nav-link:hover:not(:disabled) {
                    border-bottom-color: #b794f4;
                    color: #764ba2;
                }

                .nav-tabs .nav-link.active {
                    border: none;
                    border-bottom: 3px solid #764ba2;
                    color: #764ba2;
                    font-weight: 600;
                    background: transparent;
                }

                .nav-tabs .nav-link:disabled {
                    color: #aaa;
                    cursor: not-allowed;
                }

                /* Table header - violet accent */
                .blockContainer__block-header--bOT4P {
                    background-color: #f8f6fc !important;
                    color: #764ba2 !important;
                    border-bottom: 2px solid #e9e2f3 !important;
                }

                /* Project links - violet hover */
                .assignedProjectsBlock__project-item a {
                    color: #374151;
                    font-weight: 600;
                    transition: color 0.2s ease;
                }

                .assignedProjectsBlock__project-item a:hover {
                    color: #764ba2;
                }

                /* Language section */
                .language-display {
                    border-color: #e9e2f3 !important;
                    transition: all 0.2s ease;
                }

                .language-display:hover {
                    border-color: #b794f4 !important;
                }

                /* Edit buttons - violet */
                .btn-link {
                    color: #764ba2;
                    transition: color 0.2s ease;
                }

                .btn-link:hover {
                    color: #667eea;
                }

                /* Upload/Remove buttons already using global btn-primary styles */
            </style>

            @if (ActiveTab == Tab.ProjectAssignment)
            {
                <!-- Projects table -->
                <div class="table-responsive">
                    <table class="table table-borderless align-middle mb-3" style="min-width: 620px;">
                        <thead>
                        <tr class="text-uppercase text-muted small">
                            <th class="bg-light fw-semibold py-1 px-2 blockContainer__block-header--bOT4P"
                                style="letter-spacing:.03em;">Projects (@(Memberships?.Length ?? 0))
                            </th>
                            <th class="bg-light fw-semibold text-end py-1 px-2 blockContainer__block-header--bOT4P text-nowrap"
                                style="letter-spacing:.03em;">Project Role
                            </th>
                        </tr>
                        </thead>
                        <tbody class="small">
                        @if (Memberships is null)
                        {
                            <tr>
                                <td colspan="2" class="text-muted py-4">Loading…</td>
                            </tr>
                        }
                        else if (Memberships.Length == 0)
                        {
                            <tr>
                                <td colspan="2" class="text-muted py-4">No projects linked.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var m in Memberships)
                            {
                                <tr class="assignedProjectsBlock__project-item">
                                    <td class="assignedProjectsBlock__project-item">
                                        <a class="text-decoration-none"
                                           href="/admin/projects/@Uri.EscapeDataString(m.ProjectKey ?? string.Empty)">@m.ProjectKey?.ToUpperInvariant()</a>
                                    </td>
                                    <td class="assignedProjectsBlock__project-item text-end text-nowrap">@Regex.Replace(m.Role.ToString(), "([a-z])([A-Z])", "$1 $2").ToUpperInvariant()</td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>

                <!-- Language row (static display to mirror screenshot; no behavior change) -->
                <div class="mt-3">
                    <div class="text-muted mb-2" style="font-weight: 600; font-size: 0.9rem;">Language</div>
                    <div class="d-inline-flex align-items-center gap-2 border rounded px-3 py-2 language-display">
                        <span aria-hidden="true">🇺🇸</span>
                        <span class="small">English (United States)</span>
                    </div>
                </div>
            }
            else if (ActiveTab == Tab.ApiKeys)
            {
                <div class="mb-3 text-muted small" style="max-width: 860px;">
                    In order to provide security for your own domain password, you can use a user key — to verify your
                    account to be able to log with hub.
                </div>

                @if (ApiKeys is null)
                {
                    <div class="text-muted">Loading…</div>
                }
                else if (ApiKeys.Count == 0)
                {
                    <div class="d-flex flex-column align-items-center text-center" style="padding: 40px 0;">
                        <div class="mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="160" height="120" viewBox="0 0 160 120"
                                 aria-hidden="true">
                                <rect x="8" y="24" width="144" height="72" rx="6" fill="#F7F9FB" stroke="#E3E8EF"/>
                                <circle cx="64" cy="60" r="18" stroke="#C7D0D9" stroke-width="3" fill="none"/>
                                <path d="M82 60h52m-12-8v16m-10-12v8" stroke="#C7D0D9" stroke-width="3"
                                      stroke-linecap="round"/>
                            </svg>
                        </div>
                        <div class="h5 mb-2">No API Keys</div>
                        <div class="text-muted small mb-3" style="max-width: 560px;">
                            Generate your first API key to use with the hub.
                        </div>
                        <button class="btn btn-primary" @onclick="OnGenerateApiKey">Generate API Key</button>
                    </div>
                }
                else
                {
                    <div class="d-flex justify-content-end mb-3">
                        <button class="btn btn-primary btn-sm" @onclick="OnGenerateApiKey">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                 viewBox="0 0 16 16" class="me-1">
                                <path
                                    d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                            </svg>
                            Generate API Key
                        </button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-borderless align-middle" style="min-width: 620px;">
                            <thead>
                            <tr class="text-uppercase text-muted small">
                                <th class="bg-light fw-semibold py-1 px-2 blockContainer__block-header--bOT4P"
                                    style="letter-spacing:.03em;">API Keys (@(ApiKeys?.Count ?? 0))
                                </th>
                                <th class="bg-light fw-semibold text-end py-1 px-2 blockContainer__block-header--bOT4P text-nowrap"
                                    style="letter-spacing:.03em;">Created
                                </th>
                                <th class="bg-light fw-semibold text-end py-1 px-2 blockContainer__block-header--bOT4P"
                                    style="letter-spacing:.03em;"></th>
                            </tr>
                            </thead>
                            <tbody class="small">
                            @foreach (var k in ApiKeys!)
                            {
                                <tr class="border-top">
                                    <td class="py-2">@k.Name</td>
                                    <td class="py-2 text-muted text-end text-nowrap">@FormatAgo(k.CreatedUtc)</td>
                                    <td class="py-2 text-end">
                                        <button class="btn btn-link p-0 text-danger"
                                                @onclick="() => RevokeApiKeyWithConfirmAsync(k.Name)">Revoke
                                        </button>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            }

            @if (EditModalOpen)
            {
                <div class="pg-modal-backdrop" @onclick="CloseEditModal"></div>
                <div class="pg-modal" role="dialog" aria-modal="true" aria-labelledby="editModalTitle">
                    <div class="pg-modal-header">
                        <div id="editModalTitle" class="pg-modal-title">Edit Personal Information</div>
                        <button type="button" class="btn btn-link text-muted p-0" title="Close"
                                @onclick="CloseEditModal" aria-label="Close">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                                 viewBox="0 0 16 16" aria-hidden="true">
                                <path
                                    d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                            </svg>
                        </button>
                    </div>
                    <div class="pg-modal-body">
                        @if (!string.IsNullOrEmpty(ModalError))
                        {
                            <div class="alert alert-danger py-1 px-2 mb-2">@ModalError</div>
                        }
                        <div class="mb-3">
                            <label class="form-label small text-muted">User name</label>
                            <input
                                class="form-control @(string.IsNullOrEmpty(UsernameError) ? string.Empty : "is-invalid")"
                                @bind="EditUsername" @bind:event="oninput"
                                aria-invalid="@(!string.IsNullOrEmpty(UsernameError))"/>
                            @if (!string.IsNullOrEmpty(UsernameError))
                            {
                                <div class="invalid-feedback d-block">@UsernameError</div>
                            }
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">Email</label>
                            <input
                                class="form-control @(string.IsNullOrEmpty(EmailError) ? string.Empty : "is-invalid")"
                                type="email" @bind="EditEmail" @bind:event="oninput"
                                aria-invalid="@(!string.IsNullOrEmpty(EmailError))"/>
                            @if (!string.IsNullOrEmpty(EmailError))
                            {
                                <div class="invalid-feedback d-block">@EmailError</div>
                            }
                        </div>
                    </div>
                    <div class="pg-modal-footer d-flex justify-content-end gap-2">
                        <button class="btn btn-secondary" disabled="@IsSaving" @onclick="CloseEditModal">Cancel</button>
                        <button class="btn btn-primary" disabled="@IsSaving"
                                @onclick="SubmitEdit">
                            @(IsSaving ? "Saving…" : "Submit")
                        </button>
                    </div>
                </div>
            }

            @if (DeleteModalOpen)
            {
                <div class="pg-modal-backdrop" @onclick="CloseDeleteAvatarModal"></div>
                <div class="pg-modal" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
                    <div class="pg-modal-header">
                        <div id="deleteModalTitle" class="pg-modal-title">DELETE IMAGE</div>
                        <button type="button" class="btn btn-link text-muted p-0" title="Close"
                                @onclick="CloseDeleteAvatarModal" aria-label="Close">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                                 viewBox="0 0 16 16" aria-hidden="true">
                                <path
                                    d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                            </svg>
                        </button>
                    </div>
                    <div class="pg-modal-body">
                        <div>Are you sure you want to delete profile photo?</div>
                    </div>
                    <div class="pg-modal-footer d-flex justify-content-end gap-2">
                        <button class="btn btn-secondary" disabled="@IsDeletingAvatar"
                                @onclick="CloseDeleteAvatarModal">Cancel
                        </button>
                        <button class="btn btn-danger" disabled="@IsDeletingAvatar"
                                @onclick="ConfirmDeleteAvatar">
                            @(IsDeletingAvatar ? "Deleting…" : "Delete")
                        </button>
                    </div>
                </div>
            }

            @if (ChangePwdOpen)
            {
                <div class="pg-modal-backdrop" @onclick="CloseChangePasswordModal"></div>
                <div class="pg-modal" role="dialog" aria-modal="true" aria-labelledby="pwdModalTitle">
                    <div class="pg-modal-header">
                        <div id="pwdModalTitle" class="pg-modal-title">CHANGE PASSWORD</div>
                        <button type="button" class="btn btn-link text-muted p-0" title="Close"
                                @onclick="CloseChangePasswordModal" aria-label="Close">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                                 viewBox="0 0 16 16" aria-hidden="true">
                                <path
                                    d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                            </svg>
                        </button>
                    </div>
                    <div class="pg-modal-body">
                        @if (!string.IsNullOrEmpty(PwdError))
                        {
                            <div class="alert alert-danger py-1 px-2 mb-2">@PwdError</div>
                        }
                        <div class="mb-3">
                            <label class="form-label small text-muted">Old password</label>
                            <input
                                class="form-control @(string.IsNullOrWhiteSpace(OldPwd) ? "is-invalid" : string.Empty)"
                                type="@(ShowPwd ? "text" : "password")" @bind="OldPwd" @bind:event="oninput"/>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">New password</label>
                            <input class="form-control @(!IsNewPasswordValid ? "is-invalid" : string.Empty)"
                                   type="@(ShowPwd ? "text" : "password")" @bind="NewPwd" @bind:event="oninput"/>
                            <div class="form-text small">
                                Minimum 8 characters, at least one digit, one special symbol, one uppercase, and one
                                lowercase letter.
                            </div>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small text-muted">Confirm</label>
                            <input class="form-control @(!IsConfirmMatch ? "is-invalid" : string.Empty)"
                                   type="@(ShowPwd ? "text" : "password")" @bind="ConfirmPwd" @bind:event="oninput"/>
                        </div>
                        <div class="form-check mb-1">
                            <input id="showPwd" class="form-check-input" type="checkbox" @bind="ShowPwd"/>
                            <label for="showPwd" class="form-check-label small">Show password</label>
                        </div>
                    </div>
                    <div class="pg-modal-footer d-flex justify-content-end gap-2">
                        <button class="btn btn-secondary" disabled="@IsChangingPwd" @onclick="CloseChangePasswordModal">
                            Cancel
                        </button>
                        <button class="btn btn-primary" disabled="@(!CanSubmitPasswordChange())"
                                @onclick="SubmitPasswordChange">
                            @(IsChangingPwd ? "Saving…" : "Submit")
                        </button>
                    </div>
                </div>
            }

            @if (ApiKeyModalOpen)
            {
                <div class="pg-modal-backdrop" @onclick="CloseApiKeyModal"></div>
                <div class="pg-modal" role="dialog" aria-modal="true" aria-labelledby="apiKeyModalTitle">
                    <div class="pg-modal-header">
                        <div id="apiKeyModalTitle" class="pg-modal-title">GENERATE API KEY</div>
                        <button type="button" class="btn btn-link text-muted p-0" title="Close"
                                @onclick="CloseApiKeyModal" aria-label="Close">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                                 viewBox="0 0 16 16" aria-hidden="true">
                                <path
                                    d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                            </svg>
                        </button>
                    </div>
                    <div class="pg-modal-body">
                        @if (!string.IsNullOrEmpty(ApiKeyError))
                        {
                            <div class="alert alert-danger py-1 px-2 mb-2">@ApiKeyError</div>
                        }

                        @if (!ApiKeyGenerated)
                        {
                            <div class="text-muted mb-2">A new API Key will be generated. Keep this Key safe. We do not
                                recommend making this Key publicly available.
                            </div>
                            <div class="mb-2">
                                <label class="form-label small text-muted">API Key Name</label>
                                <input
                                    class="form-control @(string.IsNullOrWhiteSpace(ApiKeyName) || ApiKeyName!.Trim().Length > 40 ? "is-invalid" : string.Empty)"
                                    @bind="ApiKeyName" @bind:event="oninput"/>
                                @if (string.IsNullOrWhiteSpace(ApiKeyName))
                                {
                                    <div class="invalid-feedback d-block">The field is required</div>
                                }
                                else if (ApiKeyName!.Trim().Length > 40)
                                {
                                    <div class="invalid-feedback d-block">Maximum 40 characters</div>
                                }
                                <div class="form-text">Number of characters remaining: @ApiKeyRemaining</div>
                            </div>
                        }
                        else
                        {
                            <div class="mb-2">
                                <label class="form-label small text-muted">Your new API Key (copy and store it
                                    now)</label>
                                <div class="input-group">
                                    <input class="form-control" readonly value="@GeneratedApiKey"
                                           aria-label="Generated API key"/>
                                    <button class="btn btn-outline-secondary" type="button" title="Copy to clipboard"
                                            @onclick="CopyGeneratedApiKeyAsync">Copy
                                    </button>
                                </div>
                                <div class="form-text">Prefix is based on the name: spaces and underscores are replaced
                                    with hyphens.
                                </div>
                            </div>
                        }
                    </div>
                    <div class="pg-modal-footer d-flex justify-content-end gap-2">
                        <button class="btn btn-secondary" disabled="@IsGeneratingApiKey"
                                @onclick="CloseApiKeyModal">
                            @(ApiKeyGenerated ? "Close" : "Cancel")
                        </button>
                        @if (!ApiKeyGenerated)
                        {
                            <button class="btn btn-primary" disabled="@(!CanGenerateApiKey)"
                                    @onclick="SubmitGenerateApiKey">
                                @(IsGeneratingApiKey ? "Generating…" : "Generate")
                            </button>
                        }
                    </div>
                </div>
            }

            @if (RevokeConfirmModalOpen)
            {
                <div class="pg-modal-backdrop" @onclick="CloseRevokeConfirmModal"></div>
                <div class="pg-modal" role="dialog" aria-modal="true" aria-labelledby="revokeModalTitle">
                    <div class="pg-modal-header">
                        <div id="revokeModalTitle" class="pg-modal-title">REVOKE API KEY</div>
                        <button type="button" class="btn btn-link text-muted p-0" title="Close"
                                @onclick="CloseRevokeConfirmModal" aria-label="Close">
