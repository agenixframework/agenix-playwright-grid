    private bool IsNewPasswordValid
    {
        get
        {
            var s = NewPwd ?? string.Empty;
            if (s.Length < 8) return false;
            bool u = false, l = false, d = false, sym = false;
            foreach (var ch in s)
            {
                if (char.IsUpper(ch)) u = true;
                else if (char.IsLower(ch)) l = true;
                else if (char.IsDigit(ch)) d = true;
                else sym = true; // any non-alnum considered special
            }

            return u && l && d && sym;
        }
    }

    private bool IsConfirmMatch => string.Equals(NewPwd ?? string.Empty, ConfirmPwd ?? string.Empty, StringComparison.Ordinal);

