        }
        catch
        {
        }
    }

    private void ChangePassword()
    {
        try
        {
            var url = Configuration["OIDC_FORGOT_PASSWORD_URL"];
            if (!string.IsNullOrWhiteSpace(url))
            {
                Nav.NavigateTo(url!, true);
            }
            else
            {
                Nav.NavigateTo("/auth/login?changePassword=1", true);
            }
        }
        catch
        {
            Nav.NavigateTo("/auth/login", true);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Resolve user from ClaimsPrincipal via injected IHttpContextAccessor or Cascading Auth state
            var principal = Accessor?.HttpContext?.User;
            if ((principal is null || principal.Identity is null || !principal.Identity.IsAuthenticated) && AuthStateTask is not null)
            {
                try
                {
                    var state = await AuthStateTask;
                    principal = state.User;
                }
                catch
                {
                }
            }

            var name = principal?.Identity?.Name;
            var id = principal?.FindFirst("preferred_username")?.Value
                     ?? principal?.FindFirst(ClaimTypes.Email)?.Value
                     ?? name
                     ?? principal?.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            UserId = id;
            DisplayName = string.IsNullOrWhiteSpace(name) ? id ?? "User" : name!;
            EmailDisplay = principal?.FindFirst(ClaimTypes.Email)?.Value;
            RoleLabel = principal?.FindFirst("role")?.Value ?? principal?.FindFirst(ClaimTypes.Role)?.Value ?? string.Empty;
            if (string.IsNullOrWhiteSpace(RoleLabel)) RoleLabel = "user";

            // Try enrich from Hub user record
            if (!string.IsNullOrWhiteSpace(UserId))
            {
                var client = Http.CreateClient(HttpClientNames.Hub);
                using (var resp = await client.GetAsync($"/admin/users/{Uri.EscapeDataString(UserId)}"))
                {
                    if (resp.IsSuccessStatusCode)
                    {
                        var json = await resp.Content.ReadAsStringAsync();
                        try
                        {
                            using var doc = JsonDocument.Parse(json);
                            var root = doc.RootElement;
                            if (string.IsNullOrWhiteSpace(DisplayName) || string.Equals(DisplayName, "User", StringComparison.Ordinal))
                            {
                                if (root.TryGetProperty("username", out var un) || root.TryGetProperty("Username", out un))
                                    DisplayName = un.GetString() ?? DisplayName;
                            }

                            if (string.IsNullOrWhiteSpace(EmailDisplay))
                            {
                                if (root.TryGetProperty("email", out var em) || root.TryGetProperty("Email", out em))
                                    EmailDisplay = em.ValueKind == JsonValueKind.String ? em.GetString() : EmailDisplay;
                            }

                            if (string.IsNullOrWhiteSpace(RoleLabel) || string.Equals(RoleLabel, "user", StringComparison.OrdinalIgnoreCase))
                            {
                                if (root.TryGetProperty("accountRole", out var ar) || root.TryGetProperty("AccountRole", out ar))
                                {
                                    if (ar.ValueKind == JsonValueKind.Number)
                                    {
                                        if (ar.GetInt32() == 1) RoleLabel = "admin";
                                        else RoleLabel = "user";
                                    }
                                    else if (ar.ValueKind == JsonValueKind.String)
                                    {
                                        var s = (ar.GetString() ?? string.Empty).Trim().ToLowerInvariant();
                                        if (s == "administrator" || s == "admin") RoleLabel = "admin";
                                        else RoleLabel = "user";
                                    }
                                }
                                else if (root.TryGetProperty("role", out var r) || root.TryGetProperty("Role", out r))
                                {
                                    if (r.ValueKind == JsonValueKind.Number && r.GetInt32() == 1) RoleLabel = "admin";
                                    else if (r.ValueKind == JsonValueKind.String)
                                    {
                                        var s = (r.GetString() ?? string.Empty).Trim().ToLowerInvariant();
                                        if (s == "admin" || s == "administrator") RoleLabel = "admin";
                                        else RoleLabel = "user";
                                    }
                                }
                            }
                        }
                        catch
                        {
                        }
                    }
                }

                // Load project memberships
                using var resp2 = await client.GetAsync($"/admin/users/{Uri.EscapeDataString(UserId)}/projects");
                if (resp2.IsSuccessStatusCode)
                {
                    var payload = await resp2.Content.ReadAsStringAsync();
                    try
                    {
                        using var doc2 = JsonDocument.Parse(payload);
                        if (doc2.RootElement.TryGetProperty("items", out var items) && items.ValueKind == JsonValueKind.Array)
                        {
                            var list = new List<Membership>();
                            foreach (var el in items.EnumerateArray())
                            {
                                var pk = el.TryGetProperty("projectKey", out var pkEl) || el.TryGetProperty("ProjectKey", out pkEl) ? pkEl.GetString() ?? string.Empty : string.Empty;
                                var roleVal = el.TryGetProperty("role", out var rEl) || el.TryGetProperty("Role", out rEl) ? rEl.ValueKind == JsonValueKind.Number ? rEl.GetInt32() : Enum.TryParse<ProjectRole>(rEl.GetString() ?? string.Empty, true, out var parsed) ? (int)parsed : 2 : 2;
                                var role = roleVal switch { 0 => ProjectRole.ProjectLead, 1 => ProjectRole.Member, 2 => ProjectRole.Client, 3 => ProjectRole.Maintainer, _ => ProjectRole.Client };
                                if (!string.IsNullOrWhiteSpace(pk)) list.Add(new Membership { ProjectKey = pk, UserId = UserId!, Role = role, CreatedUtc = DateTime.UtcNow, UpdatedUtc = DateTime.UtcNow });
                            }

                            Memberships = list.OrderBy(m => m.ProjectKey).ToArray();
                        }
                    }
                    catch
                    {
                    }
                }
            }

            // Try load custom avatar from Hub; fall back to generated/default if absent
            await FetchAndSetAvatarAsync();

            // Compute avatar URL (fallback only)
            if (!AvatarLoaded)
                AvatarUrl = ComputeAvatarUrl(EmailDisplay, DisplayName, RoleLabel);

            // Load API keys for the current user
            await LoadApiKeysAsync();
        }
        finally
        {
            Loaded = true;
        }
    }

    private async Task FetchAndSetAvatarAsync()
    {
        if (string.IsNullOrWhiteSpace(UserId)) return;
        try
        {
            var client = Http.CreateClient(HttpClientNames.Hub);
            using var resp = await client.GetAsync($"/admin/users/{Uri.EscapeDataString(UserId)}/photo");
            if (resp.IsSuccessStatusCode)
            {
                var ct = resp.Content.Headers.ContentType?.MediaType ?? "image/png";
                var bytes = await resp.Content.ReadAsByteArrayAsync();
                if (bytes is { Length: > 0 })
                {
                    var b64 = Convert.ToBase64String(bytes);
                    AvatarUrl = $"data:{ct};base64,{b64}";
                    try
                    {
                        AvatarState.Set(AvatarUrl);
                    }
                    catch
                    {
                    }

                    AvatarLoaded = true;
                }
            }
        }
        catch
        {
        }
    }

    private string GetRoleClass()
    {
        var s = RoleLabel ?? string.Empty;
        if (string.Equals(s, "admin", StringComparison.OrdinalIgnoreCase)) return "bg-danger";
        if (string.Equals(s, "member", StringComparison.OrdinalIgnoreCase)) return "bg-primary";
        return "bg-success";
    }

    private static string ComputeAvatarUrl(string? email, string? name, string? roleLabel)
    {
        try
        {
            if (!string.IsNullOrWhiteSpace(email))
            {
                var md5 = MD5.HashData(Encoding.UTF8.GetBytes(email.Trim().ToLowerInvariant()));
                var hash = string.Concat(md5.Select(b => b.ToString("x2")));
                return $"https://www.gravatar.com/avatar/{hash}?s=128&d=identicon";
            }
        }
        catch
        {
        }

        if (!string.IsNullOrWhiteSpace(roleLabel) && roleLabel.Equals("admin", StringComparison.OrdinalIgnoreCase))
            return "images/logo.svg"; // default admin avatar
        return "images/avatar.svg";
    }

