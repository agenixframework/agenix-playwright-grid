                    string msg;
                    try
                    {
                        using var doc = JsonDocument.Parse(txt);
                        msg = doc.RootElement.TryGetProperty("error", out var e) ? e.GetString() ?? resp.ReasonPhrase ?? "Password change failed" : resp.ReasonPhrase ?? "Password change failed";
                    }
                    catch
                    {
                        msg = resp.StatusCode == HttpStatusCode.Unauthorized ? "Old password is incorrect" : resp.ReasonPhrase ?? "Password change failed";
                    }

                    PwdError = msg;
                    try
                    {
                        Toasts.Error(msg);
                    }
                    catch
                    {
                    }
                }
                catch
                {
                    PwdError = resp.ReasonPhrase ?? "Password change failed";
