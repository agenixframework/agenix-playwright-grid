            var client = Http.CreateClient(HttpClientNames.Hub);
            using var form = new MultipartFormDataContent();
            await using var stream = file.OpenReadStream(1024 * 1024); // allow up to 1MB; server enforces stricter limit
            using var sc = new StreamContent(stream);
            var ct = string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType;
            sc.Headers.ContentType = new MediaTypeHeaderValue(ct);
            form.Add(sc, "file", string.IsNullOrWhiteSpace(file.Name) ? "avatar" : file.Name);

            using var resp = await client.PostAsync($"/admin/users/{Uri.EscapeDataString(UserId)}/photo", form);
            if (resp.IsSuccessStatusCode)
            {
                await FetchAndSetAvatarAsync();
                try
