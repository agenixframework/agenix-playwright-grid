    // Helper class for grouping tests by suite
    private class SuiteTestGroup
    {
        public string SuiteName { get; set; } = "Unknown Suite";
        public Guid? SuiteId { get; set; }
        public List<TestItemDto> Tests { get; set; } = new();
    }

    private List<SuiteTestGroup> GroupTestsBySuite(List<TestItemDto> allItems)
    {
        // Filter to only Test and Scenario items (not Steps)
        var testItems = allItems
            .Where(item => item.ItemType == "Test" || item.ItemType == "Scenario")
            .ToList();

        // Group by ParentItemId (suite)
        var groupedBySuite = testItems
            .GroupBy(test => test.ParentItemId ?? Guid.Empty)
            .ToList();

        var suiteGroups = new List<SuiteTestGroup>();

        foreach (var group in groupedBySuite)
        {
            var suiteId = group.Key != Guid.Empty ? group.Key : (Guid?)null;
            var suiteName = "Unknown Suite";

            // Try to get suite name from cache
            if (suiteId.HasValue && _affectedTestsCache.TryGetValue(suiteId.Value, out var suiteItem))
            {
                suiteName = suiteItem.Name ?? "Unknown Suite";
            }
            else if (suiteId.HasValue)
            {
                // Load suite from API
                try
                {
                    var http = HttpFactory.CreateClient(HttpClientNames.Hub);
                    http.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);
                    var response = http.GetAsync($"/api/test-items/{suiteId.Value}").Result;
                    if (response.IsSuccessStatusCode)
                    {
                        var suite = response.Content.ReadFromJsonAsync<TestItemDto>().Result;
                        if (suite != null)
                        {
                            _affectedTestsCache[suiteId.Value] = suite;
                            suiteName = suite.Name ?? "Unknown Suite";
                        }
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to load suite {SuiteId}", suiteId);
                }
            }

            suiteGroups.Add(new SuiteTestGroup
            {
                SuiteName = suiteName,
                SuiteId = suiteId,
                Tests = group.OrderBy(t => t.StartTime).ToList()
            });
        }

        // Sort suite groups by suite name
        return suiteGroups.OrderBy(g => g.SuiteName).ToList();
    }

    private long? GetSuiteDbId(Guid suiteId)
    {
        // Try to get suite db_id from cache
        if (_affectedTestsCache.TryGetValue(suiteId, out var suiteItem))
        {
            return suiteItem.DbId;
        }

        // If not in cache, we can't determine db_id - return null to fallback to UUID URL
        return null;
    }

    // View state persistence helpers
    private string GetPageKey()
    {
        return $"suite_{ProjectKey}_{LaunchId}";
    }

    private async Task RestoreViewStateAsync()
    {
        try
        {
            var pageKey = GetPageKey();
            var savedView = await JS.InvokeAsync<string>("getTabState", pageKey, "list");
            _activeView = savedView ?? "list";
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to restore view state");
            _activeView = "list"; // Fallback to default
        }
    }

    private async void SwitchView(string viewName)
    {
        _activeView = viewName;
        try
        {
            var pageKey = GetPageKey();
            await JS.InvokeVoidAsync("saveTabState", pageKey, viewName);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to save view state");
        }

        StateHasChanged();
    }

