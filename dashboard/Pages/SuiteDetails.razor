    private double CalculateElapsedSeconds(LaunchDto launch)
    {
        if (launch.FinishTime.HasValue)
        {
            return (launch.FinishTime.Value - launch.StartTime).TotalSeconds;
        }

        return (DateTimeOffset.UtcNow - launch.StartTime).TotalSeconds;
    }

    private string GetDurationTooltip(LaunchDto launch)
    {
        if (launch.FinishTime.HasValue)
        {
            return $"Completed: {launch.FinishTime.Value.ToLocalTime():g}";
        }

        return "In Progress";
    }

    private string FormatDuration(double seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        if (ts.TotalMinutes < 1)
            return $"{ts.TotalSeconds:F0}s";
        return ts.TotalHours < 1 ? $"{ts.Minutes}m {ts.Seconds}s" : $"{(int)ts.TotalHours}h {ts.Minutes}m";
    }

    private string FormatAgo(DateTimeOffset time)
    {
        var elapsed = DateTimeOffset.UtcNow - time.ToUniversalTime();
        if (elapsed.TotalMinutes < 1)
            return "just now";
        if (elapsed.TotalMinutes < 60)
            return $"{(int)elapsed.TotalMinutes}m ago";
        if (elapsed.TotalHours < 24)
            return $"{(int)elapsed.TotalHours}h ago";
        return $"{(int)elapsed.TotalDays}d ago";
    }

    private async Task InitializeSignalRAsync()
    {
        try
        {
            var hubUrl = Config["HUB_SIGNALR"] ?? "http://hub:5000/ws";
            var uri = new Uri(hubUrl);
            var scheme = uri.Scheme switch { "ws" => "http", "wss" => "https", _ => uri.Scheme };
            var launchesHub = $"{scheme}://{uri.Authority}/hubs/launches";

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(launchesHub)
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On("LaunchUpdated", async () =>
            {
                await LoadDataAsync();
                await InvokeAsync(StateHasChanged);
            });

            _hubConnection.On("SuiteUpdated", async () =>
            {
                await LoadDataAsync();
                await InvokeAsync(StateHasChanged);
            });

            await _hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize SignalR connection for SuiteDetails");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

