    /// <summary>
    ///     Resolves LaunchIdOrNumber to a GUID. Supports both GUID and db_id (globally unique sequential ID per project).
    /// </summary>
    private async Task<bool> ResolveLaunchIdAsync()
    {
        if (string.IsNullOrWhiteSpace(LaunchIdOrNumber))
        {
            Logger.LogError("LaunchIdOrNumber is null or empty");
            return false;
        }

        // Try parsing as GUID first
        if (Guid.TryParse(LaunchIdOrNumber, out var guid))
        {
            LaunchId = guid;
            Logger.LogInformation("Resolved LaunchIdOrNumber as GUID: {LaunchId}", LaunchId);
            return true;
        }

        // Try parsing as long integer (db_id - globally unique sequential ID per project)
        if (long.TryParse(LaunchIdOrNumber, out var dbId))
        {
            try
            {
                var httpClient = HttpFactory.CreateClient(HttpClientNames.Hub);
                httpClient.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);

                Logger.LogInformation("Resolving launch db_id {DbId} to UUID for project {ProjectKey}", dbId, ProjectKey);

                var response = await httpClient.GetAsync($"/api/launches/by-db-id/{ProjectKey}/{dbId}");

                if (response.IsSuccessStatusCode)
                {
                    var launchDto = await response.Content.ReadFromJsonAsync<LaunchDto>();
                    if (launchDto != null)
                    {
                        LaunchId = launchDto.LaunchId;
                        Logger.LogInformation("Resolved launch db_id {DbId} to UUID {LaunchId}", dbId, LaunchId);
                        return true;
                    }
                }
                else
                {
                    var errorContent = await response.Content.ReadAsStringAsync();
                    Logger.LogError("Failed to resolve launch db_id {DbId}: Status={StatusCode}, Error={Error}",
                        dbId, response.StatusCode, errorContent);
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Exception resolving launch db_id {DbId}", dbId);
            }

            return false;
        }

        Logger.LogError("LaunchIdOrNumber is neither a valid GUID nor an integer: {LaunchIdOrNumber}", LaunchIdOrNumber);
        return false;
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var httpClient = HttpFactory.CreateClient(HttpClientNames.Hub);
            httpClient.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);

            Logger.LogInformation("Loading launch details for LaunchId={LaunchId}, ProjectKey={ProjectKey}", LaunchId, ProjectKey);

            // Fetch launch details
            var launchResponse = await httpClient.GetAsync($"/api/launches/{LaunchId}");
            Logger.LogInformation("Launch response status: {StatusCode}", launchResponse.StatusCode);

            if (launchResponse.IsSuccessStatusCode)
            {
                _launch = await launchResponse.Content.ReadFromJsonAsync<LaunchDto>();
                Logger.LogInformation("Launch loaded successfully: {LaunchName}", _launch?.Name);
            }
            else
            {
                var errorContent = await launchResponse.Content.ReadAsStringAsync();
                Logger.LogError("Failed to load launch: Status={StatusCode}, Error={Error}", launchResponse.StatusCode, errorContent);
            }

            // Fetch test items for this launch (using new hierarchical model)
            var testItemsResponse = await httpClient.GetAsync($"/api/launches/{LaunchId}/test-items");
            Logger.LogInformation("Test items response status: {StatusCode}", testItemsResponse.StatusCode);

            if (testItemsResponse.IsSuccessStatusCode)
            {
                var testItems = await testItemsResponse.Content.ReadFromJsonAsync<List<TestItemDto>>();
                Logger.LogInformation("Loaded {Count} test items", testItems?.Count ?? 0);

                // Log item types for debugging
                if (testItems != null)
                {
                    foreach (var item in testItems)
                    {
                        Logger.LogInformation("Test item: Id={Id}, Name={Name}, ItemType={ItemType}, HasParentItemId={HasParentItemId}",
                            item.Id, item.Name, item.ItemType, item.ParentItemId.HasValue);
                    }
                }

                // Filter test items to show only Suite type items
                _suites = testItems?
                    .Where(item => item.ItemType == "Suite")
                    .Select(item => new SuiteSummaryDto
                    {
                        Id = item.Id,
                        LaunchId = LaunchId,
                        DbId = item.DbId,
                        SuiteNumber = item.SuiteNumber,
                        Name = item.Name,
                        Description = item.Description,
                        Attributes = item.Attributes ?? Array.Empty<string>(),
                        Type = item.ItemType ?? "Suite",
                        StartTime = item.StartTime,
                        FinishTime = item.FinishTime,
                        Status = item.ComputedStatus ?? item.SessionStatus ?? "Unknown",
                        DurationSeconds = item.DurationMs.HasValue ? item.DurationMs.Value / 1000.0 : null,
                        TotalTests = item.TotalTests,
                        PassedTests = item.PassedTests,
                        FailedTests = item.FailedTests,
                        SkippedTests = item.SkippedTests,
                        TimedoutTests = item.TimedoutTests
                    })
                    .ToList() ?? [];

                Logger.LogInformation("Filtered to {Count} suites", _suites?.Count ?? 0);
            }
            else
            {
                var errorContent = await testItemsResponse.Content.ReadAsStringAsync();
                Logger.LogError("Failed to load test items: Status={StatusCode}, Error={Error}", testItemsResponse.StatusCode, errorContent);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading launch suites for LaunchId={LaunchId}, ProjectKey={ProjectKey}", LaunchId, ProjectKey);
        }

        // Load unique errors for this launch
        await LoadUniqueErrorsAsync();
    }

    private async Task LoadUniqueErrorsAsync()
    {
        try
        {
            var httpClient = HttpFactory.CreateClient(HttpClientNames.Hub);
            httpClient.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);

            Logger.LogInformation("Loading unique errors for LaunchId={LaunchId}", LaunchId);

            var response = await httpClient.GetAsync($"/api/launches/{LaunchId}/unique-errors");

            if (response.IsSuccessStatusCode)
            {
                _uniqueErrors = await response.Content.ReadFromJsonAsync<List<UniqueErrorDto>>();
                Logger.LogInformation("Loaded {Count} unique error patterns", _uniqueErrors?.Count ?? 0);
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Logger.LogWarning("Failed to load unique errors: Status={StatusCode}, Error={Error}",
                    response.StatusCode, errorContent);
                _uniqueErrors = new List<UniqueErrorDto>();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error loading unique errors for LaunchId={LaunchId}", LaunchId);
            _uniqueErrors = new List<UniqueErrorDto>();
        }
    }

    private async Task ToggleStackTrace(int errorIndex)
    {
        if (_expandedStackTraces.Contains(errorIndex))
        {
            _expandedStackTraces.Remove(errorIndex);
        }
        else
        {
            _expandedStackTraces.Add(errorIndex);

            // Load affected tests asynchronously when expanding
            if (!_loadedAffectedTests.ContainsKey(errorIndex) && _uniqueErrors != null && errorIndex < _uniqueErrors.Count)
            {
                var error = _uniqueErrors[errorIndex];
                var affectedTests = await GetAffectedTestsAsync(error.TestItemIds);
                _loadedAffectedTests[errorIndex] = affectedTests;
                StateHasChanged();
            }
        }
    }

    private bool IsStackTraceExpanded(int errorIndex)
    {
        return _expandedStackTraces.Contains(errorIndex);
    }

    private void FilterByErrorPattern(UniqueErrorDto error)
    {
        // Switch to list view and filter by affected test items
        _activeView = "list";
        _isFilteredByError = true;

        // Clear existing filters
        _filterCriteria.Clear();

        // Add filter for test item IDs affected by this error
        var testIdsString = string.Join(",", error.TestItemIds.Select(id => id.ToString()));
        _filterCriteria.Add(new FilterCriterion
        {
            Field = "id",
            Operator = "in",
            Value = testIdsString
        });

        Logger.LogInformation("Filtering by error pattern: {Fingerprint}, showing {Count} affected tests",
            error.Fingerprint, error.FailedTestCount);

        StateHasChanged();
    }

    private void ClearErrorFilter()
    {
        _isFilteredByError = false;

        // Remove the ID filter
        _filterCriteria.RemoveAll(f => f.Field == "id" && f.Operator == "in");

        StateHasChanged();
    }

