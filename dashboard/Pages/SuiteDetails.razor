    private void OnFieldChange(FilterCriterion filter)
    {
        // Reset operator to appropriate default when field changes
        filter.Operator = filter.Field switch
        {
            "status" => "equals",
            "started_time" => "range",
            "duration" or "total" or "passed" or "failed" or "skipped" => "equals",
            "attribute" => "all",
            _ => "contains"
        };

        // Clear value when field changes
        filter.Value = string.Empty;
        filter.FromDate = string.Empty;
        filter.ToDate = string.Empty;
        filter.DateRangePreset = string.Empty;
        filter.Attributes.Clear();
        StateHasChanged();
    }

    private string GetDateRangeDisplay(FilterCriterion filter)
    {
        if (string.IsNullOrEmpty(filter.DateRangePreset))
            return "Select date range";

        return filter.DateRangePreset switch
        {
            "today" => "Today",
            "last_2_days" => "Last 2 days",
            "last_7_days" => "Last 7 days",
            "last_30_days" => "Last 30 days",
            "custom" => !string.IsNullOrEmpty(filter.FromDate) || !string.IsNullOrEmpty(filter.ToDate)
                ? $"{filter.FromDate} - {filter.ToDate}"
                : "Custom range",
            _ => "Select date range"
        };
    }

    private void SetDateRangePreset(FilterCriterion filter, string preset)
    {
        filter.DateRangePreset = preset;

        var now = DateTimeOffset.UtcNow;
        filter.FromDate = string.Empty;
        filter.ToDate = string.Empty;

        switch (preset)
        {
            case "today":
                filter.FromDate = now.ToString("yyyy-MM-dd");
                filter.ToDate = now.ToString("yyyy-MM-dd");
                break;
            case "last_2_days":
                filter.FromDate = now.AddDays(-2).ToString("yyyy-MM-dd");
                filter.ToDate = now.ToString("yyyy-MM-dd");
                break;
            case "last_7_days":
                filter.FromDate = now.AddDays(-7).ToString("yyyy-MM-dd");
                filter.ToDate = now.ToString("yyyy-MM-dd");
                break;
            case "last_30_days":
                filter.FromDate = now.AddDays(-30).ToString("yyyy-MM-dd");
                filter.ToDate = now.ToString("yyyy-MM-dd");
                break;
            case "custom":
                // User will set dates manually
                break;
        }

        StateHasChanged();
    }

    private void AddAttribute(FilterCriterion filter)
    {
