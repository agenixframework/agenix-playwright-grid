            StateHasChanged();
        }
    }

    private void RemoveAttribute(FilterCriterion filter, AttributePair attr)
    {
        filter.Attributes.Remove(attr);
        StateHasChanged();
    }

    // Filter matching logic
    private bool MatchesCriterion(SuiteSummaryDto suite, FilterCriterion criterion)
    {
        if (string.IsNullOrWhiteSpace(criterion.Value) && criterion.Field != "started_time" && criterion.Field != "attribute" && criterion.Field != "id")
            return true;

        return criterion.Field switch
        {
            "id" => ApplyIdFilter(suite.Id, criterion.Operator, criterion.Value),
            "name" => ApplyStringFilter(suite.Name, criterion.Operator, criterion.Value),
            "description" => ApplyStringFilter(suite.Description ?? "", criterion.Operator, criterion.Value),
            "status" => MatchesStatusFilter(suite, criterion.Value),
            "attribute" => ApplyAttributeFilter(suite.Attributes, criterion.Attributes, criterion.Operator),
            "started_time" => ApplyDateRangeFilter(suite.StartTime, criterion),
            "duration" => ApplyNumericFilter(GetDurationSeconds(suite), criterion.Operator, criterion.Value),
            "total" => ApplyNumericFilter(suite.TotalTests, criterion.Operator, criterion.Value),
            "passed" => ApplyNumericFilter(suite.PassedTests, criterion.Operator, criterion.Value),
            "failed" => ApplyNumericFilter(suite.FailedTests, criterion.Operator, criterion.Value),
            "skipped" => ApplyNumericFilter(suite.SkippedTests, criterion.Operator, criterion.Value),
            _ => true
        };
    }

    private bool ApplyIdFilter(Guid suiteId, string op, string filterValue)
    {
        if (op == "in")
        {
            // Split comma-separated GUIDs and check if suite ID is in the list
            var idList = filterValue.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            return idList.Any(id => Guid.TryParse(id, out var guid) && guid == suiteId);
        }

        return true;
    }

    private bool ApplyStringFilter(string? value, string op, string filterValue)
    {
        if (string.IsNullOrWhiteSpace(value)) return false;

        return op switch
        {
            "contains" => value.Contains(filterValue, StringComparison.OrdinalIgnoreCase),
            "not_contains" => !value.Contains(filterValue, StringComparison.OrdinalIgnoreCase),
            "equals" => string.Equals(value, filterValue, StringComparison.OrdinalIgnoreCase),
            "not_equals" => !string.Equals(value, filterValue, StringComparison.OrdinalIgnoreCase),
            _ => true
        };
    }

    private bool ApplyNumericFilter(double value, string op, string filterValue)
    {
        if (!double.TryParse(filterValue, out var target)) return true;

        return op switch
        {
            "gte" => value >= target,
            "lte" => value <= target,
            "equals" => Math.Abs(value - target) < 0.01,
            _ => true
        };
    }

    private bool ApplyDateRangeFilter(DateTimeOffset date, FilterCriterion criterion)
    {
        if (string.IsNullOrEmpty(criterion.FromDate) && string.IsNullOrEmpty(criterion.ToDate))
            return true;

        var fromDate = string.IsNullOrEmpty(criterion.FromDate) ? DateTimeOffset.MinValue : DateTimeOffset.Parse(criterion.FromDate);
        var toDate = string.IsNullOrEmpty(criterion.ToDate) ? DateTimeOffset.MaxValue : DateTimeOffset.Parse(criterion.ToDate).AddDays(1).AddSeconds(-1);

        return date >= fromDate && date <= toDate;
    }

    private bool MatchesStatusFilter(SuiteSummaryDto suite, string filterValue)
    {
        if (string.IsNullOrWhiteSpace(filterValue)) return true;
        return string.Equals(suite.Status, filterValue, StringComparison.OrdinalIgnoreCase);
    }

    private bool ApplyAttributeFilter(string[]? suiteAttributes, List<AttributePair> filterAttributes, string op)
    {
        if (filterAttributes == null || !filterAttributes.Any()) return true;
        if (suiteAttributes == null || suiteAttributes.Length == 0) return op.StartsWith("without");

        var suiteAttrSet = suiteAttributes.ToHashSet(StringComparer.OrdinalIgnoreCase);

        return op switch
        {
            "all" => filterAttributes.All(fa => suiteAttrSet.Any(sa => MatchesAttribute(sa, fa))),
            "without_all" => !filterAttributes.All(fa => suiteAttrSet.Any(sa => MatchesAttribute(sa, fa))),
            "any" => filterAttributes.Any(fa => suiteAttrSet.Any(sa => MatchesAttribute(sa, fa))),
            "without_any" => !filterAttributes.Any(fa => suiteAttrSet.Any(sa => MatchesAttribute(sa, fa))),
            _ => true
        };
    }

    private bool MatchesAttribute(string suiteAttr, AttributePair filterAttr)
    {
        if (string.IsNullOrWhiteSpace(filterAttr.Value))
        {
            // Match just the key
            return suiteAttr.StartsWith(filterAttr.Key + ":", StringComparison.OrdinalIgnoreCase) ||
                   string.Equals(suiteAttr, filterAttr.Key, StringComparison.OrdinalIgnoreCase);
        }

        // Match key:value
        var expected = $"{filterAttr.Key}:{filterAttr.Value}";
        return string.Equals(suiteAttr, expected, StringComparison.OrdinalIgnoreCase);
    }

    private double GetDurationSeconds(SuiteSummaryDto suite)
    {
        return suite.DurationSeconds ?? (suite.FinishTime.HasValue
            ? (suite.FinishTime.Value - suite.StartTime).TotalSeconds
            : (DateTimeOffset.UtcNow - suite.StartTime).TotalSeconds);
    }

    // Sorting state
    private string _sortBy = "starttime_desc"; // Default sort by start time descending (newest first)

    // Pagination state
    private int _skip;
    private int _take = 25;

    // Sorting and pagination computed properties
    private IEnumerable<SuiteSummaryDto> SortedFilteredSuites
    {
        get
        {
            var filtered = FilteredSuites.AsEnumerable();

            // Apply sorting
            filtered = _sortBy switch
            {
                "name_asc" => filtered.OrderBy(s => s.Name),
                "name_desc" => filtered.OrderByDescending(s => s.Name),
                "starttime_asc" => filtered.OrderBy(s => s.StartTime),
                "starttime_desc" => filtered.OrderByDescending(s => s.StartTime),
                "status_asc" => filtered.OrderBy(s => s.Status),
                "status_desc" => filtered.OrderByDescending(s => s.Status),
                _ => filtered.OrderByDescending(s => s.StartTime) // Default
            };

            return filtered;
        }
    }

    private IEnumerable<SuiteSummaryDto> PagedSuites => SortedFilteredSuites.Skip(_skip).Take(_take);

    // Sorting method
    private void SortBy(string column)
    {
        if (_sortBy.StartsWith(column))
        {
            // Toggle direction
            _sortBy = _sortBy.EndsWith("_asc") ? $"{column}_desc" : $"{column}_asc";
        }
        else
        {
            // New column, default to ascending (except starttime defaults to desc)
            _sortBy = column == "starttime" ? $"{column}_desc" : $"{column}_asc";
        }

        // Reset pagination when sorting changes
        _skip = 0;
        StateHasChanged();
    }

    // Pagination methods
    private void PreviousPage()
    {
        if (_skip > 0)
        {
            _skip = Math.Max(0, _skip - _take);
            StateHasChanged();
        }
    }

    private void NextPage()
    {
        if (_skip + _take < SortedFilteredSuites.Count())
        {
            _skip += _take;
            StateHasChanged();
        }
    }

    private void OnTakeChanged(int newTake)
    {
        _take = newTake;
        _skip = 0; // Reset to first page
        StateHasChanged();
    }

    // Filter icon click handler
    private void AddFilterForField(string fieldName)
    {
        // Check if a filter for this field already exists
        var existingFilter = _filterCriteria.FirstOrDefault(f => f.Field == fieldName);
        if (existingFilter == null)
        {
            // Add new filter criterion for this field
            var newFilter = new FilterCriterion
            {
                Field = fieldName,
                // Set appropriate default operator
                Operator = fieldName switch
                {
                    "status" => "equals",
                    "started_time" => "range",
                    "total" or "passed" or "failed" or "skipped" => "equals",
                    "attribute" => "all",
                    _ => "contains"
                }
            };

            _filterCriteria.Add(newFilter);

            // Show filter panel if it's hidden
            if (!_showFilterPanel)
            {
                _showFilterPanel = true;
            }

            StateHasChanged();
        }
    }

    private sealed class FilterCriterion
    {
        public string Field { get; set; } = "name";
        public string Operator { get; set; } = "contains";
        public string Value { get; set; } = string.Empty;
        public string LogicalOperator { get; set; } = "AND";

        // Date range properties
        public string FromDate { get; set; } = string.Empty;
        public string ToDate { get; set; } = string.Empty;
        public string DateRangePreset { get; set; } = string.Empty;
        public bool ShowDateRangePicker { get; set; }

        // Attribute filter properties
        public List<AttributePair> Attributes { get; set; } = new();
        public string TempAttributeKey { get; set; } = string.Empty;
        public string TempAttributeValue { get; set; } = string.Empty;
    }

    private sealed class AttributePair
    {
        public string Key { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    // Description and attributes expansion tracking
    private readonly HashSet<Guid> _expandedDescriptions = new();
    private readonly HashSet<Guid> _expandedAttributes = new();
    private const int DescriptionPreviewLength = 100;

    private bool IsDescriptionExpanded(Guid suiteId)
    {
        return _expandedDescriptions.Contains(suiteId);
    }

    private bool IsAttributesExpanded(Guid suiteId)
    {
        return _expandedAttributes.Contains(suiteId);
    }

    private void ToggleDescription(Guid suiteId)
    {
        if (_expandedDescriptions.Contains(suiteId))
        {
            _expandedDescriptions.Remove(suiteId);
        }
        else
        {
            _expandedDescriptions.Add(suiteId);
        }

        StateHasChanged();
    }

    private void ToggleAttributes(Guid suiteId)
    {
        if (_expandedAttributes.Contains(suiteId))
        {
            _expandedAttributes.Remove(suiteId);
        }
        else
        {
            _expandedAttributes.Add(suiteId);
        }

        StateHasChanged();
    }

    private bool ShouldTruncateDescription(string? description)
    {
        return !string.IsNullOrEmpty(description) && description.Length > DescriptionPreviewLength;
    }

    private string GetDisplayDescription(Guid suiteId, string? description)
    {
        if (string.IsNullOrEmpty(description)) return string.Empty;

        if (!ShouldTruncateDescription(description) || IsDescriptionExpanded(suiteId))
        {
            return description;
        }

        return description.Substring(0, DescriptionPreviewLength) + "...";
    }

    private void FilterByAttribute(string key, string value)
    {
        // Add filter for attribute key:value
        var existingFilter = _filterCriteria.FirstOrDefault(f => f.Field == "attribute");
        if (existingFilter == null)
        {
            var newFilter = new FilterCriterion
            {
                Field = "attribute",
                Operator = "all",
                Attributes = new List<AttributePair> { new() { Key = key, Value = value } }
            };
            _filterCriteria.Add(newFilter);
        }
        else
        {
            // Add to existing attribute filter if not already present
            if (!existingFilter.Attributes.Any(a => a.Key == key && a.Value == value))
            {
                existingFilter.Attributes.Add(new AttributePair { Key = key, Value = value });
            }
        }

        _showFilterPanel = true;
        StateHasChanged();
    }

    private void FilterByTag(string tag)
    {
        // Add filter for tag (attribute without key)
        var existingFilter = _filterCriteria.FirstOrDefault(f => f.Field == "attribute");
        if (existingFilter == null)
        {
            var newFilter = new FilterCriterion
            {
                Field = "attribute",
                Operator = "all",
                Attributes = new List<AttributePair> { new() { Key = tag, Value = string.Empty } }
            };
            _filterCriteria.Add(newFilter);
        }
        else
        {
            // Add to existing attribute filter if not already present
            if (!existingFilter.Attributes.Any(a => a.Key == tag && string.IsNullOrEmpty(a.Value)))
            {
                existingFilter.Attributes.Add(new AttributePair { Key = tag, Value = string.Empty });
            }
        }

        _showFilterPanel = true;
        StateHasChanged();
    }

    private string GetSuiteDurationTooltip(SuiteSummaryDto suite)
    {
        var startLocal = suite.StartTime.ToLocalTime();

        // Check if suite is actually in progress
        var isRunning = suite.Status?.Equals("InProgress", StringComparison.OrdinalIgnoreCase) == true ||
                        suite.Status?.Equals("Running", StringComparison.OrdinalIgnoreCase) == true;

        if (suite.FinishTime.HasValue)
        {
            var finishLocal = suite.FinishTime.Value.ToLocalTime();
            var duration = suite.FinishTime.Value - suite.StartTime;
            var durationText = duration.TotalMinutes < 1
                ? $"{duration.TotalSeconds:F1}s"
                : duration.TotalHours < 1
                    ? $"{duration.Minutes}m {duration.Seconds}s"
                    : $"{(int)duration.TotalHours}h {duration.Minutes}m";
            return $"Duration: {durationText}\nFinish time: {finishLocal:yyyy-MM-dd HH:mm:ss} UTC{finishLocal:zzz}";
        }

        if (isRunning)
        {
            return $"Start time: {startLocal:yyyy-MM-dd HH:mm:ss} UTC{startLocal:zzz}\nIn Progress...";
        }

        // Suite completed but FinishTime not set - show start time only
        return $"Start time: {startLocal:yyyy-MM-dd HH:mm:ss} UTC{startLocal:zzz}";
    }

    private RenderFragment RenderDonut(int centerValue, int totalTests, int passed, int failed, int skipped, int timedout, bool showPercentage, string type)
    {
        const int size = 50;
        const double radius = 20.0; // 50 * 0.4
        const double strokeWidth = 10.0; // 50 * 0.2
        const double circumference = 2 * Math.PI * radius;

        return __builder =>
        {
            <div class="donut-wrapper">
                <svg class="donut-svg" width="@size" height="@size" viewBox="0 0 @size @size">
                    @* Background circle *@
                    <circle cx="@(size / 2)" cy="@(size / 2)" r="@radius"
                            fill="none" stroke="#E5E7EB" stroke-width="@strokeWidth"/>

                    @* Segments - render passed, failed, skipped *@
                    @{
                        double offset = 0;

                        // Green segment (passed)
                        if (passed > 0)
                        {
                            var segmentLength = passed / (double)totalTests * circumference;
                            <circle cx="@(size / 2)" cy="@(size / 2)" r="@radius"
                                    fill="none"
                                    stroke="#10B981"
                                    stroke-width="@strokeWidth"
                                    stroke-dasharray="@(segmentLength.ToString(CultureInfo.InvariantCulture)) @(circumference.ToString(CultureInfo.InvariantCulture))"
                                    stroke-dashoffset="@((-offset).ToString(CultureInfo.InvariantCulture))"
                                    opacity="0.9"/>
                            offset += segmentLength;
                        }

                        // Red segment (failed)
                        if (failed > 0)
                        {
                            var segmentLength = failed / (double)totalTests * circumference;
                            <circle cx="@(size / 2)" cy="@(size / 2)" r="@radius"
                                    fill="none"
                                    stroke="#EF4444"
                                    stroke-width="@strokeWidth"
                                    stroke-dasharray="@(segmentLength.ToString(CultureInfo.InvariantCulture)) @(circumference.ToString(CultureInfo.InvariantCulture))"
                                    stroke-dashoffset="@((-offset).ToString(CultureInfo.InvariantCulture))"
                                    opacity="0.9"/>
                            offset += segmentLength;
                        }

                        // Orange segment (skipped)
                        if (skipped > 0)
                        {
                            var segmentLength = skipped / (double)totalTests * circumference;
                            <circle cx="@(size / 2)" cy="@(size / 2)" r="@radius"
                                    fill="none"
                                    stroke="#F59E0B"
                                    stroke-width="@strokeWidth"
                                    stroke-dasharray="@(segmentLength.ToString(CultureInfo.InvariantCulture)) @(circumference.ToString(CultureInfo.InvariantCulture))"
                                    stroke-dashoffset="@((-offset).ToString(CultureInfo.InvariantCulture))"
                                    opacity="0.9"/>
                        }
                    }
                </svg>
                <div class="donut-center">@centerValue</div>
                @if (showPercentage && centerValue > 0 && totalTests > 0)
                {
                    var percentage = (centerValue / (double)totalTests * 100).ToString("F1");
                    <div class="percentage-badge @type">@percentage%</div>
                }
            </div>
        };
    }

    // Cache for affected test items to avoid repeated API calls
    private readonly Dictionary<Guid, TestItemDto> _affectedTestsCache = new();

    private async Task<List<TestItemDto>> GetAffectedTestsAsync(List<Guid> testItemIds)
    {
        var result = new List<TestItemDto>();
        var processedTestIds = new HashSet<Guid>(); // Track unique test items to avoid duplicates

        foreach (var itemId in testItemIds)
        {
            // Check cache first
            if (!_affectedTestsCache.TryGetValue(itemId, out var item))
            {
                // Load from API if not cached
                try
                {
                    var http = HttpFactory.CreateClient(HttpClientNames.Hub);
                    http.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);

                    var response = await http.GetAsync($"/api/test-items/{itemId}");
                    if (response.IsSuccessStatusCode)
                    {
                        item = await response.Content.ReadFromJsonAsync<TestItemDto>();
                        if (item != null)
                        {
                            _affectedTestsCache[itemId] = item;
                        }
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to load test item {ItemId}", itemId);
                    continue;
                }
            }

            if (item == null) continue;

            // If this is a Step, trace up to find the parent Test/Scenario
            var testItem = await FindParentTestAsync(item);

            if (testItem != null && !processedTestIds.Contains(testItem.Id))
            {
                result.Add(testItem);
                processedTestIds.Add(testItem.Id);
            }
        }

        return result;
    }

    private async Task<TestItemDto?> FindParentTestAsync(TestItemDto item)
    {
        // If this is already a Test or Scenario, return it
        if (item.ItemType == "Test" || item.ItemType == "Scenario")
        {
            return item;
        }

        // If this is a Step (or other nested type), trace up to find the parent Test
        var currentItem = item;
        var maxDepth = 10; // Prevent infinite loops
        var depth = 0;

        while (currentItem.ParentItemId.HasValue && depth < maxDepth)
        {
            var parentId = currentItem.ParentItemId.Value;

            // Check cache first
            if (!_affectedTestsCache.TryGetValue(parentId, out var parentItem))
            {
                // Load parent from API
                try
                {
                    var http = HttpFactory.CreateClient(HttpClientNames.Hub);
                    http.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);

                    var response = await http.GetAsync($"/api/test-items/{parentId}");
                    if (response.IsSuccessStatusCode)
                    {
                        parentItem = await response.Content.ReadFromJsonAsync<TestItemDto>();
                        if (parentItem != null)
                        {
                            _affectedTestsCache[parentId] = parentItem;
                        }
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to load parent item {ParentId}", parentId);
                    break;
                }
            }

            if (parentItem == null) break;

            // If we found a Test or Scenario, return it
            if (parentItem.ItemType == "Test" || parentItem.ItemType == "Scenario")
            {
                return parentItem;
            }

            // Continue traversing up the hierarchy
            currentItem = parentItem;
            depth++;
        }

        // If we couldn't find a Test parent, return null (will be filtered out)
        return null;
    }

