    private string GetTestResultsSummary()
    {
        if (_run == null) return "";
        var parts = new List<string>();
        if (_run.Passed > 0) parts.Add($"{_run.Passed} passed");
        if (_run.Failed > 0) parts.Add($"{_run.Failed} failed");
        if (_run.Skipped > 0) parts.Add($"{_run.Skipped} skipped");
        if (_run.TimedOut > 0) parts.Add($"{_run.TimedOut} timed out");
        return parts.Count > 0 ? $"({string.Join(", ", parts)})" : $"({_run.TotalTests} tests)";
    }

