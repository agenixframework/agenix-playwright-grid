    protected override async Task OnParametersSetAsync()
    {
        // If the component is re-parameterized (e.g., same page navigated quickly), make sure we don't stack connections
        if (_conn is not null)
        {
            try
            {
                await _conn.DisposeAsync();
            }
            catch
            {
            }

            _conn = null;
        }

        var http = HttpFactory.CreateClient(HttpClientNames.Hub);
        var got404 = false;

        try
        {
            var resp = await http.GetAsync($"/results/{runId}");
            if (!resp.IsSuccessStatusCode)
            {
                if (resp.StatusCode == HttpStatusCode.NotFound)
                    got404 = true;
            }
            else
            {
                var run = await resp.Content.ReadFromJsonAsync<ResultRunSummaryDto>();
                lock (_gate)
                {
                    _run = run;
                }
            }
        }
        catch
        {
        }

        // Load test cases
        try
        {
            var testCasesResp = await http.GetAsync($"/api/runs/{runId}/tests");
            if (testCasesResp.IsSuccessStatusCode)
            {
                _testCases = await testCasesResp.Content.ReadFromJsonAsync<List<TestCaseDetailDto>>();
            }
            else
            {
                _testCases = new List<TestCaseDetailDto>();
            }
        }
        catch
        {
            _testCases = new List<TestCaseDetailDto>();
        }

        // Try to load hierarchical test items (Phase 7 integration)
        try
        {
            // Attempt to get test items for this run (if run has been converted to test item)
            var testItemResp = await http.GetAsync($"/api/test-items/{runId}/tree?maxDepth=5");
            if (testItemResp.IsSuccessStatusCode)
            {
                var rootItem = await testItemResp.Content.ReadFromJsonAsync<TestItemDto>();
                _testItems = rootItem != null ? new List<TestItemDto> { rootItem } : new List<TestItemDto>();
            }
            else
            {
                _testItems = new List<TestItemDto>();
            }
        }
        catch
        {
            // Test items not available - not an error, just means this run doesn't use hierarchical model yet
            _testItems = new List<TestItemDto>();
        }

        // Try to enable server-driven paging: query count and load first page
        var enabledServerPaging = await TryEnableServerPagingAsync();
        if (!enabledServerPaging)
        {
            // Fallback: fetch initial slice and do client-side paging
            try
            {
                var cmdsResp = await http.GetAsync($"/results/{runId}/commands?take=200");
                var cmds = (cmdsResp.IsSuccessStatusCode
                    ? await cmdsResp.Content.ReadFromJsonAsync<List<CommandLogEventDto>>()
                    : new List<CommandLogEventDto>()) ?? new List<CommandLogEventDto>();
                lock (_gate)
                {
                    _commands = cmds;
                }

                ResetCmdPage();
                ClampPage();
            }
            catch
            {
                lock (_gate)
                {
                    _commands = new List<CommandLogEventDto>();
                }

                ResetCmdPage();
                ClampPage();
            }

            // No simulated data - only show real browser commands from database
            // Only Test and Scenario types should have real browser events logged
            lock (_gate)
            {
                runNotFound = got404 && _run is null && _commands.Count == 0;
            }

            // Ensure pagination is consistent after initial load/seeding
            ResetCmdPage();
            ClampPage();
        }

        // Live updates (create a single connection per page instance)
        var hubUrl = Config["HUB_SIGNALR"] ?? "http://hub:5000/ws";
        try
        {
            var uri = new Uri(hubUrl);
            var scheme = uri.Scheme switch { "ws" => "http", "wss" => "https", _ => uri.Scheme };
            var resultsWs = $"{scheme}://{uri.Authority}/results-ws";

            _conn = new HubConnectionBuilder()
                .WithUrl(resultsWs)
                .WithAutomaticReconnect()
                .Build();

            _conn.On<ResultRunSummaryDto>("RunUpdate", run =>
                InvokeAsync(() =>
                {
                    if (_disposed) return;
                    if (!string.Equals(run.RunId, runId, StringComparison.OrdinalIgnoreCase)) return;
                    lock (_gate)
                    {
                        _run = run;
                        runNotFound = false;
                    }

                    StateHasChanged();
                }));

            _conn.On("CommandLogChunk", (CommandLogEventDto[] items) =>
            {
                if (_disposed) return;
                if (items == null || items.Length == 0) return;

                if (_useServerPaging)
                {
                    // Increase count for this run and refresh last page
                    var added = items.Count(it => string.Equals(it.RunId, runId, StringComparison.OrdinalIgnoreCase));
                    if (added > 0)
                    {
                        _serverCmdCount += added;
                        // If on last page, reload it to include new items
                        if (CmdPage == CmdTotalPages)
                        {
                            _ = LoadServerPageAsync(CmdPage);
                        }

                        _ = InvokeAsync(StateHasChanged);
                    }
                }
                else
                {
                    lock (_gate)
                    {
                        _commands ??= new List<CommandLogEventDto>();
                        foreach (var it in items)
                        {
                            if (string.Equals(it.RunId, runId, StringComparison.OrdinalIgnoreCase))
                                _commands.Add(it);
                        }

                        _commands = _commands.OrderBy(c => c.TimestampUtc).TakeLast(1000).ToList();
                    }

                    ClampPage();
                    _ = InvokeAsync(StateHasChanged);
                }
            });

            // SignalR test case updates
            _conn.On<ResultTestCaseDto>("TestUpdate", testCase =>
            {
                InvokeAsync(() =>
                {
                    if (_disposed) return;
                    if (!string.Equals(testCase.RunId, runId, StringComparison.OrdinalIgnoreCase)) return;

                    lock (_gate)
                    {
                        _testCases ??= new List<TestCaseDetailDto>();

                        // Convert ResultTestCaseDto to TestCaseDetailDto
                        var detailedTest = new TestCaseDetailDto
                        {
                            RunId = testCase.RunId,
                            TestId = testCase.TestId,
                            TestTitle = testCase.Title,
                            TestFile = testCase.File,
                            Status = testCase.Status,
                            StartTime = DateTime.UtcNow,
                            EndTime = null,
                            DurationMs = testCase.DurationMs,
                            ErrorMessage = testCase.ErrorMessage,
                            ErrorStack = testCase.ErrorStack
                        };

                        var existing = _testCases.FirstOrDefault(t => t.TestId == testCase.TestId);
                        if (existing != null)
                            _testCases.Remove(existing);
                        _testCases.Add(detailedTest);
                    }

                    StateHasChanged();
                });
            });

            // SignalR test item updates (Phase 9 - Real-time hierarchical updates)
            _conn.On<TestItemDto>("TestItemUpdated", testItem =>
            {
                InvokeAsync(() =>
                {
                    if (_disposed) return;
                    if (_testItems == null) return;

                    lock (_gate)
                    {
                        // Update or add the test item in the hierarchical structure
                        UpdateTestItemInTree(testItem);
                    }

                    StateHasChanged();
                });
            });

            _conn.On<Guid, string?, string?>("TestItemStatusChanged", (itemId, sessionStatus, computedStatus) =>
            {
                InvokeAsync(() =>
                {
                    if (_disposed) return;
                    if (_testItems == null) return;

                    lock (_gate)
                    {
                        // Find and update the test item status
                        UpdateTestItemStatus(itemId, sessionStatus, computedStatus);
                    }

                    StateHasChanged();
                });
            });

            await _conn.StartAsync();
            await _conn.SendAsync("JoinRun", runId);
        }
        catch
        {
            // ignore live update errors for now
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_conn != null)
        {
            try
            {
                await _conn.SendAsync("LeaveRun", runId);
            }
            catch
            {
            }

            try
            {
                await _conn.DisposeAsync();
            }
            catch
            {
            }

            _conn = null;
        }
    }

    // Phase 9: Helper methods for real-time test item updates
    private void UpdateTestItemInTree(TestItemDto updatedItem)
    {
        if (_testItems == null) return;

        // Find and update the item in the tree (recursive search)
        for (var i = 0; i < _testItems.Count; i++)
        {
            if (_testItems[i].Id == updatedItem.Id)
            {
                // Found at root level - replace it
                _testItems[i] = updatedItem;
                return;
            }

            // Search in children recursively
            if (UpdateItemInChildren(_testItems[i], updatedItem))
                return;
        }

        // If not found, add as new root item (shouldn't happen normally)
        _testItems.Add(updatedItem);
    }

    private bool UpdateItemInChildren(TestItemDto parent, TestItemDto updatedItem)
    {
        if (parent.Children == null) return false;

        for (var i = 0; i < parent.Children.Count; i++)
        {
            if (parent.Children[i].Id == updatedItem.Id)
            {
                // Found in children - need to create new parent with updated child (immutable records)
                var newChildren = parent.Children.ToList();
                newChildren[i] = updatedItem;

                // Update the parent in the main list
                UpdateParentWithNewChildren(parent.Id, newChildren);
                return true;
            }

            // Search deeper
            if (UpdateItemInChildren(parent.Children[i], updatedItem))
                return true;
        }

        return false;
    }

    private void UpdateParentWithNewChildren(Guid parentId, List<TestItemDto> newChildren)
    {
        if (_testItems == null) return;

        for (var i = 0; i < _testItems.Count; i++)
        {
            if (_testItems[i].Id == parentId)
            {
                _testItems[i] = _testItems[i] with { Children = newChildren };
                return;
            }

            // Search in children
            UpdateParentInChildren(_testItems[i], parentId, newChildren);
        }
    }

    private bool UpdateParentInChildren(TestItemDto item, Guid targetParentId, List<TestItemDto> newChildren)
    {
        if (item.Children == null) return false;

        for (var i = 0; i < item.Children.Count; i++)
        {
            if (item.Children[i].Id == targetParentId)
            {
                var updatedChildren = item.Children.ToList();
                updatedChildren[i] = updatedChildren[i] with { Children = newChildren };

                // Need to update this item's parent now
                UpdateParentWithNewChildren(item.Id, updatedChildren);
                return true;
            }

            if (UpdateParentInChildren(item.Children[i], targetParentId, newChildren))
                return true;
        }

        return false;
    }

    private void UpdateTestItemStatus(Guid itemId, string? sessionStatus, string? computedStatus)
    {
        if (_testItems == null) return;

        // Find and update status in the tree
        for (var i = 0; i < _testItems.Count; i++)
        {
            if (_testItems[i].Id == itemId)
            {
                _testItems[i] = _testItems[i] with
                {
                    SessionStatus = sessionStatus ?? _testItems[i].SessionStatus,
                    ComputedStatus = computedStatus ?? _testItems[i].ComputedStatus
                };
                return;
            }

            // Search in children
            if (UpdateStatusInChildren(_testItems[i], itemId, sessionStatus, computedStatus))
                return;
        }
    }

    private bool UpdateStatusInChildren(TestItemDto parent, Guid itemId, string? sessionStatus, string? computedStatus)
    {
        if (parent.Children == null) return false;

        for (var i = 0; i < parent.Children.Count; i++)
        {
            if (parent.Children[i].Id == itemId)
            {
                var updatedChild = parent.Children[i] with
                {
                    SessionStatus = sessionStatus ?? parent.Children[i].SessionStatus,
                    ComputedStatus = computedStatus ?? parent.Children[i].ComputedStatus
                };

                var newChildren = parent.Children.ToList();
                newChildren[i] = updatedChild;
                UpdateParentWithNewChildren(parent.Id, newChildren);
                return true;
            }

            if (UpdateStatusInChildren(parent.Children[i], itemId, sessionStatus, computedStatus))
                return true;
        }

        return false;
    }

    private async Task Copy(CommandLogEventDto ev)
    {
        var props = ev.Props is null || ev.Props.Count == 0
            ? string.Empty
            : string.Join(" ", ev.Props.Select(kv => $"{kv.Key}={kv.Value}"));
        var text = $"{ev.TimestampUtc:o} [{ev.Kind}] {ev.Message} {props}".Trim();
        try
        {
            await JS.InvokeVoidAsync("copyText", text);
            await JS.InvokeVoidAsync("alert", "Command copied to clipboard");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Copy command failed for run {RunId}", _run?.RunId);
        }
    }

    private MarkupString RenderPlaywrightProtocol(CommandLogEventDto ev)
    {
        var dir = "";
        if (ev.Props != null && ev.Props.TryGetValue("direction", out var d)) dir = d ?? "";
        var badgeClass = string.Equals(dir, "c2s", StringComparison.OrdinalIgnoreCase) ? "primary" : "info";
        var dirBadge = string.IsNullOrWhiteSpace(dir) ? string.Empty : $"<span class=\"badge bg-{badgeClass} me-2\">{dir}</span>";

        var text = ev.Message ?? string.Empty;
        var pretty = text;
        try
        {
            using var doc = JsonDocument.Parse(text);
            pretty = JsonSerializer.Serialize(doc.RootElement, new JsonSerializerOptions
            {
                WriteIndented = true
            });
        }
        catch
        {
            /* leave as-is if not JSON */
        }

        // Encode content to avoid HTML injection; keep our own badges unencoded
        var encoded = WebUtility.HtmlEncode(pretty);
        var html = $"{dirBadge}<pre class=\"mb-0 small\" style=\"white-space:pre-wrap; overflow:auto; max-height:24rem;\">{encoded}</pre>";
        return new MarkupString(html);
    }

