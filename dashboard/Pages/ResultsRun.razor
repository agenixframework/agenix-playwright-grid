            </div>
        </div>
    }

    <ConfirmDialog @ref="Confirm"/>
</div>

@code {
    private ConfirmDialog? Confirm;
    [Parameter] public string runId { get; set; } = string.Empty;
    [Parameter] public string? projectKey { get; set; }
    [Parameter] public Guid? launchId { get; set; }
    [Parameter] public Guid? suiteId { get; set; }

    private ResultRunSummaryDto? _run;
    private bool runNotFound;
    private List<CommandLogEventDto>? _commands;
    private HubConnection? _conn;
    private bool _disposed;

    // Test cases state
    private List<TestCaseDetailDto>? _testCases;
    private List<TestItemDto>? _testItems; // Hierarchical test items
    private string _testCaseViewMode = "legacy"; // "legacy" or "hierarchical"

    // Tab management
    private string MainTab = "logs"; // Main tab (logs, attachments, details, history)
    private string ActiveTab = "tests"; // Sub-tab for logs (tests or commands)
    private string ViewMode = "list"; // View mode for logs tab (list or history)

    // Client-side detected OS for display when server OS is missing
    private string? _displayOs;

    private bool NeedsOsDetect()
    {
        return string.IsNullOrWhiteSpace(_run?.OS) || _run!.OS == "-";
    }

    private string GetDisplayOS()
    {
        return NeedsOsDetect() ? _displayOs ?? "-" : _run!.OS ?? "-";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Only attempt detection once and only if server OS is missing
        if (_displayOs is null && NeedsOsDetect())
        {
            try
            {
                var detected = await JS.InvokeAsync<string>("detectOS");
                if (!string.IsNullOrWhiteSpace(detected) && detected != "-")
                    _displayOs = detected;
                else
                    _displayOs = "-";
            }
            catch
            {
                _displayOs = "-"; // keep safe fallback for tests/non-browser renderers
            }

            StateHasChanged();
        }
    }

    // Add a gate to serialize all mutations and snapshot reads
    private readonly object _gate = new();

    private string cmdKindFilter = string.Empty;
    private string cmdDirectionFilter = string.Empty;

    // Pagination state for Commands
    private int CmdPage = 1;
    private readonly int CmdPageSize = 50;

    // Server-driven paging state
    private bool _useServerPaging;
    private int _serverCmdCount;
    private List<CommandLogEventDto> _pageBuffer = new();

    private int CmdTotal => _useServerPaging ? _serverCmdCount : FilteredCommands.Count;
    private int CmdTotalPages => Math.Max(1, (int)Math.Ceiling(CmdTotal / (double)CmdPageSize));
    private int PageStart => CmdTotal == 0 ? 0 : (CmdPage - 1) * CmdPageSize + 1;
    private int PageEnd => Math.Min(CmdPage * CmdPageSize, CmdTotal);

    private List<CommandLogEventDto> PagedCommands
    {
        get
        {
            if (_useServerPaging)
            {
                // Apply client-side filters over server-provided page
                return _pageBuffer
                    .Where(c => string.IsNullOrWhiteSpace(cmdKindFilter) || c.Kind?.Contains(cmdKindFilter, StringComparison.OrdinalIgnoreCase) == true)
                    .Where(c =>
                    {
                        if (string.IsNullOrWhiteSpace(cmdDirectionFilter)) return true;
                        var dir = string.Empty;
                        if (c.Props != null && c.Props.TryGetValue("direction", out var d) && d != null)
                            dir = d;
                        return dir.Contains(cmdDirectionFilter, StringComparison.OrdinalIgnoreCase);
                    })
                    .OrderBy(c => c.TimestampUtc)
                    .ToList();
            }

            var list = FilteredCommands;
            var skip = Math.Max(0, (CmdPage - 1) * CmdPageSize);
            return list.Skip(skip).Take(CmdPageSize).ToList();
        }
    }

    private async Task PrevCmdPage()
    {
        if (CmdPage > 1)
        {
            CmdPage--;
            if (_useServerPaging)
                await LoadServerPageAsync(CmdPage);
            StateHasChanged();
        }
    }

    private async Task NextCmdPage()
    {
        var total = CmdTotalPages;
        if (CmdPage < total)
        {
            CmdPage++;
            if (_useServerPaging)
                await LoadServerPageAsync(CmdPage);
            StateHasChanged();
        }
    }

    private void ResetCmdPage()
    {
        CmdPage = 1;
    }

    private void ClampPage()
    {
        var total = CmdTotalPages;
        if (CmdPage > total) CmdPage = total;
        if (CmdPage < 1) CmdPage = 1;
    }

    private List<CommandLogEventDto> FilteredCommands
    {
        get
        {
            List<CommandLogEventDto> snap;
            lock (_gate)
            {
                snap = (_commands ?? new List<CommandLogEventDto>()).ToList();
            }

            return snap
                .Where(c => string.IsNullOrWhiteSpace(cmdKindFilter) || c.Kind?.Contains(cmdKindFilter, StringComparison.OrdinalIgnoreCase) == true)
                .Where(c =>
                {
                    if (string.IsNullOrWhiteSpace(cmdDirectionFilter)) return true;
                    var dir = string.Empty;
                    if (c.Props != null && c.Props.TryGetValue("direction", out var d) && d != null)
                        dir = d;
                    return dir.Contains(cmdDirectionFilter, StringComparison.OrdinalIgnoreCase);
                })
                .OrderBy(c => c.TimestampUtc)
                .ToList();
        }
    }

    // Method to handle input changes - explicitly defined for testing
    private void OnKindInput(ChangeEventArgs e)
    {
        cmdKindFilter = e.Value?.ToString() ?? string.Empty;
        ResetCmdPage();
        StateHasChanged();
    }

    private void OnDirectionInput(ChangeEventArgs e)
    {
        cmdDirectionFilter = e.Value?.ToString() ?? string.Empty;
        ResetCmdPage();
        StateHasChanged();
    }

    private void SetKindFilter(string kind)
    {
        cmdKindFilter = kind ?? string.Empty;
        ResetCmdPage();
        StateHasChanged();
    }

    private void ClearKindFilter()
    {
        cmdKindFilter = string.Empty;
        ResetCmdPage();
        StateHasChanged();
    }

    private int CommandCount
    {
        get
        {
            lock (_gate)
            {
                return _commands?.Count ?? 0;
            }
        }
    }

    private Dictionary<string, int> KindCounts
    {
        get
        {
            List<CommandLogEventDto> snap;
            lock (_gate)
            {
                snap = (_commands ?? new List<CommandLogEventDto>()).ToList();
            }

            return snap
                .GroupBy(c => string.IsNullOrWhiteSpace(c.Kind) ? "(none)" : c.Kind)
                .ToDictionary(g => g.Key, g => g.Count(), StringComparer.OrdinalIgnoreCase);
        }
    }

    private string DurationText()
    {
        var run = _run;
        if (run == null) return "-";
        var start = run.StartedAtUtc;
        var end = run.CompletedAtUtc ?? DateTime.UtcNow;
        if (end < start) end = start;
        var span = end - start;
        if (span.TotalSeconds < 1) return "<1s";
        if (span.TotalMinutes < 1) return $"{(int)span.TotalSeconds}s";
        if (span.TotalHours < 1) return $"{(int)span.TotalMinutes}m {span.Seconds}s";
        return $"{(int)span.TotalHours}h {span.Minutes}m";
    }

