    private sealed class CountResponse
    {
        public int count { get; set; }
        public int Count { get; set; }
    }

    private async Task<bool> TryEnableServerPagingAsync()
    {
        try
        {
            var http = HttpFactory.CreateClient(HttpClientNames.Hub);
            var resp = await http.GetAsync($"/results/{runId}/commands/count");
            if (!resp.IsSuccessStatusCode) return false;
            var payload = await resp.Content.ReadFromJsonAsync<CountResponse>();
            var count = payload?.count > 0 ? payload!.count : payload?.Count ?? 0;
            _useServerPaging = true;
            _serverCmdCount = Math.Max(0, count);
            await LoadServerPageAsync(1);
            ResetCmdPage();
            ClampPage();
            return true;
        }
        catch
        {
            _useServerPaging = false;
            return false;
        }
    }

    private async Task LoadServerPageAsync(int page)
    {
        if (page < 1) page = 1;
        var skip = (page - 1) * CmdPageSize;
        try
        {
            var http = HttpFactory.CreateClient(HttpClientNames.Hub);
            var url = $"/results/{runId}/commands?skip={skip}&take={CmdPageSize}";
            var items = await http.GetFromJsonAsync<List<CommandLogEventDto>>(url) ?? new List<CommandLogEventDto>();
            _pageBuffer = items.OrderBy(c => c.TimestampUtc).ToList();
        }
        catch
        {
            _pageBuffer = new List<CommandLogEventDto>();
        }
    }

