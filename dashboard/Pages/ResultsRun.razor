    @if (MainTab == "details")
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        @* Dual Status Display: Test Outcomes and Browser Session *@
                        <div class="status-container mb-2">
                            @* Primary: Test Outcome Status *@
                            <div class="mb-1">
                                <span class="text-muted">Tests:</span>
                                <span class="badge @GetTestStatusBadgeClass(_run!.ComputedStatus ?? _run.Status)">
                                @GetTestStatusDisplay(_run!.ComputedStatus ?? _run.Status)
                            </span>
                                <span class="ms-2 small text-muted">
                                @GetTestResultsSummary()
                            </span>
                            </div>

                            @* Secondary: Browser Session Status (only show if problematic) *@
                            @if (IsBrowserSessionProblematic(_run!.SessionStatus ?? _run.Status))
                            {
                                <div>
                                    <span class="text-muted">Browser:</span>
                                    <span class="badge @GetSessionStatusBadgeClass(_run!.SessionStatus ?? _run.Status)"
                                          title="@GetSessionStatusTooltip(_run!.SessionStatus ?? _run.Status)">
                                    @GetSessionStatusDisplay(_run!.SessionStatus ?? _run.Status)
                                </span>
                                    <span class="ms-2 small text-warning">
                                    ⚠️ Infrastructure issue - browser session did not close cleanly
                                </span>
                                </div>
                            }
                        </div>

                        <div class="small text-muted">App: @_run!.App · Browser: @_run.Browser · Env: @_run.Env</div>
                        <div class="small text-muted">Region/OS: @(_run!.Region ?? "-") / @GetDisplayOS()</div>
                    </div>
                    <div class="text-end small text-muted">
                        <div>Started: @_run!.StartedAtUtc.ToLocalTime().ToString("g")</div>
                        @if (_run!.CompletedAtUtc is not null)
                        {
                            <div>Completed: @_run.CompletedAtUtc.Value.ToLocalTime().ToString("g")</div>
                        }
                        <div>Node: @(_run.WorkerNodeId ?? "-")</div>
                        <div>
                            PW/Browsers: @(string.Join(" / ", new[] { _run.PlaywrightVersion, _run.BrowserVersion }.Where(x => !string.IsNullOrWhiteSpace(x))))</div>
                    </div>
                </div>
                <div class="d-flex flex-wrap align-items-center gap-2 mt-3">
                    <button class="btn btn-sm btn-outline-secondary" title="Copy RunId" @onclick="CopyRunId">Copy RunId
                    </button>
                    @if (!string.IsNullOrWhiteSpace(_run.ExternalId))
                    {
                        <button class="btn btn-sm btn-outline-secondary" title="Copy ExternalId"
                                @onclick="CopyExternalId">
                            Copy ExternalId
