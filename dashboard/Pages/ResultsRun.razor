@page "/results/{runId}"
@using System.Net.Http
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components
@implements IAsyncDisposable
@inject IHttpClientFactory HttpFactory
@inject IConfiguration Config
@inject IJSRuntime JS
@inject ILogger<ResultsRun> Logger

<div class="d-flex align-items-center justify-content-between my-3">
    <h3 class="mb-0">Run @Short(runId)</h3>
    <a href="/results" class="btn btn-sm btn-outline-secondary" title="Back to Runs">&larr; Back to Runs</a>
</div>

@if (runNotFound)
{
    <div class="alert alert-warning">
        Run not found. <a href="/results">Back to runs</a>
    </div>
}
else if (_run == null)
{
    <div class="alert alert-info">Loading run...</div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between">
                <div>
                    <div><span class="text-muted">Status:</span> <span
                            class="badge @StatusBadgeClass(_run.Status)">@_run.Status</span></div>
                    <div class="small text-muted">App: @_run.App · Browser: @_run.Browser · Env: @_run.Env</div>
                    <div class="small text-muted">Region/OS: @(_run.Region ?? "-") / @GetDisplayOS()</div>
                </div>
                <div class="text-end small text-muted">
                    <div>Started: @_run.StartedAtUtc.ToLocalTime().ToString("g")</div>
                    @if (_run.CompletedAtUtc is not null)
                    {
                        <div>Completed: @_run.CompletedAtUtc.Value.ToLocalTime().ToString("g")</div>
                    }
                    <div>Node: @(_run.WorkerNodeId ?? "-")</div>
                    <div>
                        PW/Browsers: @(string.Join(" / ", new[] { _run.PlaywrightVersion, _run.BrowserVersion }.Where(x => !string.IsNullOrWhiteSpace(x))))</div>
                </div>
            </div>
            <div class="d-flex flex-wrap align-items-center gap-2 mt-3">
                <span class="badge bg-light text-dark">Duration: @DurationText()</span>
                @if (_run.Failed > 0)
                {
                    <span class="badge bg-danger">Failed: @_run.Failed</span>
                }
                <span class="badge bg-light text-dark">Commands: @CommandCount</span>
                <span class="badge bg-light text-dark">Kinds: @KindCounts.Count</span>
                <button class="btn btn-sm btn-outline-secondary" title="Copy RunId" @onclick="CopyRunId">Copy RunId
                </button>
                @if (!string.IsNullOrWhiteSpace(_run.ExternalId))
                {
                    <button class="btn btn-sm btn-outline-secondary" title="Copy ExternalId" @onclick="CopyExternalId">
                        Copy ExternalId
                    </button>
                }
                @if (IsRunningStatus(_run.Status))
                {
                    <button class="btn btn-sm btn-outline-danger" disabled="@_stopping" @onclick="StopRunAsync">
                        @(_stopping ? "Stopping..." : "Mark Stopped & Release")
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="border-start border-end border-bottom p-2 mb-3">
        <h5 class="mb-2">Commands</h5>
        <div class="row g-2 mb-2">
            <div class="col-sm-3">
                <input class="form-control form-control-sm" placeholder="Kind (e.g. Borrow)"
                       value="@cmdKindFilter"
                       @oninput="OnKindInput"/>
            </div>
            <div class="col-sm-3">
                <input class="form-control form-control-sm" placeholder="Direction (c2s/s2c/runner)"
                       value="@cmdDirectionFilter"
                       @oninput="OnDirectionInput"/>
            </div>
        </div>
        @if (KindCounts.Count > 0)
        {
            <div class="mb-2">
                <span class="small text-muted me-2">Quick filters:</span>
                @foreach (var kv in KindCounts.OrderBy(kv => kv.Key))
                {
                    <button
                        class="btn btn-sm @(string.Equals(cmdKindFilter, kv.Key, StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-outline-primary") me-1 mb-1"
                        @onclick="() => SetKindFilter(kv.Key)">
                        @kv.Key <span class="badge bg-light text-dark ms-1">@kv.Value</span>
                    </button>
                }
                @if (!string.IsNullOrWhiteSpace(cmdKindFilter))
                {
                    <button class="btn btn-sm btn-outline-secondary mb-1" @onclick="ClearKindFilter">Clear</button>
                }
            </div>
        }
        @if (_commands == null)
        {
            <div class="text-muted">Loading commands...</div>
        }
        else if (FilteredCommands.Count == 0)
        {
            <div class="text-muted">No commands.</div>
        }
        else
        {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="small text-muted">Showing @PageStart-@PageEnd of @CmdTotal</div>
                <div class="btn-group btn-group-sm" role="group" aria-label="Commands pagination">
                    <button class="btn btn-outline-secondary" disabled="@(CmdPage <= 1)" @onclick="PrevCmdPage">Prev
                    </button>
                    <span class="btn btn-light disabled">Page @CmdPage / @CmdTotalPages</span>
                    <button class="btn btn-outline-secondary" disabled="@(CmdPage >= CmdTotalPages)"
                            @onclick="NextCmdPage">Next
                    </button>
                </div>
            </div>
            <div class="list-group small">
                @foreach (var ev in PagedCommands)
                {
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <span class="badge bg-secondary me-2">@ev.Kind</span>
                                <strong>@ev.Message</strong>
                                @if (!string.IsNullOrWhiteSpace(ev.TestId))
                                {
                                    <span class="badge bg-light text-dark ms-2">test=@ev.TestId</span>
                                }
                                @if (ev.Props is not null && ev.Props.Count > 0)
                                {
                                    <div class="mt-1">
                                        @foreach (var p in ev.Props)
                                        {
                                            <span class="badge bg-light text-dark me-1">@p.Key=@p.Value</span>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="text-end">
                                <div class="text-muted">@ev.TimestampUtc.ToLocalTime().ToString("HH:mm:ss")</div>
                                <button class="btn btn-sm btn-outline-secondary mt-1"
                                        @onclick="async () => await Copy(ev)">Copy
                                </button>
                            </div>
                        </div>

                        @if (string.Equals(ev.Kind, "PwProtocol", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="mt-2">
                                @RenderPlaywrightProtocol(ev)
                            </div>
                        }
                    </div>
                }
            </div>
            @if (CmdTotalPages > 1)
            {
                <div class="d-flex justify-content-end align-items-center mt-2">
                    <div class="btn-group btn-group-sm" role="group" aria-label="Commands pagination bottom">
                        <button class="btn btn-outline-secondary" disabled="@(CmdPage <= 1)" @onclick="PrevCmdPage">
                            Prev
                        </button>
                        <span class="btn btn-light disabled">Page @CmdPage / @CmdTotalPages</span>
                        <button class="btn btn-outline-secondary" disabled="@(CmdPage >= CmdTotalPages)"
                                @onclick="NextCmdPage">Next
                        </button>
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    [Parameter] public string runId { get; set; } = string.Empty;

    private ResultRunSummaryDto? _run;
    private bool runNotFound = false;
    private List<CommandLogEventDto>? _commands;
    private HubConnection? _conn;
    private bool _disposed = false;

    // Client-side detected OS for display when server OS is missing
    private string? _displayOs;

    private bool NeedsOsDetect()
    {
        return string.IsNullOrWhiteSpace(_run?.OS) || _run!.OS == "-";
    }

    private string GetDisplayOS()
    {
        return NeedsOsDetect() ? (_displayOs ?? "-") : (_run!.OS ?? "-");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Only attempt detection once and only if server OS is missing
        if (_displayOs is null && NeedsOsDetect())
        {
            try
            {
                var detected = await JS.InvokeAsync<string>("detectOS");
                if (!string.IsNullOrWhiteSpace(detected) && detected != "-")
                    _displayOs = detected;
                else
                    _displayOs = "-";
            }
            catch
            {
                _displayOs = "-"; // keep safe fallback for tests/non-browser renderers
            }

            StateHasChanged();
        }
    }

    // Add a gate to serialize all mutations and snapshot reads
    private readonly object _gate = new();

    private string cmdKindFilter = string.Empty;
    private string cmdDirectionFilter = string.Empty;

    // Pagination state for Commands
    private int CmdPage = 1;
    private int CmdPageSize = 50;

    // Server-driven paging state
    private bool _useServerPaging = false;
    private int _serverCmdCount = 0;
    private List<CommandLogEventDto> _pageBuffer = new();

    private int CmdTotal => _useServerPaging ? _serverCmdCount : FilteredCommands.Count;
    private int CmdTotalPages => Math.Max(1, (int)Math.Ceiling(CmdTotal / (double)CmdPageSize));
    private int PageStart => CmdTotal == 0 ? 0 : (CmdPage - 1) * CmdPageSize + 1;
    private int PageEnd => Math.Min(CmdPage * CmdPageSize, CmdTotal);

    private List<CommandLogEventDto> PagedCommands
    {
        get
        {
            if (_useServerPaging)
            {
                // Apply client-side filters over server-provided page
                return _pageBuffer
                    .Where(c => string.IsNullOrWhiteSpace(cmdKindFilter) || c.Kind?.Contains(cmdKindFilter, StringComparison.OrdinalIgnoreCase) == true)
                    .Where(c =>
                    {
                        if (string.IsNullOrWhiteSpace(cmdDirectionFilter)) return true;
                        var dir = string.Empty;
                        if (c.Props != null && c.Props.TryGetValue("direction", out var d) && d != null)
                            dir = d;
                        return dir.Contains(cmdDirectionFilter, StringComparison.OrdinalIgnoreCase);
                    })
                    .OrderBy(c => c.TimestampUtc)
                    .ToList();
            }

            var list = FilteredCommands;
            var skip = Math.Max(0, (CmdPage - 1) * CmdPageSize);
            return list.Skip(skip).Take(CmdPageSize).ToList();
        }
    }

    private async Task PrevCmdPage()
    {
        if (CmdPage > 1)
        {
            CmdPage--;
            if (_useServerPaging)
                await LoadServerPageAsync(CmdPage);
            StateHasChanged();
        }
    }

    private async Task NextCmdPage()
    {
        var total = CmdTotalPages;
        if (CmdPage < total)
        {
            CmdPage++;
            if (_useServerPaging)
                await LoadServerPageAsync(CmdPage);
            StateHasChanged();
        }
    }

    private void ResetCmdPage()
    {
        CmdPage = 1;
    }

    private void ClampPage()
    {
        var total = CmdTotalPages;
        if (CmdPage > total) CmdPage = total;
        if (CmdPage < 1) CmdPage = 1;
    }

    private List<CommandLogEventDto> FilteredCommands
    {
        get
        {
            List<CommandLogEventDto> snap;
            lock (_gate)
            {
                snap = (_commands ?? new List<CommandLogEventDto>()).ToList();
            }

            return snap
                .Where(c => string.IsNullOrWhiteSpace(cmdKindFilter) || c.Kind?.Contains(cmdKindFilter, StringComparison.OrdinalIgnoreCase) == true)
                .Where(c =>
                {
                    if (string.IsNullOrWhiteSpace(cmdDirectionFilter)) return true;
                    var dir = string.Empty;
                    if (c.Props != null && c.Props.TryGetValue("direction", out var d) && d != null)
                        dir = d;
                    return dir.Contains(cmdDirectionFilter, StringComparison.OrdinalIgnoreCase);
                })
                .OrderBy(c => c.TimestampUtc)
                .ToList();
        }
    }

    // Method to handle input changes - explicitly defined for testing
    private void OnKindInput(ChangeEventArgs e)
    {
        cmdKindFilter = e.Value?.ToString() ?? string.Empty;
        ResetCmdPage();
        StateHasChanged();
    }

    private void OnDirectionInput(ChangeEventArgs e)
    {
        cmdDirectionFilter = e.Value?.ToString() ?? string.Empty;
        ResetCmdPage();
        StateHasChanged();
    }

    private void SetKindFilter(string kind)
    {
        cmdKindFilter = kind ?? string.Empty;
        ResetCmdPage();
        StateHasChanged();
    }

    private void ClearKindFilter()
    {
        cmdKindFilter = string.Empty;
        ResetCmdPage();
        StateHasChanged();
    }

    private int CommandCount
    {
        get
        {
            lock (_gate)
            {
                return _commands?.Count ?? 0;
            }
        }
    }

    private Dictionary<string, int> KindCounts
    {
        get
        {
            List<CommandLogEventDto> snap;
            lock (_gate)
            {
                snap = (_commands ?? new List<CommandLogEventDto>()).ToList();
            }

            return snap
                .GroupBy(c => string.IsNullOrWhiteSpace(c.Kind) ? "(none)" : c.Kind)
                .ToDictionary(g => g.Key, g => g.Count(), StringComparer.OrdinalIgnoreCase);
        }
    }

    private string DurationText()
    {
        var run = _run;
        if (run == null) return "-";
        var start = run.StartedAtUtc;
        var end = run.CompletedAtUtc ?? DateTime.UtcNow;
        if (end < start) end = start;
        var span = end - start;
        if (span.TotalSeconds < 1) return "<1s";
        if (span.TotalMinutes < 1) return $"{(int)span.TotalSeconds}s";
        if (span.TotalHours < 1) return $"{(int)span.TotalMinutes}m {(int)span.Seconds}s";
        return $"{(int)span.TotalHours}h {(int)span.Minutes}m";
    }

    private async Task CopyRunId()
    {
        try
        {
            await JS.InvokeVoidAsync("copyText", _run?.RunId ?? string.Empty);
            await JS.InvokeVoidAsync("alert", "RunId copied to clipboard");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "CopyRunId failed for run {RunId}", _run?.RunId);
        }
    }

    private async Task CopyExternalId()
    {
        try
        {
            await JS.InvokeVoidAsync("copyText", _run?.ExternalId ?? string.Empty);
            await JS.InvokeVoidAsync("alert", "ExternalId copied to clipboard");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "CopyExternalId failed for run {RunId}", _run?.RunId);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        // If the component is re-parameterized (e.g., same page navigated quickly), make sure we don't stack connections
        if (_conn is not null)
        {
            try
            {
                await _conn.DisposeAsync();
            }
            catch
            {
            }

            _conn = null;
        }

        var http = HttpFactory.CreateClient("hub");
        var got404 = false;

        try
        {
            var resp = await http.GetAsync($"/results/{runId}");
            if (!resp.IsSuccessStatusCode)
            {
                if (resp.StatusCode == System.Net.HttpStatusCode.NotFound)
                    got404 = true;
            }
            else
            {
                var run = await resp.Content.ReadFromJsonAsync<ResultRunSummaryDto>();
                lock (_gate)
                {
                    _run = run;
                }
            }
        }
        catch
        {
        }

        // Try to enable server-driven paging: query count and load first page
        var enabledServerPaging = await TryEnableServerPagingAsync();
        if (!enabledServerPaging)
        {
            // Fallback: fetch initial slice and do client-side paging
            try
            {
                var cmdsResp = await http.GetAsync($"/results/{runId}/commands?take=200");
                var cmds = (cmdsResp.IsSuccessStatusCode
                    ? await cmdsResp.Content.ReadFromJsonAsync<List<CommandLogEventDto>>()
                    : new List<CommandLogEventDto>()) ?? new List<CommandLogEventDto>();
                lock (_gate)
                {
                    _commands = cmds;
                }

                ResetCmdPage();
                ClampPage();
            }
            catch
            {
                lock (_gate)
                {
                    _commands = new List<CommandLogEventDto>();
                }

                ResetCmdPage();
                ClampPage();
            }

            // Seed simulated data only if still empty
            lock (_gate)
            {
                if (_commands.Count == 0)
                    _commands = GenerateSimulatedPlaywrightCommands(runId);
                if (_run is null && _commands.Count > 0)
                    _run = GenerateSimulatedRunSummary(runId);

                runNotFound = got404 && _run is null && _commands.Count == 0;
            }

            // Ensure pagination is consistent after initial load/seeding
            ResetCmdPage();
            ClampPage();
        }

        // Live updates (create a single connection per page instance)
        var hubUrl = Config["HUB_SIGNALR"] ?? "http://hub:5000/ws";
        try
        {
            var uri = new Uri(hubUrl);
            var scheme = uri.Scheme switch { "ws" => "http", "wss" => "https", _ => uri.Scheme };
            var resultsWs = $"{scheme}://{uri.Authority}/results-ws";

            _conn = new HubConnectionBuilder()
                .WithUrl(resultsWs)
                .WithAutomaticReconnect()
                .Build();

            _conn.On<ResultRunSummaryDto>("RunUpdate", run =>
                InvokeAsync(() =>
                {
                    if (_disposed) return;
                    if (!string.Equals(run.RunId, runId, StringComparison.OrdinalIgnoreCase)) return;
                    lock (_gate)
                    {
                        _run = run;
                        runNotFound = false;
                    }

                    StateHasChanged();
                }));

            _conn.On<CommandLogEventDto[]>("CommandLogChunk", (CommandLogEventDto[] items) =>
            {
                if (_disposed) return;
                if (items == null || items.Length == 0) return;

                if (_useServerPaging)
                {
                    // Increase count for this run and refresh last page
                    var added = items.Count(it => string.Equals(it.RunId, runId, StringComparison.OrdinalIgnoreCase));
                    if (added > 0)
                    {
                        _serverCmdCount += added;
                        // If on last page, reload it to include new items
                        if (CmdPage == CmdTotalPages)
                        {
                            _ = LoadServerPageAsync(CmdPage);
                        }

                        _ = InvokeAsync(StateHasChanged);
                    }
                }
                else
                {
                    lock (_gate)
                    {
                        _commands ??= new List<CommandLogEventDto>();
                        foreach (var it in items)
                        {
                            if (string.Equals(it.RunId, runId, StringComparison.OrdinalIgnoreCase))
                                _commands.Add(it);
                        }

                        _commands = _commands.OrderBy(c => c.TimestampUtc).TakeLast(1000).ToList();
                    }

                    ClampPage();
                    _ = InvokeAsync(StateHasChanged);
                }
            });

            await _conn.StartAsync();
            await _conn.SendAsync("JoinRun", runId);
        }
        catch
        {
            // ignore live update errors for now
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_conn != null)
        {
            try
            {
                await _conn.SendAsync("LeaveRun", runId);
            }
            catch
            {
            }

            try
            {
                await _conn.DisposeAsync();
            }
            catch
            {
            }

            _conn = null;
        }
    }

    private async Task Copy(CommandLogEventDto ev)
    {
        var props = ev.Props is null || ev.Props.Count == 0
            ? string.Empty
            : string.Join(" ", ev.Props.Select(kv => $"{kv.Key}={kv.Value}"));
        var text = $"{ev.TimestampUtc:o} [{ev.Kind}] {ev.Message} {props}".Trim();
        try
        {
            await JS.InvokeVoidAsync("copyText", text);
            await JS.InvokeVoidAsync("alert", "Command copied to clipboard");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Copy command failed for run {RunId}", _run?.RunId);
        }
    }

    private MarkupString RenderPlaywrightProtocol(CommandLogEventDto ev)
    {
        var dir = "";
        if (ev.Props != null && ev.Props.TryGetValue("direction", out var d)) dir = d ?? "";
        var badgeClass = string.Equals(dir, "c2s", StringComparison.OrdinalIgnoreCase) ? "primary" : "info";
        var dirBadge = string.IsNullOrWhiteSpace(dir) ? string.Empty : $"<span class=\"badge bg-{badgeClass} me-2\">{dir}</span>";

        var text = ev.Message ?? string.Empty;
        var pretty = text;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(text);
            pretty = System.Text.Json.JsonSerializer.Serialize(doc.RootElement, new System.Text.Json.JsonSerializerOptions
            {
                WriteIndented = true
            });
        }
        catch
        {
            /* leave as-is if not JSON */
        }

        // Encode content to avoid HTML injection; keep our own badges unencoded
        var encoded = System.Net.WebUtility.HtmlEncode(pretty);
        var html = $"{dirBadge}<pre class=\"mb-0 small\" style=\"white-space:pre-wrap; overflow:auto; max-height:24rem;\">{encoded}</pre>";
        return new MarkupString(html);
    }

    private static string Short(string? id)
    {
        return id?.Length > 8 ? id.Substring(0, 8) : (id ?? "-");
    }

    private static string StatusBadgeClass(string? status)
    {
        var s = status?.Trim().ToLowerInvariant() ?? "";
        switch (s)
        {
            case "passed": return "bg-success";
            case "failed": return "bg-danger";
            case "running":
            case "inprogress": return "bg-warning text-dark";
            case "queued": return "bg-secondary";
            case "stopped":
            case "autostopped": return "bg-dark";
            default: return "bg-light text-dark";
        }
    }

    private bool _stopping = false;

    private static bool IsRunningStatus(string? status)
    {
        return string.Equals(status, "Running", StringComparison.OrdinalIgnoreCase) || string.Equals(status, "InProgress", StringComparison.OrdinalIgnoreCase);
    }

    private async Task StopRunAsync()
    {
        var id = _run?.RunId;
        if (string.IsNullOrWhiteSpace(id)) return;
        if (_stopping) return;
        _stopping = true;
        using var __scope = Logger.BeginScope(new Dictionary<string, object> { ["runId"] = id! });
        try
        {
            var http = HttpFactory.CreateClient("hub");
            var resp = await http.PostAsync($"/results/{id}/stop", null);
            if (!resp.IsSuccessStatusCode)
            {
                var txt = await resp.Content.ReadAsStringAsync();
                Logger.LogWarning("Stop run failed for {RunId}: {StatusCode} {Body}", id, (int)resp.StatusCode, txt);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Stop run exception for {RunId}", id);
        }
        finally
        {
            _stopping = false;
        }
    }

    private static ResultRunSummaryDto GenerateSimulatedRunSummary(string runId)
    {
        return new ResultRunSummaryDto
        {
            RunId = runId,
            App = "sim-app",
            Browser = "Chromium",
            Env = "local",
            Region = "",
            OS = System.Runtime.InteropServices.RuntimeInformation.OSDescription,
            Status = "Running",
            TotalTests = 1,
            Passed = 0,
            Failed = 0,
            StartedAtUtc = DateTime.UtcNow.AddSeconds(-12),
            WorkerNodeId = "sim-node",
            PlaywrightVersion = "1.54.2",
            BrowserVersion = "125.0"
        };
    }

    private static List<CommandLogEventDto> GenerateSimulatedPlaywrightCommands(string runId)
    {
        var now = DateTime.UtcNow.AddSeconds(-10);
        var browserId = $"sim-{Short(runId)}-browser";
        var testId = $"{Short(runId)}:spec.ts:should work";
        var list = new List<CommandLogEventDto>();

        list.Add(new CommandLogEventDto
        {
            RunId = runId,
            TimestampUtc = now,
            Kind = "ServerLaunch",
            Message = "Playwright server started",
            Props = new Dictionary<string, string> { ["wsEndpoint"] = "ws://localhost:9222/playwright", ["args"] = "--disable-gpu --no-sandbox" }
        });

        list.Add(new CommandLogEventDto
        {
            RunId = runId,
            TimestampUtc = now.AddSeconds(1),
            Kind = "Borrow",
            Message = "Borrowed Chromium endpoint",
            Props = new Dictionary<string, string> { ["labelKey"] = "local:Chromium", ["browserId"] = browserId }
        });

        // More simulated commands...
        return list;
    }

    private sealed class CountResponse
    {
        public int count { get; set; }
        public int Count { get; set; }
    }

    private async Task<bool> TryEnableServerPagingAsync()
    {
        try
        {
            var http = HttpFactory.CreateClient("hub");
            var resp = await http.GetAsync($"/results/{runId}/commands/count");
            if (!resp.IsSuccessStatusCode) return false;
            var payload = await resp.Content.ReadFromJsonAsync<CountResponse>();
            var count = payload?.count > 0 ? payload!.count : payload?.Count ?? 0;
            _useServerPaging = true;
            _serverCmdCount = Math.Max(0, count);
            await LoadServerPageAsync(1);
            ResetCmdPage();
            ClampPage();
            return true;
        }
        catch
        {
            _useServerPaging = false;
            return false;
        }
    }

    private async Task LoadServerPageAsync(int page)
    {
        if (page < 1) page = 1;
        var skip = (page - 1) * CmdPageSize;
        try
        {
            var http = HttpFactory.CreateClient("hub");
            var url = $"/results/{runId}/commands?skip={skip}&take={CmdPageSize}";
            var items = await http.GetFromJsonAsync<List<CommandLogEventDto>>(url) ?? new List<CommandLogEventDto>();
            _pageBuffer = items.OrderBy(c => c.TimestampUtc).ToList();
        }
        catch
        {
            _pageBuffer = new List<CommandLogEventDto>();
        }
    }

}
