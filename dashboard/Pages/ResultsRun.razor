    private async Task StopRunAsync()
    {
        var id = _run?.RunId;
        if (string.IsNullOrWhiteSpace(id)) return;
        // Confirm intent
        var ok = Confirm != null ? await Confirm.Show($"Mark run {Short(id)} as Stopped and release any borrowed sessions?", "Confirm Action", "Yes", "No") : await JS.InvokeAsync<bool>("confirm", $"Mark run {Short(id)} as Stopped and release any borrowed sessions?");
        if (!ok) return;
        if (_stopping) return;
        _stopping = true;
        using var __scope = Logger.BeginScope(new Dictionary<string, object> { ["runId"] = id! });
        try
        {
            var http = HttpFactory.CreateClient(HttpClientNames.Hub);
            var resp = await http.PostAsync($"/results/{id}/stop", null);
            if (!resp.IsSuccessStatusCode)
            {
                var txt = await resp.Content.ReadAsStringAsync();
                Logger.LogWarning("Stop run failed for {RunId}: {StatusCode} {Body}", id, (int)resp.StatusCode, txt);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Stop run exception for {RunId}", id);
        }
        finally
        {
            _stopping = false;
        }
    }

