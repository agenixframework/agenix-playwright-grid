@namespace Dashboard.Pages
@inject NavigationManager Nav

<link href="css/not-found.css" rel="stylesheet"/>

<div class="not-found-container">
    <div class="not-found-content">
        <div class="not-found-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="1.5">
                <path
                    d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"/>
            </svg>
        </div>

        <h1 class="not-found-title">Page Not Found</h1>

        <p class="not-found-message">
            Sorry, we couldn't find the page you're looking for. The page may have been moved, deleted, or never
            existed.
        </p>

        <div class="not-found-details">
            <span class="not-found-path">@CurrentPath</span>
        </div>

        <div class="not-found-actions">
            <button class="btn btn-primary btn-lg" @onclick="GoHome">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"
                     class="me-2">
                    <path
                        d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.707 1.5ZM13 7.207V13.5a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5V7.207l5-5 5 5Z"/>
                </svg>
                Go to Home
            </button>
            <button class="btn btn-outline-secondary btn-lg" @onclick="GoBack">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"
                     class="me-2">
                    <path fill-rule="evenodd"
                          d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
                </svg>
                Go Back
            </button>
        </div>

        <div class="not-found-footer">
            <p class="not-found-help">
                Need help? Check the
                <a href="/diagnostics" class="not-found-link">diagnostics page</a>
                or contact your administrator.
            </p>
        </div>
    </div>
</div>

@code {
    private string CurrentPath => Nav.Uri.Replace(Nav.BaseUri.TrimEnd('/'), "");

    private void GoHome()
    {
        Nav.NavigateTo("/", true);
    }

    private void GoBack()
    {
        Nav.NavigateTo(Nav.Uri, false);
        // Note: Blazor doesn't have native browser history API access
        // This will stay on the same page, but the user can use browser back button
    }

}
