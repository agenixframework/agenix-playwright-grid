
@page "/"
@namespace Dashboard.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/>
    <title>Playwright Grid Dashboard</title>
    <base href="~/"/>
    <link rel="icon" type="image/x-icon" href="~/images/agenix-favicon.ico"/>
    <link rel="icon" type="image/png" sizes="16x16" href="~/images/icon-16.png"/>
    <link rel="icon" type="image/png" sizes="32x32" href="~/images/icon-32.png"/>
    <link rel="icon" type="image/png" sizes="128x128" href="~/images/icon-128.png"/>
    <link rel="apple-touch-icon" sizes="128x128" href="~/images/icon-128.png"/>
    <link rel="apple-touch-icon" sizes="256x256" href="~/images/icon-256.png"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          crossorigin="anonymous"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"
          crossorigin="anonymous"/>
    <link href="https://cdn.jsdelivr.net/npm/c3@0.7.20/c3.min.css" rel="stylesheet"/>
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true"/>
    <link href="~/Dashboard.styles.css" rel="stylesheet" asp-append-version="true"/>
</head>
<body>
<app>
    <component type="typeof(App)" render-mode="ServerPrerendered"/>
</app>
<script src="https://d3js.org/d3.v5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/c3@0.7.20/c3.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        crossorigin="anonymous"></script>
<script src="_framework/blazor.server.js"></script>
<script src="~/js/app.js" asp-append-version="true"></script>
</body>
</html>
