@page "/results"
@using System.Net.Http
@using System.Net.Http.Json
@using System.Linq
@implements IAsyncDisposable
@inject IHttpClientFactory HttpFactory
@inject IConfiguration Config

<div class="d-flex align-items-center my-3">
    <h3 class="mb-0">Test Runs</h3>
    <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="Refresh">Refresh</button>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-sm-2">
                <label class="form-label">App</label>
                <input class="form-control form-control-sm" @bind="filterApp"/>
            </div>
            <div class="col-sm-2">
                <label class="form-label">Browser</label>
                <input class="form-control form-control-sm" @bind="filterBrowser"/>
            </div>
            <div class="col-sm-2">
                <label class="form-label">Env</label>
                <input class="form-control form-control-sm" @bind="filterEnv"/>
            </div>
            <div class="col-sm-2">
                <label class="form-label">Status</label>
                <input class="form-control form-control-sm" @bind="filterStatus"/>
            </div>
            <div class="col-sm-3">
                <label class="form-label">Search (RunId/ExternalId)</label>
                <input class="form-control form-control-sm" @bind="searchText"/>
            </div>
            <div class="col-sm-1">
                <button class="btn btn-sm btn-primary w-100" @onclick="LoadRuns">Apply</button>
            </div>
            <div class="col-sm-1">
                <button class="btn btn-sm btn-outline-secondary w-100" @onclick="ClearFilters">Clear</button>
            </div>
        </div>
    </div>
</div>

@if (_runs == null)
{
    <div class="alert alert-info">Loading runs...</div>
}
else if (!FilteredRuns.Any())
{
    <div class="alert alert-secondary">
        <div class="fw-semibold">No results</div>
        <div class="small">Tip: emit runId in your CI when calling /session/borrow and /session/return so the hub can
            attribute events to a run. Then navigate here to see live updates.
        </div>
    </div>
}
else
{
    @* Summary cards *@
    <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="text-muted small">Runs</div>
                    <div class="display-6">@TotalRuns()</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="text-muted small">Pass rate</div>
                        <div class="fw-semibold">@PassRate()%</div>
                    </div>
                    <div class="mt-2">
                        <svg viewBox="0 0 100 20" width="100%" height="30" preserveAspectRatio="none"
                             aria-label="Pass rate trend">
                            <polyline fill="none" stroke="#0d6efd" stroke-width="2"
                                      points="@PassRatePoints()"></polyline>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between small">
                        <div class="text-success">Passed: @PassedRunsCount()</div>
                        <div class="text-danger">Failed: @FailedRunsCount()</div>
                    </div>
                    <div class="d-flex justify-content-between small mt-1">
                        <div class="text-secondary">Stopped: @StoppedRunsCount()</div>
                        <div class="text-muted">Completed: @TotalCompletedRuns()</div>
                    </div>
                    <div class="progress mt-2" role="progressbar" aria-label="Runs breakdown" aria-valuemin="0"
                         aria-valuemax="100">
                        <div class="progress-bar bg-success"
                             style="width:@Percent(PassedRunsCount(), Math.Max(1, TotalCompletedRuns()))%"></div>
                        <div class="progress-bar bg-danger"
                             style="width:@Percent(FailedRunsCount(), Math.Max(1, TotalCompletedRuns()))%"></div>
                        <div class="progress-bar bg-secondary"
                             style="width:@Percent(StoppedRunsCount(), Math.Max(1, TotalCompletedRuns()))%"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="text-muted small">Running</div>
                    <div class="display-6">@RunningCount()</div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <div class="small text-muted">Showing @PageStart-@PageEnd of @TotalCount</div>
        <div class="d-flex align-items-center gap-2">
            <div class="input-group input-group-sm" style="width: 140px;">
                <label class="input-group-text" for="pageSizeSelect">Page</label>
                <select id="pageSizeSelect" class="form-select" value="@PageSize" @onchange="OnPageSizeChanged">
                    <option value="10">10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </div>
            <div class="btn-group btn-group-sm" role="group" aria-label="Runs pagination">
                <button class="btn btn-outline-secondary" disabled="@(EffectivePage <= 1)" @onclick="PrevPage">Prev
                </button>
                <span class="btn btn-light disabled">Page @EffectivePage / @TotalPages</span>
                <button class="btn btn-outline-secondary" disabled="@(EffectivePage >= TotalPages)" @onclick="NextPage">
                    Next
                </button>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
            <thead class="table-light">
            <tr>
                <th>Run</th>
                <th>Status</th>
                <th>App</th>
                <th>Browser</th>
                <th>Env</th>
                <th>Region/OS</th>
                <th>Total</th>
                <th>Passed</th>
                <th>Failed</th>
                <th>Duration</th>
                <th>Started</th>
                <th>Node</th>
                <th>PW/Browsers</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var r in PagedRuns)
            {
                var dur = r.CompletedAtUtc.HasValue ? r.CompletedAtUtc.Value - r.StartedAtUtc : DateTime.UtcNow - r.StartedAtUtc;
                <tr>
                    <td><a href="/results/@r.RunId">@Short(r.RunId)</a></td>
                    <td>
                        <span class="badge @StatusBadgeClass(r.Status)">@r.Status</span>
                        @if (IsHanging(r))
                        {
                            <span class="badge bg-danger ms-1"
                                  title="No activity >= @HangingIdleMinutes minutes, duration >= @HangingMaxDurationHours hours, outstanding borrowed >= 1">Hanging</span>
                        }
                    </td>
                    <td>@r.App</td>
                    <td>@r.Browser</td>
                    <td>@r.Env</td>
                    <td>@(string.Join(" / ", new string?[] { r.Region, r.OS }.Where(x => !string.IsNullOrWhiteSpace(x))))</td>
                    <td>@EffectiveTotalTests(r)</td>
                    <td class="text-success">@EffectivePassed(r)</td>
                    <td class="text-danger">@EffectiveFailed(r)</td>
                    <td>@(dur.TotalMinutes < 1 ? $"{dur.TotalSeconds:F0}s" : $"{dur.TotalMinutes:F1}m")</td>
                    <td>
                        <div>@r.StartedAtUtc.ToLocalTime().ToString("g")</div>
                        <div class="small text-muted">@FormatAgo(r.StartedAtUtc)</div>
                    </td>
                    <td>@(r.WorkerNodeId ?? "-")</td>
                    <td>@(string.Join(" / ", new[] { r.PlaywrightVersion, r.BrowserVersion }.Where(x => !string.IsNullOrWhiteSpace(x))))</td>
                    <td>
                        @if (IsRunningStatus(r.Status))
                        {
                            <button class="btn btn-sm btn-outline-danger" disabled="@_stopping.Contains(r.RunId)"
                                    @onclick="()=> StopRunAsync(r.RunId)">
                                @(_stopping.Contains(r.RunId) ? "Stopping..." : "Mark Stopped & Release")
                            </button>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@code {
    private List<ResultRunSummaryDto> _runs; // current page buffer from server
    private HubConnection _conn;
    private string filterApp = string.Empty, filterBrowser = string.Empty, filterEnv = string.Empty, filterStatus = string.Empty, searchText = string.Empty;

    // Total count from server for current server-side filters (app/browser/env/status)
    private int _totalRunsCount = 0;

    // Apply only local search (RunId/ExternalId) on the page buffer. Other filters go to server.
    private IEnumerable<ResultRunSummaryDto> FilteredRuns => (_runs ?? new List<ResultRunSummaryDto>())
        .Where(r => string.IsNullOrWhiteSpace(searchText) || r.RunId?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true || r.ExternalId?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true)
        .OrderByDescending(r => r.StartedAtUtc)
        .ToList();

    private int Page { get; set; } = 1;
    private int PageSize { get; set; } = 25;
    private int TotalCount => string.IsNullOrWhiteSpace(searchText) ? _totalRunsCount : FilteredRuns.Count();
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(TotalCount / (double)Math.Max(1, PageSize)));
    private int EffectivePage => Math.Min(Math.Max(Page, 1), TotalPages);
    private int PageStart => TotalCount == 0 ? 0 : (EffectivePage - 1) * PageSize + 1;
    private int PageEnd => Math.Min(EffectivePage * PageSize, TotalCount);
    private IEnumerable<ResultRunSummaryDto> PagedRuns => FilteredRuns.ToList();

    private void ClampPage()
    {
        var total = TotalPages;
        if (Page > total) Page = total;
        if (Page < 1) Page = 1;
    }

    private void ResetPage()
    {
        Page = 1;
        ClampPage();
    }

    private async Task PrevPage()
    {
        if (Page > 1)
        {
            Page--;
            await LoadPageAsync();
            await EnsureActivityForVisibleRuns();
        }
    }

    private async Task NextPage()
    {
        var total = TotalPages;
        if (Page < total)
        {
            Page++;
            await LoadPageAsync();
            await EnsureActivityForVisibleRuns();
        }
    }

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (e?.Value is not null && int.TryParse(e.Value.ToString(), out var ps))
        {
            PageSize = Math.Max(1, ps);
            ResetPage();
            await LoadCountAsync();
            await LoadPageAsync();
            await EnsureActivityForVisibleRuns();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRuns();
        await EnsureActivityForVisibleRuns();

        // Subscribe to ResultsHub for live RunsIndex and RunUpdate events
        var hubUrl = Config["HUB_SIGNALR"] ?? "http://hub:5000/ws";
        try
        {
            var uri = new Uri(hubUrl);
            var scheme = uri.Scheme switch { "ws" => "http", "wss" => "https", _ => uri.Scheme };
            var resultsWs = $"{scheme}://{uri.Authority}/results-ws";

            _conn = new HubConnectionBuilder()
                .WithUrl(resultsWs)
                .WithAutomaticReconnect()
                .Build();

            void OnRunsIndex(ResultRunSummaryDto[] __)
            {
                _ = InvokeAsync(RefreshCurrentPageAsync);
            }

            _conn.On<ResultRunSummaryDto>("RunUpdate", run =>
            {
                // Legacy inline handler replaced below; keep a no-op registration guard
            });
            _conn.Remove("RunUpdate");
            _conn.On<ResultRunSummaryDto[]>("RunsIndex", OnRunsIndex);

            _conn.On<ResultRunSummaryDto>("RunUpdate", run =>
            {
                // On any single run update, refresh current page and hanging info for that run
                _ = InvokeAsync(async () =>
                {
                    await RefreshCurrentPageAsync();
                    await FetchRunHangingInfo(run.RunId, run.StartedAtUtc);
                });
            });

            await _conn.StartAsync();
        }
        catch
        {
            // Ignore SignalR issues for MVP
        }
    }

    private async Task LoadRuns()
    {
        ResetPage();
        await LoadCountAsync();
        await LoadPageAsync();
        await EnsureActivityForVisibleRuns();
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        if (_conn != null)
        {
            try
            {
                await _conn.DisposeAsync();
            }
            catch
            {
            }
        }
    }

    private sealed class CountResponse
    {
        public int count { get; set; }
        public int Count { get; set; }
    }

    private string BuildFilterQuery()
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(filterStatus)) parts.Add($"status={Uri.EscapeDataString(filterStatus)}");
        if (!string.IsNullOrWhiteSpace(filterApp)) parts.Add($"app={Uri.EscapeDataString(filterApp)}");
        if (!string.IsNullOrWhiteSpace(filterBrowser)) parts.Add($"browser={Uri.EscapeDataString(filterBrowser)}");
        if (!string.IsNullOrWhiteSpace(filterEnv)) parts.Add($"env={Uri.EscapeDataString(filterEnv)}");
        return parts.Count == 0 ? string.Empty : "&" + string.Join("&", parts);
    }

    private async Task LoadCountAsync()
    {
        try
        {
            var http = HttpFactory.CreateClient("hub");
            var url = $"/results/count?dummy=1{BuildFilterQuery()}";
            var payload = await http.GetFromJsonAsync<CountResponse>(url);
            _totalRunsCount = Math.Max(0, payload?.count > 0 ? payload.count : payload?.Count ?? 0);
        }
        catch
        {
            _totalRunsCount = 0;
        }
    }

    private async Task LoadPageAsync()
    {
        var skip = Math.Max(0, (EffectivePage - 1) * Math.Max(1, PageSize));
        try
        {
            var http = HttpFactory.CreateClient("hub");
            var url = $"/results?skip={skip}&take={PageSize}{BuildFilterQuery()}";
            _runs = await http.GetFromJsonAsync<List<ResultRunSummaryDto>>(url) ?? new List<ResultRunSummaryDto>();
        }
        catch
        {
            _runs = new List<ResultRunSummaryDto>();
        }
    }

    private async Task RefreshCurrentPageAsync()
    {
        await LoadCountAsync();
        ClampPage();
        await LoadPageAsync();
        await EnsureActivityForVisibleRuns();
        await InvokeAsync(StateHasChanged);
    }

    private async Task Refresh()
    {
        await LoadRuns();
    }

    private async Task ClearFilters()
    {
        filterApp = filterBrowser = filterEnv = filterStatus = searchText = string.Empty;
        await LoadRuns();
    }

    private readonly HashSet<string> _stopping = new(StringComparer.OrdinalIgnoreCase);

    private static bool IsRunningStatus(string? status)
    {
        return string.Equals(status, "Running", StringComparison.OrdinalIgnoreCase) || string.Equals(status, "InProgress", StringComparison.OrdinalIgnoreCase);
    }

    private async Task StopRunAsync(string runId)
    {
        if (string.IsNullOrWhiteSpace(runId)) return;
        if (_stopping.Contains(runId)) return;
        _stopping.Add(runId);
        try
        {
            var http = HttpFactory.CreateClient("hub");
            var resp = await http.PostAsync($"/results/{runId}/stop", null);
            if (!resp.IsSuccessStatusCode)
            {
                var txt = await resp.Content.ReadAsStringAsync();
                Console.WriteLine($"[Dashboard] stop run failed: {(int)resp.StatusCode} {txt}");
            }

            // Refresh list to reflect updates
            await LoadRuns();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Dashboard] stop run exception: {ex.Message}");
        }
        finally
        {
            _stopping.Remove(runId);
        }
    }

    private static string Short(string id)
    {
        return id?.Length > 8 ? id.Substring(0, 8) : id;
    }

    private static int Percent(int part, int total)
    {
        return total <= 0 ? 0 : (int)Math.Round(part * 100.0 / Math.Max(1, total));
    }

    private int TotalRuns()
    {
        return TotalCount;
    }


    private static int EffectiveTotalTests(ResultRunSummaryDto r)
    {
        return r.TotalTests > 0
            ? r.TotalTests
            : string.Equals(r.Status, "Passed", StringComparison.OrdinalIgnoreCase) || string.Equals(r.Status, "Failed", StringComparison.OrdinalIgnoreCase) ? 1 : 0;
    }


    private static int EffectivePassed(ResultRunSummaryDto r)
    {
        return r.TotalTests > 0 || r.Passed > 0 || r.Failed > 0
            ? r.Passed
            : string.Equals(r.Status, "Passed", StringComparison.OrdinalIgnoreCase)
                ? 1
                : 0;
    }


    private static int EffectiveFailed(ResultRunSummaryDto r)
    {
        return r.TotalTests > 0 || r.Passed > 0 || r.Failed > 0
            ? r.Failed
            : string.Equals(r.Status, "Failed", StringComparison.OrdinalIgnoreCase)
                ? 1
                : 0;
    }


    private int TotalTests()
    {
        return FilteredRuns.Sum(EffectiveTotalTests);
    }

    private int PassedCount()
    {
        return FilteredRuns.Sum(EffectivePassed);
    }

    private int FailedCount()
    {
        return FilteredRuns.Sum(EffectiveFailed);
    }

    // Run-level counts
    private int PassedRunsCount()
    {
        return FilteredRuns.Count(r => string.Equals(r.Status, "Passed", StringComparison.OrdinalIgnoreCase));
    }

    private int FailedRunsCount()
    {
        return FilteredRuns.Count(r => string.Equals(r.Status, "Failed", StringComparison.OrdinalIgnoreCase));
    }

    private int StoppedRunsCount()
    {
        return FilteredRuns.Count(r => string.Equals(r.Status, "Stopped", StringComparison.OrdinalIgnoreCase) || string.Equals(r.Status, "AutoStopped", StringComparison.OrdinalIgnoreCase));
    }

    private int TotalCompletedRuns()
    {
        return PassedRunsCount() + FailedRunsCount() + StoppedRunsCount();
    }

    private int RunningCount()
    {
        return FilteredRuns.Count(r => string.Equals(r.Status, "Running", StringComparison.OrdinalIgnoreCase) || string.Equals(r.Status, "InProgress", StringComparison.OrdinalIgnoreCase));
    }

    // Pass rate should include stopped runs in denominator and be based on run-level outcome
    private int PassRate()
    {
        var t = TotalCompletedRuns();
        return Percent(PassedRunsCount(), Math.Max(1, t));
    }

    private string PassRatePoints()
    {
        // Sparkline reflects run-level pass/fail over last 20 runs (Stopped treated as fail)
        var rates = FilteredRuns
            .OrderByDescending(r => r.StartedAtUtc)
            .Take(20)
            .Select(r => string.Equals(r.Status, "Passed", StringComparison.OrdinalIgnoreCase) ? 100 : 0)
            .Reverse()
            .ToList();
        return BuildSparklinePoints(rates);
    }

    private static string StatusBadgeClass(string status)
    {
        var s = status?.Trim().ToLowerInvariant() ?? "";
        switch (s)
        {
            case "passed": return "bg-success";
            case "failed": return "bg-danger";
            case "running":
            case "inprogress": return "bg-warning text-dark";
            case "queued": return "bg-secondary";
            case "stopped": return "bg-dark";
            case "autostopped": return "bg-dark";
            default: return "bg-light text-dark";
        }
    }

    private static string FormatAgo(DateTime dt)
    {
        var utc = dt.Kind == DateTimeKind.Unspecified ? DateTime.SpecifyKind(dt, DateTimeKind.Utc) : dt.ToUniversalTime();
        var span = DateTime.UtcNow - utc;
        if (span.TotalSeconds < 0) span = TimeSpan.Zero;
        if (span.TotalSeconds < 60) return $"{(int)span.TotalSeconds}s ago";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return $"{(int)span.TotalDays}d ago";
    }

    private static string BuildSparklinePoints(List<int> values)
    {
        if (values == null || values.Count == 0) return "0,10 100,10";
        var n = values.Count;
        var step = n > 1 ? 100.0 / (n - 1) : 100.0;
        var pts = new List<string>(n);
        for (var i = 0; i < n; i++)
        {
            var v = Math.Clamp(values[i], 0, 100);
            var x = step * i;
            var y = 20 - v / 100.0 * 20; // invert y
            pts.Add($"{x:0.###},{y:0.###}");
        }

        return string.Join(" ", pts);
    }

    // Hanging detection configuration and state
    private int HangingIdleMinutes => int.TryParse(Config["HANGING_IDLE_MINUTES"], out var m) ? Math.Max(1, m) : 30;
    private int HangingMaxDurationHours => int.TryParse(Config["HANGING_MAX_HOURS"], out var h) ? Math.Max(1, h) : 3;

    private sealed class HangingInfo
    {
        public DateTime LastActivityUtc { get; set; }
        public int OutstandingBrowsers { get; set; }
        public DateTime ComputedAtUtc { get; set; }
    }

    private readonly Dictionary<string, HangingInfo> _hangingInfo = new(StringComparer.OrdinalIgnoreCase);
    private readonly object _hangingGate = new();

    private bool IsHanging(ResultRunSummaryDto r)
    {
        if (!IsRunningStatus(r.Status)) return false;
        HangingInfo? info;
        lock (_hangingGate)
        {
            _hangingInfo.TryGetValue(r.RunId, out info);
        }

        if (info is null) return false; // unknown yet
        var idleThreshold = TimeSpan.FromMinutes(HangingIdleMinutes);
        var maxDur = TimeSpan.FromHours(HangingMaxDurationHours);
        var now = DateTime.UtcNow;
        var duration = (r.CompletedAtUtc ?? now) - r.StartedAtUtc;
        var idle = now - info.LastActivityUtc;
        return idle >= idleThreshold && duration >= maxDur && info.OutstandingBrowsers >= 1;
    }

    private async Task EnsureActivityForVisibleRuns()
    {
        var page = PagedRuns.ToList();
        var tasks = new List<Task>();
        foreach (var r in page)
        {
            HangingInfo? info;
            lock (_hangingGate)
            {
                _hangingInfo.TryGetValue(r.RunId, out info);
            }

            var stale = info is null || DateTime.UtcNow - info.ComputedAtUtc > TimeSpan.FromMinutes(1);
            if (!stale) continue;
            tasks.Add(FetchRunHangingInfo(r.RunId, r.StartedAtUtc));
        }

        if (tasks.Count > 0)
        {
            try
            {
                await Task.WhenAll(tasks);
            }
            catch
            {
            }

            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task FetchRunHangingInfo(string runId, DateTime startedAtUtc)
    {
        try
        {
            var http = HttpFactory.CreateClient("hub");
            var url = $"/results/{runId}/commands?skip=0&take=5000";
            var cmds = await http.GetFromJsonAsync<List<CommandLogEventDto>>(url) ?? new List<CommandLogEventDto>();
            var lastActivity = startedAtUtc;
            if (cmds.Count > 0)
            {
                foreach (var c in cmds)
                {
                    if (c.TimestampUtc > lastActivity) lastActivity = c.TimestampUtc;
                }
            }

            var launched = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            var returned = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            foreach (var c in cmds)
            {
                if (string.Equals(c.Kind, "ServerLaunch", StringComparison.OrdinalIgnoreCase) && c.Props != null && c.Props.TryGetValue("browserId", out var bid) && !string.IsNullOrWhiteSpace(bid))
                {
                    launched.Add(bid);
                }
                else if (string.Equals(c.Kind, "Return", StringComparison.OrdinalIgnoreCase) && c.Props != null && c.Props.TryGetValue("browserId", out var rb) && !string.IsNullOrWhiteSpace(rb))
                {
                    returned.Add(rb);
                }
            }

            var outstanding = launched.Count(id => !returned.Contains(id));
            var info = new HangingInfo { LastActivityUtc = lastActivity, OutstandingBrowsers = outstanding, ComputedAtUtc = DateTime.UtcNow };
            lock (_hangingGate)
            {
                _hangingInfo[runId] = info;
            }
        }
        catch
        {
            // ignore
        }
    }

}