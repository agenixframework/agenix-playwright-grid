@page "/"
@page "/pool/"
@using System.Text.RegularExpressions
@using Dashboard.Application.Ports
@implements IDisposable
@inject IPoolStateReader Proxy
@inject IHttpClientFactory HttpFactory
@inject IJSRuntime JS

<link href="css/index-pool.css" rel="stylesheet"/>

<div class="page-header">
    <div class="header-content">
        <div class="header-icon">
            <svg viewBox="0 0 16 16" aria-hidden="true">
                <path d="M1.5 8a6.5 6.5 0 1 1 13 0A6.5 6.5 0 0 1 1.5 8zM8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0z"/>
                <path
                    d="M6.646 6.646a.5.5 0 0 1 .708 0l2 2a.5.5 0 0 1 0 .708l-2 2a.5.5 0 0 1-.708-.708L8.293 9H6.5a.5.5 0 0 1 0-1h1.793L6.646 6.354a.5.5 0 0 1 0-.708z"/>
                <circle cx="8" cy="8" r="1.5"/>
            </svg>
        </div>
        <div>
            <h3>Live Browser Pool Dashboard</h3>
            <div class="subtitle">Monitor active browser pools and resource utilization</div>
        </div>
    </div>
</div>

@if (Proxy.Get() is null)
{
    <div class="alert alert-info">Waiting for state...</div>
}
else
{
    var state = Proxy.Get()!;
    var totalPools = state!.Pools.Count;
    var totalBrowsers = state.Pools.Sum(p => p.Total);
    var borrowed = state.Pools.Sum(p => p.Borrowed);
    var available = totalBrowsers - borrowed;

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="text-muted small">Pools</div>
                    <div class="display-6">@totalPools</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="text-muted small">Browsers</div>
                    <div class="display-6">@totalBrowsers</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="text-muted small">Borrowed</div>
                    <div class="display-6 text-danger">@borrowed</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="text-muted small">Available</div>
                    <div class="display-6 text-success">@available</div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex align-items-center justify-content-between mt-3 mb-3">
        <h5 class="mb-0">Pools</h5>
        <div class="d-flex gap-2 align-items-center">
            <div class="search-controls">
                <input type="text" class="form-control form-control-sm" placeholder="Search pools..."
                       @bind="_poolSearchQuery" @oninput="StateHasChanged" style="width: 200px;">
            </div>
            <select class="form-select form-select-sm" @bind="_poolFilterStatus" style="width: 140px;">
                <option value="all">All Status</option>
                <option value="healthy">Healthy</option>
                <option value="warning">Warning</option>
                <option value="critical">Critical</option>
                <option value="maintenance">Maintenance</option>
                <option value="offline">Offline</option>
            </select>
        </div>
    </div>

    @if (GetFilteredAndSortedPools().Count() == 0)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            @if (state.Pools.Count == 0)
            {
                <span>No pools configured.</span>
            }
            else
            {
                <span>No pools match the current filter criteria.</span>
            }
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var p in GetFilteredAndSortedPools())
            {
                var borrowedPct = Percent(p.Borrowed, p.Total);
                var availPct = Percent(p.Total - p.Borrowed, p.Total);
                var healthStatus = GetPoolHealthStatus(p);
                var isRestarting = IsRestarting(p.Label);

                <div class="col-12 col-md-6 col-lg-4">
                    <div
                        class="card h-100 pool-card @(p.MaintenanceActive ? "maintenance-mode" : "") @(isRestarting ? "restarting" : "")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div class="pool-header">
                                    @{
                                        var engine = GetEngine(p.Label);
                                    }
                                    <div class="d-flex align-items-start">
                                        <span class="me-2 pool-icon @GetActivityIndicatorClass(isRestarting)"
                                              title="@engine">@((MarkupString)GetEngineIcon(engine))</span>
                                        <div>
                                            <div class="fw-semibold pool-name tooltip-trigger"
                                                 title="Pool: @p.Label\nEngine: @engine">@p.Label</div>
                                            @if (!string.IsNullOrWhiteSpace(p.BrowserVersion))
                                            {
                                                <div class="small text-muted browser-version tooltip-trigger"
                                                     title="Browser Version: @p.BrowserVersion">@p.BrowserVersion</div>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center flex-wrap gap-1">
                                    <span class="badge @healthStatus.badgeClass pool-status-badge tooltip-trigger"
                                          title="@GetPoolTooltip(p)">@healthStatus.status.ToUpper()</span>
                                    <span class="badge bg-light text-dark total-count">@p.Total total</span>
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary pool-actions-btn"
                                                type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                                title="Pool actions">
                                            &#8942;
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end dropdown-menu-enhanced">
                                            <li class="dropdown-header">
                                                <i class="fas fa-cog me-2"></i>Pool Actions
                                            </li>
                                            <li>
                                                <button class="dropdown-item @(isRestarting ? "loading" : "")"
                                                        disabled="@(p.MaintenanceActive || isRestarting)"
                                                        @onclick="() => RestartPool(p.Label)"
                                                        title="Restart all pre-warmed browsers in this pool">
                                                    @if (isRestarting)
                                                    {
                                                        <i class="spinner-border spinner-border-sm me-2" role="status"
                                                           aria-hidden="true"></i>
                                                        <span>Restarting…</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="fas fa-redo me-2 text-warning"></i>
                                                        <span>Restart Pool</span>
                                                    }
                                                </button>
                                            </li>
                                            <li>
                                                <hr class="dropdown-divider">
                                            </li>
                                            <li class="dropdown-header">
                                                <i class="fas fa-info-circle me-2"></i>Pool Info
                                            </li>
                                            <li>
                                                <button class="dropdown-item-info" disabled>
                                                    <div class="d-flex justify-content-between">
                                                        <span>Utilization:</span>
                                                        <strong>@((p.Total > 0 ? Math.Round(p.Borrowed * 100.0 / p.Total, 1) : 0).ToString("F1"))%</strong>
                                                    </div>
                                                </button>
                                            </li>
                                            <li>
                                                <button class="dropdown-item-info" disabled>
                                                    <div class="d-flex justify-content-between">
                                                        <span>Available:</span>
                                                        <strong class="text-success">@(p.Total - p.Borrowed)</strong>
                                                    </div>
                                                </button>
                                            </li>
                                            <li>
                                                <button class="dropdown-item-info" disabled>
                                                    <div class="d-flex justify-content-between">
                                                        <span>In Use:</span>
                                                        <strong class="text-primary">@p.Borrowed</strong>
                                                    </div>
                                                </button>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <div class="pool-stats mb-3">
                                <div class="row g-2 text-center">
                                    <div class="col-4">
                                        <div class="stat-value text-success">@(p.Total - p.Borrowed)</div>
                                        <div class="stat-label">Available</div>
                                    </div>
                                    <div class="col-4">
                                        <div class="stat-value text-danger">@p.Borrowed</div>
                                        <div class="stat-label">Borrowed</div>
                                    </div>
                                    <div class="col-4">
                                        <div class="stat-value text-primary">@borrowedPct%</div>
                                        <div class="stat-label">Utilization</div>
                                    </div>
                                </div>
                            </div>

                            <div class="progress enhanced-progress mb-2" role="progressbar"
                                 aria-label="Pool utilization"
                                 aria-valuemin="0" aria-valuemax="100" style="height: 8px;">
                                <div class="progress-bar bg-success progress-available"
                                     style="width:@(availPct)%"></div>
                                <div class="progress-bar bg-danger progress-borrowed"
                                     style="width:@(borrowedPct)%"></div>
                            </div>

                            @if (p.MaintenanceActive)
                            {
                                <div class="alert alert-warning alert-sm mb-2">
                                    <i class="fas fa-tools me-1"></i>
                                    <small>Maintenance mode: borrowing paused; counts frozen until pool is fully
                                        restored.</small>
                                </div>
                            }

                            @if (state.Workers is not null)
                            {
                                var poolWorkers = state.Workers.Where(w => w.Pools != null && w.Pools.ContainsKey(p.Label)).ToList();
                                if (poolWorkers.Count > 0)
                                {
                                    <div class="mt-2 small">
                                        <span class="text-muted me-1">Workers:</span>
                                        @foreach (var w in poolWorkers)
                                        {
                                            <span class="badge bg-light text-dark me-1"
                                                  title="@w.Id">@ShortId(w.Id)</span>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="d-flex align-items-center justify-content-between mt-4 mb-3">
        <h5 class="mb-0">Workers</h5>
        <div class="d-flex gap-2 align-items-center">
            <div class="search-controls">
                <input type="text" class="form-control form-control-sm" placeholder="Search workers..."
                       @bind="_workerSearchQuery" @oninput="StateHasChanged" style="width: 200px;">
            </div>
            <select class="form-select form-select-sm" @bind="_workerFilterStatus" style="width: 140px;">
                <option value="all">All Status</option>
                <option value="online">Online</option>
                <option value="warning">Warning</option>
                <option value="offline">Offline</option>
                <option value="quarantined">Quarantined</option>
            </select>
            <span class="badge bg-light text-dark">@state.Workers!.Count total</span>
        </div>
    </div>

    @if (GetFilteredAndSortedWorkers().Count() == 0)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            @if (state.Workers!.Count == 0)
            {
                <span>No workers registered. Workers will appear here once they connect to the hub.</span>
            }
            else
            {
                <span>No workers match the current filter criteria.</span>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle workers-table">
                <thead>
                <tr>
                    <th scope="col" style="width: 40px;"></th>
                    <th scope="col">Worker</th>
                    <th scope="col" class="d-none d-md-table-cell"
                        title="Worker-provided metadata labels (e.g., region=local). 'local' is the default region if NODE_REGION is not set.">
                        Labels
                    </th>
                    <th scope="col">Status</th>
                    <th scope="col" class="d-none d-lg-table-cell">Playwright</th>
                    <th scope="col" class="text-end">Browsers</th>
                    <th scope="col" class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var w in GetFilteredAndSortedWorkers())
                {
                    var connectionStatus = GetWorkerConnectionStatus(w);
                    var isUpgrading = IsUpgrading(w.Id);

                    <tr class="worker-row @(w.Quarantined ? "quarantined" : "")">
                        <td>
                            <button class="btn btn-sm btn-link expand-btn p-0"
                                    @onclick="() => ToggleWorkerExpansion(w.Id)"
                                    title="@(_expandedWorkers.Contains(w.Id) ? "Collapse details" : "Expand details")">
                                <i class="fas @(_expandedWorkers.Contains(w.Id) ? "fa-chevron-up" : "fa-chevron-down")"></i>
                            </button>
                        </td>
                        <td>
                            <div class="worker-info">
                                <span class="fw-semibold worker-id tooltip-trigger"
                                      title="@GetWorkerTooltip(w)">@ShortId(w.Id)</span>
                                <div class="d-md-none small text-muted mt-1">
                                    @if (w.Labels?.Count > 0)
                                    {
                                        @foreach (var lab in w.Labels.Take(2))
                                        {
                                            var truncated = TruncateLabel(lab);
                                            <span class="badge bg-light text-dark me-1 label-badge tooltip-trigger"
                                                  title="@lab">@truncated</span>
                                        }

                                        @if (w.Labels.Count > 2)
                                        {
                                            <span class="text-muted tooltip-trigger"
                                                  title="@string.Join("\n", w.Labels.Skip(2))">+@(w.Labels.Count - 2) more</span>
                                        }
                                    }
                                </div>
                            </div>
                        </td>
                        <td class="d-none d-md-table-cell">
                            @if (w.Labels == null || w.Labels.Count == 0)
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                @foreach (var lab in w.Labels.Take(3))
                                {
                                    var truncated = TruncateLabel(lab);
                                    <span class="badge bg-light text-dark me-1 label-badge tooltip-trigger"
                                          title="@lab">@truncated</span>
                                }

                                @if (w.Labels.Count > 3)
                                {
                                    <span class="text-muted small tooltip-trigger"
                                          title="@string.Join("\n", w.Labels.Skip(3))">+@(w.Labels.Count - 3) more</span>
                                }
                            }
                        </td>
                        <td>
                            <div class="worker-status">
                                <span class="badge @connectionStatus.badgeClass worker-status-badge mb-1"
                                      title="@connectionStatus.description">@connectionStatus.status.ToUpper()</span>
                                <div class="small text-muted"
                                     title="@w.LastSeen.ToString("u")">@FormatAgo(w.LastSeen)</div>
                            </div>
                        </td>
                        <td class="d-none d-lg-table-cell">
                            @if (string.IsNullOrWhiteSpace(w.PlaywrightVersion))
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                <span class="playwright-version">@w.PlaywrightVersion</span>
                            }
                        </td>
                        <td class="text-end">
                            <span class="browser-count">@w.TotalBrowsers</span>
                        </td>
                        <td class="text-end">
                            <div class="dropdown d-inline">
                                <button
                                    class="btn btn-sm btn-outline-secondary worker-actions-btn @(isUpgrading ? "activity-pulse" : "")"
                                    type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                    title="Worker actions">
                                    &#8943;
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end dropdown-menu-sm dropdown-menu-enhanced">
                                    <li class="dropdown-header">
                                        <i class="fas fa-server me-2"></i>Worker Actions
                                    </li>
                                    <li>
                                        <button class="dropdown-item @(isUpgrading ? "loading" : "")"
                                                disabled="@isUpgrading"
                                                title="Graceful drain and restart sidecars on this worker"
                                                @onclick="() => UpgradeWorker(w.Id)">
                                            @if (isUpgrading)
                                            {
                                                <i class="spinner-border spinner-border-sm me-2" role="status"
                                                   aria-hidden="true"></i>
                                                <span>Restarting…</span>
                                            }
                                            else
                                            {
                                                <i class="fas fa-sync-alt me-2 text-warning"></i>
                                                <span>Restart Worker</span>
                                            }
                                        </button>
                                    </li>
                                    @if (w.Quarantined)
                                    {
                                        <li>
                                            <hr class="dropdown-divider">
                                        </li>
                                        <li>
                                            <button class="dropdown-item text-danger" disabled>
                                                <i class="fas fa-exclamation-triangle me-2"></i>
                                                <span>Quarantined</span>
                                            </button>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </td>
                    </tr>
                    @if (_expandedWorkers.Contains(w.Id))
                    {
                        <tr class="worker-details-row">
                            <td></td>
                            <td colspan="6" class="p-0">
                                <div class="worker-details-panel">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <div class="detail-card">
                                                <h6 class="detail-title"><i
                                                        class="fas fa-info-circle text-primary me-2"></i>Worker
                                                    Information</h6>
                                                <div class="detail-content">
                                                    <div class="detail-item">
                                                        <strong>Full ID:</strong> <code
                                                            class="worker-id-full">@w.Id</code>
                                                    </div>
                                                    <div class="detail-item">
                                                        <strong>Status:</strong> <span
                                                            class="badge @connectionStatus.badgeClass">@connectionStatus.status</span>
                                                    </div>
                                                    <div class="detail-item">
                                                        <strong>Last
                                                            Seen:</strong> @w.LastSeen.ToString("yyyy-MM-dd HH:mm:ss") UTC
                                                    </div>
                                                    <div class="detail-item">
                                                        <strong>Quarantined:</strong> <span
                                                            class="@(w.Quarantined ? "text-danger" : "text-success")">@(w.Quarantined ? "Yes" : "No")</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="detail-card">
                                                <h6 class="detail-title"><i class="fas fa-cogs text-success me-2"></i>Technical
                                                    Details</h6>
                                                <div class="detail-content">
                                                    <div class="detail-item">
                                                        <strong>Total Browsers:</strong> @w.TotalBrowsers
                                                    </div>
                                                    @if (!string.IsNullOrWhiteSpace(w.PlaywrightVersion))
                                                    {
                                                        <div class="detail-item">
                                                            <strong>Playwright Version:</strong>
                                                            <code>@w.PlaywrightVersion</code>
                                                        </div>
                                                    }
                                                    @if (w.Labels?.Count > 0)
                                                    {
                                                        <div class="detail-item">
                                                            <strong>Labels:</strong>
                                                            <div class="mt-1">
                                                                @foreach (var label in w.Labels)
                                                                {
                                                                    <span
                                                                        class="badge bg-light text-dark me-1 mb-1">@label</span>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    }

    <!-- Phase 3: Analytics Dashboard -->
    <div class="analytics-section mt-5">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h4 class="mb-0"><i class="fas fa-chart-line text-primary me-2"></i>Analytics & Performance</h4>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm" style="width: 120px;">
                    <option value="1h">Last Hour</option>
                    <option value="24h" selected>Last 24h</option>
                    <option value="7d">Last 7 Days</option>
                    <option value="30d">Last 30 Days</option>
                </select>
                <button class="btn btn-sm btn-outline-secondary" title="Refresh Data">
                    <i class="fas fa-sync-alt"></i>
                </button>
            </div>
        </div>

        <!-- Key Metrics Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-3 col-sm-6">
                <div class="metric-card">
                    <div class="metric-header">
                        <i class="fas fa-clock text-info"></i>
                        <span>Avg Response Time</span>
                    </div>
                    <div class="metric-value">@GetAverageResponseTime()ms</div>
                    <div class="metric-trend @GetTrendClass("response", 5.2)">
                        <i class="fas @GetTrendIcon(5.2)"></i>
                        <span>+5.2% vs yesterday</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="metric-card">
                    <div class="metric-header">
                        <i class="fas fa-chart-line text-success"></i>
                        <span>Success Rate</span>
                    </div>
                    <div class="metric-value">@GetSuccessRate().ToString("F2")%</div>
                    <div class="metric-trend @GetTrendClass("success", 2.1)">
                        <i class="fas @GetTrendIcon(2.1)"></i>
                        <span>+2.1% vs yesterday</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="metric-card">
                    <div class="metric-header">
                        <i class="fas fa-users text-warning"></i>
                        <span>Peak Concurrency</span>
                    </div>
                    <div class="metric-value">@GetPeakConcurrency()</div>
                    <div class="metric-trend @GetTrendClass("concurrency", -1.3)">
                        <i class="fas @GetTrendIcon(-1.3)"></i>
                        <span>-1.3% vs yesterday</span>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="metric-card">
                    <div class="metric-header">
                        <i class="fas fa-server text-danger"></i>
                        <span>Resource Usage</span>
                    </div>
                    <div class="metric-value">@GetResourceUsage()%</div>
                    <div class="metric-trend @GetTrendClass("resource", 0.8)">
                        <i class="fas @GetTrendIcon(0.8)"></i>
                        <span>+0.8% vs yesterday</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- System Health Alerts -->
        <div class="alerts-section mb-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="mb-0"><i class="fas fa-bell text-warning me-2"></i>System Alerts</h6>
                <span class="badge bg-warning">@GetActiveAlertsCount() Active</span>
            </div>

            <div class="alerts-container">
                @foreach (var alert in GetSystemAlerts())
                {
                    <div class="alert-item @GetAlertClass(alert.severity)">
                        <div class="alert-icon">
                            <i class="fas @GetAlertIcon(alert.severity)"></i>
                        </div>
                        <div class="alert-content">
                            <div class="alert-title">@alert.title</div>
                            <div class="alert-description">@alert.description</div>
                            <div class="alert-time">@FormatAgo(alert.timestamp)</div>
                        </div>
                        <div class="alert-actions">
                            <button class="btn btn-sm btn-link text-muted" title="Dismiss">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </div>
                }

                @if (!GetSystemAlerts().Any())
                {
                    <div class="no-alerts">
                        <i class="fas fa-check-circle text-success fa-2x mb-2"></i>
                        <p class="text-muted mb-0">All systems operational</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="mt-3">
        <small class="text-muted">Updated @FormatAgo(state.Now) (UTC @state.Now.ToString("u"))</small>
    </div>
}

<ConfirmDialog @ref="Confirm"/>

<style>
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 2rem 0 1.5rem;
        margin-bottom: 2rem;
        border-bottom: 2px solid var(--border);
    }

    .header-content {
        display: flex;
        align-items: center;
        gap: 1.25rem;
    }

    .header-icon {
        display: flex;
