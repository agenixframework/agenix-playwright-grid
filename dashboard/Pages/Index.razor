@page "/"
@using Dashboard.Application.Ports
@implements IDisposable
@inject IPoolStateReader Proxy
@inject IHttpClientFactory HttpFactory

<div class="d-flex align-items-center my-3">
    <h3 class="mb-0">Live Browser Pool Dashboard</h3>
    <a class="btn btn-sm btn-outline-primary ms-auto" href="/results" title="Go to Test Results">View Test Results</a>
</div>

@if (Proxy.Get() is null)
{
    <div class="alert alert-info">Waiting for state...</div>
}
else
{
    var state = Proxy.Get();
    var totalPools = state!.Pools.Count;
    var totalBrowsers = state.Pools.Sum(p => p.Total);
    var borrowed = state.Pools.Sum(p => p.Borrowed);
    var available = totalBrowsers - borrowed;

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="text-muted small">Pools</div>
                    <div class="display-6">@totalPools</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="text-muted small">Browsers</div>
                    <div class="display-6">@totalBrowsers</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="text-muted small">Borrowed</div>
                    <div class="display-6 text-danger">@borrowed</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100">
                <div class="card-body">
                    <div class="text-muted small">Available</div>
                    <div class="display-6 text-success">@available</div>
                </div>
            </div>
        </div>
    </div>

    <h5 class="mt-3">Pools</h5>
    @if (state.Pools.Count == 0)
    {
        <div class="text-muted">No pools configured.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var p in state.Pools.OrderBy(x => x.Label))
            {
                var borrowedPct = Percent(p.Borrowed, p.Total);
                var availPct = Percent(p.Total - p.Borrowed, p.Total);
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 @(p.MaintenanceActive ? "bg-light border-secondary opacity-75" : "")">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="fw-semibold">
                                    @{
                                        var engine = GetEngine(p.Label);
                                    }
                                    <span class="me-1" title="@engine">@((MarkupString)GetEngineIcon(engine))</span>
                                    @p.Label
                                </div>
                                <div class="d-flex align-items-center">
                                    @if (p.MaintenanceActive)
                                    {
                                        <span class="badge bg-warning text-dark me-2"
                                              title="Borrowing paused; counts frozen">Maintenance</span>
                                    }
                                    <span class="badge bg-secondary">@p.Total total</span>
                                    <button class="btn btn-sm btn-outline-warning ms-2"
                                            disabled="@(IsRestarting(p.Label) || p.MaintenanceActive)"
                                            title="@(p.MaintenanceActive ? "Pool is in maintenance; restart disabled" : "Recycle all pre-warmed browsers in this pool")"
                                            @onclick="() => RestartPool(p.Label)">
                                        @if (IsRestarting(p.Label))
                                        {
                                            <span class="spinner-border spinner-border-sm me-1" role="status"
                                                  aria-hidden="true"></span>
                                            <span>Restarting…</span>
                                        }
                                        else
                                        {
                                            <span>Restart All</span>
                                        }
                                    </button>
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(p.BrowserVersion))
                            {
                                <div class="small text-muted">Browser: @p.BrowserVersion</div>
                            }
                            <div class="mt-2 small">
                                <span class="text-danger me-2">Borrowed: @p.Borrowed</span>
                                <span class="text-success">Available: @(p.Total - p.Borrowed)</span>
                            </div>
                            <div class="progress mt-2" role="progressbar" aria-label="Pool utilization"
                                 aria-valuemin="0" aria-valuemax="100">
                                <div class="progress-bar bg-success" style="width:@(availPct)%"></div>
                                <div class="progress-bar bg-danger" style="width:@(borrowedPct)%"></div>
                            </div>
                            <div class="d-flex justify-content-between small text-muted mt-1">
                                <div>@availPct% available</div>
                                <div>@borrowedPct% borrowed</div>
                            </div>
                            @if (p.MaintenanceActive)
                            {
                                <div class="mt-2 small text-muted">
                                    Maintenance mode: borrowing paused; counts frozen until pool is fully restored.
                                </div>
                            }

                            @if (state.Workers is not null)
                            {
                                var poolWorkers = state.Workers.Where(w => w.Pools != null && w.Pools.ContainsKey(p.Label)).ToList();
                                if (poolWorkers.Count > 0)
                                {
                                    <div class="mt-2 small">
                                        <span class="text-muted me-1">Workers:</span>
                                        @foreach (var w in poolWorkers)
                                        {
                                            <span class="badge bg-light text-dark me-1"
                                                  title="@w.Id">@ShortId(w.Id)</span>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <h5 class="mt-4">Workers</h5>
    @if (state.Workers.Count == 0)
    {
        <div class="text-muted">No workers registered.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                <tr>
                    <th scope="col">Worker</th>
                    <th scope="col"
                        title="Worker-provided metadata labels (e.g., region=local). 'local' is the default region if NODE_REGION is not set.">
                        Labels
                    </th>
                    <th scope="col">Last seen</th>
                    <th scope="col">Playwright</th>
                    <th scope="col" class="text-end">Total browsers</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var w in state.Workers)
                {
                    <tr>
                        <td class="fw-semibold" title="@w.Id">@ShortId(w.Id)</td>
                        <td>
                            @if (w.Labels == null || w.Labels.Count == 0)
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                @foreach (var lab in w.Labels)
                                {
                                    <span class="badge bg-light text-dark me-1">@lab</span>
                                }
                            }
                        </td>
                        <td>
                            <span title="@w.LastSeen.ToString("u")">@FormatAgo(w.LastSeen)</span>
                        </td>
                        <td>
                            @if (string.IsNullOrWhiteSpace(w.PlaywrightVersion))
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                <span>@w.PlaywrightVersion</span>
                            }
                        </td>
                        <td class="text-end">@w.TotalBrowsers</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-3">
        <small class="text-muted">Updated @FormatAgo(state.Now) (UTC @state.Now.ToString("u"))</small>
    </div>
}

@code {

    private readonly HashSet<string> _restarting = new(StringComparer.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        Proxy.Changed += OnProxyChanged;
    }

    private void OnProxyChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Proxy.Changed -= OnProxyChanged;
    }

    private bool IsRestarting(string labelKey)
    {
        return _restarting.Contains(labelKey);
    }

    private async Task RestartPool(string labelKey)
    {
        if (string.IsNullOrWhiteSpace(labelKey)) return;
        if (!_restarting.Add(labelKey)) return;
        // trigger immediate UI update so the button disables/spinner shows right away
        await InvokeAsync(StateHasChanged);
        try
        {
            var client = HttpFactory.CreateClient("hub");
            using var resp = await client.PostAsync($"/admin/pools/{Uri.EscapeDataString(labelKey)}/restart", new StringContent(""));
            // optional: could display a toast or console log
        }
        catch
        {
            // swallow errors for UI simplicity; could be enhanced with notifications
        }
        finally
        {
            _restarting.Remove(labelKey);
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string ShortId(string id)
    {
        return string.IsNullOrEmpty(id) ? "-" : id.Length <= 8 ? id : id[..8];
    }

    private static string FormatAgo(DateTime dt)
    {
        var utc = dt.Kind == DateTimeKind.Unspecified ? DateTime.SpecifyKind(dt, DateTimeKind.Utc) : dt.ToUniversalTime();
        var span = DateTime.UtcNow - utc;
        if (span.TotalSeconds < 0) span = TimeSpan.Zero;
        if (span.TotalSeconds < 60) return $"{(int)span.TotalSeconds}s ago";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return $"{(int)span.TotalDays}d ago";
    }

    private static int Percent(int part, int total)
    {
        return total <= 0 ? 0 : (int)Math.Round(part * 100.0 / Math.Max(1, total));
    }

    private static string GetEngine(string label)
    {
        if (string.IsNullOrWhiteSpace(label)) return "Chromium";
        var parts = label.Split(':', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length >= 2 ? parts[1] : label;
    }

    private static string NormalizeEngineKey(string engine)
    {
        var e = engine?.Trim().ToLowerInvariant() ?? "";
        return e switch
        {
            "safari" => "webkit",
            "webkit" => "webkit",
            "firefox" => "firefox",
            "ff" => "firefox",
            "chromium" => "chromium",
            "chrome" => "chromium",
            "google chrome" => "chromium",
            "chronium" => "chromium",
            _ => e
        };
    }

    private static string GetEngineIcon(string engine)
    {
        var key = NormalizeEngineKey(engine);
        return key switch
        {
            "chromium" => "<svg width='18' height='18' viewBox='0 0 24 24' aria-hidden='true'><circle cx='12' cy='12' r='10' fill='#4285F4'/><path d='M12 7a5 5 0 100 10 5 5 0 000-10zm0 2a3 3 0 110 6 3 3 0 010-6z' fill='white'/></svg>",
            "firefox" => "<svg width='18' height='18' viewBox='0 0 24 24' aria-hidden='true'><circle cx='12' cy='12' r='10' fill='#FF7139'/><path d='M12 7c-2.5 0-4.5 2-4.5 4.5S9.5 16 12 16c2 0 3.8-1.4 4.3-3.3-.4.2-.9.3-1.3.3-1.7 0-3-1.3-3-3 0-.4.1-.9.3-1.3C11.4 8.2 10 10 10 12c0 .8.3 1.6.8 2.2-1.2-.4-2.1-1.6-2.1-3 0-1.8 1.5-3.2 3.3-3.2z' fill='white'/></svg>",
            "webkit" => "<svg width='18' height='18' viewBox='0 0 24 24' aria-hidden='true'><circle cx='12' cy='12' r='10' fill='#1b9df0'/><circle cx='12' cy='12' r='7.5' fill='white'/><polygon points='12,6 14.5,12 12,18 9.5,12' fill='#ff3b30'/><polygon points='12,7.5 13.4,12 12,16.5 10.6,12' fill='#ffffff'/></svg>",
            _ => "<svg width='18' height='18' viewBox='0 0 24 24' aria-hidden='true'><path fill='#6c757d' d='M9 3h6v2l-2 3v7l3 4v2H8v-2l3-4V8L9 5V3z'/></svg>"
        };
    }


}
