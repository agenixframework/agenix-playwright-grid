            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            using var content = JsonContent.Create(new Dictionary<string, string> { ["accountRole"] = "Administrator" });
            using var resp = await client.PatchAsync($"/admin/users/{Uri.EscapeDataString(id)}", content);
