    /// <summary>
    ///     Recursively expands all parent steps up to the root
    /// </summary>
    private void ExpandParentSteps(Guid? stepId)
    {
        if (!stepId.HasValue) return;

        // Expand this step
        if (!_expandedSteps.Contains(stepId.Value))
        {
            _expandedSteps.Add(stepId.Value);
        }

        // Find the parent of this step and recursively expand it
        var parentStep = _logEntries.FirstOrDefault(e => e.Id == stepId.Value);
        if (parentStep != null && parentStep.ParentId.HasValue)
        {
            ExpandParentSteps(parentStep.ParentId);
        }
    }

    /// <summary>
    ///     Switches to a different tab and clears any persistent highlights
    /// </summary>
    private async Task SwitchTabAsync(string tabName)
    {
        // Clear any persistent highlights when switching tabs
        try
        {
            await JS.InvokeVoidAsync("window.clearHighlights");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to clear highlights when switching to tab {TabName}", tabName);
        }

        // Prevent switching to browser/commands tabs if no browser session exists
        if ((tabName == "browser" || tabName == "commands") && !HasBrowserSession())
        {
            _activeTab = "logs";
            return;
        }

        _activeTab = tabName;

        // Preload artifact URLs when switching to artifacts tab
        if (tabName == "artifacts")
        {
            _ = Task.Run(async () => await PreloadArtifactUrlsAsync());
        }
    }

    /// <summary>
    ///     Determines if the current test item has an associated browser session.
    ///     Only Test and Scenario item types can have browser sessions.
    /// </summary>
    private bool HasBrowserSession()
    {
        if (_testItem == null) return false;

        // Only Test and Scenario types can have browser sessions
        if (_testItem.ItemType != "Test" && _testItem.ItemType != "Scenario")
            return false;

        // Check if browser was actually borrowed
        return !string.IsNullOrEmpty(_testItem.BrowserId) ||
               !string.IsNullOrEmpty(_testItem.WebSocketEndpoint);
    }

    /// <summary>
    ///     Checks if a step contains any ERROR or FATAL logs among its children
    /// </summary>
    private bool StepContainsErrorLogs(Guid stepId)
    {
        return _logEntries.Any(e =>
            !e.IsStepHeader &&
            e.ParentId == stepId &&
            (e.Level.ToLower() == "error" || e.Level.ToLower() == "fatal"));
    }

    /// <summary>
    ///     Sorts log entries in hierarchical order: each parent is immediately followed by its children and their logs
    /// </summary>
    private List<LogEntryDto> SortLogEntriesHierarchically(List<LogEntryDto> entries)
    {
        var result = new List<LogEntryDto>();
        var entriesById = entries.ToDictionary(e => e.Id);

        // Helper function to recursively add a parent and all its descendants
        void AddEntryAndDescendants(LogEntryDto entry)
        {
            // Add the current entry
            result.Add(entry);

            // If this is a step header, add its child logs first (non-step-header children)
            var childLogs = entries
                .Where(e => !e.IsStepHeader && e.ParentId == entry.Id)
                .OrderBy(e => e.Timestamp)
                .ToList();

            foreach (var childLog in childLogs)
            {
                result.Add(childLog);
            }

            // Then add nested step headers (child steps) and their descendants recursively
            var childSteps = entries
                .Where(e => e.IsStepHeader && e.ParentId == entry.Id)
                .OrderBy(e => e.Timestamp)
                .ToList();

            foreach (var childStep in childSteps)
            {
                AddEntryAndDescendants(childStep); // Recursive call
            }
        }

        // Start with top-level entries (no parent or parent not in the list)
        var topLevelEntries = entries
            .Where(e => !e.ParentId.HasValue || !entriesById.ContainsKey(e.ParentId.Value))
            .OrderBy(e => e.Timestamp)
            .ToList();

        foreach (var entry in topLevelEntries)
        {
            AddEntryAndDescendants(entry);
        }

        Logger.LogInformation("Sorted {Original} log entries into hierarchical order: {Sorted} entries",
            entries.Count, result.Count);

        return result;
    }

    // DTO for log entries
    private class LogEntryDto
    {
        public Guid Id { get; set; } = Guid.NewGuid();
        public Guid? ParentId { get; set; }
        public bool IsStepHeader { get; set; }
        public bool IsNested { get; set; }
        public int NestLevel { get; set; }
        public DateTimeOffset Timestamp { get; set; } = DateTimeOffset.UtcNow;
        public string Level { get; set; } = "INFO";
        public string Source { get; set; } = "";
        public string Message { get; set; } = "";
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public string Status { get; set; } = "InProgress";
        public long? DurationMs { get; set; }
        public int AttachmentCount { get; set; }
        public bool HasAttachment { get; set; }
        public string AttachmentType { get; set; } = "";
        public string AttachmentName { get; set; } = "";
        public Guid? ArtifactId { get; set; }
        public bool IsTruncated => Message.Length > 300;
    }

    // DTO for stack trace entries
    private class StackTraceEntryDto
    {
        public Guid Id { get; set; } = Guid.NewGuid();
        public Guid? LogEntryId { get; set; }
        public DateTimeOffset Timestamp { get; set; } = DateTimeOffset.UtcNow;
        public string Context { get; set; } = "";
        public string Level { get; set; } = "ERROR";
        public string ExceptionClass { get; set; } = "";
        public string Message { get; set; } = "";
        public string? HttpMethod { get; set; }
        public string? Url { get; set; }
        public int? StatusCode { get; set; }
        public string? StatusMessage { get; set; } // HTTP status text (e.g., "Conflict", "Internal Server Error")
        public List<string> ExceptionMessages { get; set; } = new(); // Exception messages and "Caused by:" chains
        public List<string> StackTraceLines { get; set; } = new(); // Stack trace code lines
    }

    // Export methods
    private async Task ExportLogsAsJson()
    {
        var json = JsonSerializer.Serialize(FilteredLogEntries, new JsonSerializerOptions { WriteIndented = true });
        await JS.InvokeVoidAsync("downloadFile", "logs.json", "application/json", json);
    }

    private async Task ExportLogsAsCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Timestamp,Level,Source,Message,Status,Duration");
        foreach (var entry in FilteredLogEntries)
        {
            if (entry.IsStepHeader)
            {
                sb.AppendLine($"\"{entry.Timestamp:yyyy-MM-dd HH:mm:ss}\",STEP,{entry.Source},\"{entry.Name}\",{entry.Status},{entry.DurationMs}");
            }
            else
            {
                var escapedMessage = entry.Message.Replace("\"", "\"\"");
                sb.AppendLine($"\"{entry.Timestamp:yyyy-MM-dd HH:mm:ss}\",{entry.Level},{entry.Source},\"{escapedMessage}\",,,");
            }
        }
        await JS.InvokeVoidAsync("downloadFile", "logs.csv", "text/csv", sb.ToString());
    }

    // ==== Playwright Server Commands Tab ====
    private List<CommandLogEventDto>? _commands;
    private string _cmdKindFilter = string.Empty;
    private string _cmdDirectionFilter = string.Empty;
    private int _cmdPage = 1;
    private readonly int _cmdPageSize = 50;

    private int CmdTotal => FilteredCommands.Count;
    private int CmdTotalPages => Math.Max(1, (int)Math.Ceiling(CmdTotal / (double)_cmdPageSize));
    private int PageStart => CmdTotal == 0 ? 0 : (_cmdPage - 1) * _cmdPageSize + 1;
    private int PageEnd => Math.Min(_cmdPage * _cmdPageSize, CmdTotal);

    private List<CommandLogEventDto> PagedCommands
    {
        get
        {
            var list = FilteredCommands;
            var skip = Math.Max(0, (_cmdPage - 1) * _cmdPageSize);
            return list.Skip(skip).Take(_cmdPageSize).ToList();
        }
    }

    private List<CommandLogEventDto> FilteredCommands
    {
        get
        {
            var commands = _commands ?? new List<CommandLogEventDto>();
            return commands
                .Where(c => string.IsNullOrWhiteSpace(_cmdKindFilter) ||
                           c.Kind?.Contains(_cmdKindFilter, StringComparison.OrdinalIgnoreCase) == true)
                .Where(c =>
                {
                    if (string.IsNullOrWhiteSpace(_cmdDirectionFilter)) return true;
                    var dir = string.Empty;
                    if (c.Props != null && c.Props.TryGetValue("direction", out var d) && d != null)
                        dir = d;
                    return dir.Contains(_cmdDirectionFilter, StringComparison.OrdinalIgnoreCase);
                })
                .OrderBy(c => c.TimestampUtc)
                .ToList();
        }
    }

    private int CommandCount => _commands?.Count ?? 0;

    private Dictionary<string, int> KindCounts
    {
        get
        {
            var commands = _commands ?? new List<CommandLogEventDto>();
            return commands
                .GroupBy(c => string.IsNullOrWhiteSpace(c.Kind) ? "(none)" : c.Kind)
                .ToDictionary(g => g.Key, g => g.Count(), StringComparer.OrdinalIgnoreCase);
        }
    }

    private string DurationText()
    {
        if (_testItem == null) return "-";
        var start = _testItem.StartTime;
        var end = _testItem.FinishTime ?? DateTimeOffset.UtcNow;
        if (end < start) end = start;
        var span = end - start;
        if (span.TotalSeconds < 1) return "<1s";
        if (span.TotalMinutes < 1) return $"{(int)span.TotalSeconds}s";
        if (span.TotalHours < 1) return $"{(int)span.TotalMinutes}m {span.Seconds}s";
        return $"{(int)span.TotalHours}h {span.Minutes}m";
    }

    private async Task PrevCmdPage()
    {
        if (_cmdPage > 1)
        {
            _cmdPage--;
            StateHasChanged();
        }
        await Task.CompletedTask;
    }

    private async Task NextCmdPage()
    {
        if (_cmdPage < CmdTotalPages)
        {
            _cmdPage++;
            StateHasChanged();
        }
        await Task.CompletedTask;
    }

    private void ResetCmdPage()
    {
        _cmdPage = 1;
    }

    private void OnKindInput(ChangeEventArgs e)
    {
        _cmdKindFilter = e.Value?.ToString() ?? string.Empty;
        ResetCmdPage();
        StateHasChanged();
    }

    private void OnDirectionInput(ChangeEventArgs e)
    {
        _cmdDirectionFilter = e.Value?.ToString() ?? string.Empty;
        ResetCmdPage();
        StateHasChanged();
    }

    private void SetKindFilter(string kind)
    {
        _cmdKindFilter = kind ?? string.Empty;
        ResetCmdPage();
        StateHasChanged();
    }

    private void ClearKindFilter()
    {
        _cmdKindFilter = string.Empty;
        ResetCmdPage();
        StateHasChanged();
    }

    private async Task CopyCommand(CommandLogEventDto ev)
    {
        var props = ev.Props is null || ev.Props.Count == 0
            ? string.Empty
            : string.Join(" ", ev.Props.Select(kv => $"{kv.Key}={kv.Value}"));
        var text = $"{ev.TimestampUtc:o} [{ev.Kind}] {ev.Message} {props}".Trim();
        try
        {
            await JS.InvokeVoidAsync("copyText", text);
            await JS.InvokeVoidAsync("alert", "Command copied to clipboard");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Copy command failed for test item {ItemId}", _testItem?.Id);
        }
    }

    private MarkupString RenderPlaywrightProtocol(CommandLogEventDto ev)
    {
        var dir = "";
        if (ev.Props != null && ev.Props.TryGetValue("direction", out var d)) dir = d ?? "";
        var badgeClass = string.Equals(dir, "c2s", StringComparison.OrdinalIgnoreCase) ? "primary" : "info";
        var dirBadge = string.IsNullOrWhiteSpace(dir) ? string.Empty : $"<span class=\"badge bg-{badgeClass} me-2\">{dir}</span>";

        var text = ev.Message ?? string.Empty;
        var pretty = text;
        try
        {
            using var doc = JsonDocument.Parse(text);
            pretty = JsonSerializer.Serialize(doc.RootElement, new JsonSerializerOptions
            {
                WriteIndented = true
            });
        }
        catch
        {
            /* leave as-is if not JSON */
        }

        // Encode content to avoid HTML injection; keep our own badges unencoded
        var encoded = WebUtility.HtmlEncode(pretty);
        var html = $"{dirBadge}<pre class=\"mb-0 small\" style=\"white-space:pre-wrap; overflow:auto; max-height:24rem;\">{encoded}</pre>";
        return new MarkupString(html);
    }

    // ==== Artifacts Tab ====
    private int _currentArtifactIndex;
    private readonly Dictionary<Guid, string> _artifactUrlCache = new();

    private void NavigateToPreviousArtifact()
    {
        if (_currentArtifactIndex > 0)
        {
            _currentArtifactIndex--;
            StateHasChanged();
        }
    }

    private void NavigateToNextArtifact()
    {
        if (_testItem?.Attachments != null && _currentArtifactIndex < _testItem.Attachments.Count - 1)
        {
            _currentArtifactIndex++;
            StateHasChanged();
        }
    }

    private void SelectArtifact(int index)
    {
        if (_testItem?.Attachments != null && index >= 0 && index < _testItem.Attachments.Count)
        {
            _currentArtifactIndex = index;
            StateHasChanged();
        }
    }

    private void ScrollThumbnailsLeft()
    {
        NavigateToPreviousArtifact();
    }

    private void ScrollThumbnailsRight()
    {
        NavigateToNextArtifact();
    }

    private async Task PreloadArtifactUrlsAsync()
    {
        if (_testItem?.Attachments == null) return;

        foreach (var artifact in _testItem.Attachments)
        {
            if (!_artifactUrlCache.ContainsKey(artifact.Id))
            {
                var url = await GetArtifactUrlAsync(artifact.Id);
                _artifactUrlCache[artifact.Id] = url;
            }
        }

        StateHasChanged();
    }

    private async Task<string> GetArtifactUrlAsync(Guid artifactId)
    {
        // Try SessionStorage cache first
        var cachedUrl = await JS.InvokeAsync<string>("ArtifactCache.getCachedUrl", new object[] { artifactId.ToString() });
        if (!string.IsNullOrEmpty(cachedUrl))
        {
            return cachedUrl;
        }

        // Cache miss - get pre-signed URL from backend
        try
        {
            var http = HttpFactory.CreateClient(HttpClientNames.Hub);
            var response = await http.GetAsync($"/api/artifacts/{artifactId}/url?expirySeconds=3600");

            if (response.IsSuccessStatusCode)
            {
                var urlResponse = await response.Content.ReadFromJsonAsync<ArtifactUrlResponse>();
                if (urlResponse != null)
                {
                    // Cache the pre-signed URL
                    await JS.InvokeAsync<object>("ArtifactCache.cacheUrl", new object[]
                    {
                        artifactId.ToString(),
                        urlResponse.Url,
                        urlResponse.ExpiresAt.ToString("o")
                    });

                    return urlResponse.Url;
                }
            }
        }
        catch
        {
            // Fallback to direct download endpoint
        }

        // Fallback: use dashboard proxy endpoint (relative URL)
        return $"/api/artifacts/{artifactId}";
    }

    private string GetArtifactUrl(Guid artifactId)
    {
        // Return cached URL if available
        if (_artifactUrlCache.TryGetValue(artifactId, out var url))
        {
            return url;
        }

        // Fallback: use dashboard proxy endpoint (relative URL)
        // Will be replaced when preload completes
        return $"/api/artifacts/{artifactId}";
    }

    private string GetInlineArtifactUrl(string artifactUrl)
    {
        // Add inline=true query parameter for browser inline display
        if (artifactUrl.Contains("?"))
        {
            // URL already has query parameters (e.g., pre-signed MinIO URL)
            return $"{artifactUrl}&inline=true";
        }

        // Direct endpoint URL - add first query parameter
        return $"{artifactUrl}?inline=true";
    }

    private string GetDownloadArtifactUrl(string artifactUrl)
    {
        // Remove inline=true if present (forces attachment disposition)
        return artifactUrl.Replace("?inline=true", "").Replace("&inline=true", "");
    }

    private async Task DownloadArtifact(string url, string filename)
    {
        // Simple direct download link (preserves auth, works for all file types)
        await JS.InvokeVoidAsync("eval", $@"
            const a = document.createElement('a');
            a.href = '{url}';
            a.download = '{filename}';
            a.click();
        ");
    }

    private async Task DownloadAllArtifactsAsZip()
    {
        if (_testItem == null) return;

        // Use relative URL - dashboard proxies zip download to Hub
        var url = $"/api/test-items/{_testItem.Id}/artifacts/download-zip";

        await JS.InvokeVoidAsync("eval", $"window.location.href = '{url}';");
    }

    private record ArtifactUrlResponse(Guid ArtifactId, string Url, int ExpiresInSeconds, DateTime ExpiresAt, string FileName, string ContentType, long FileSize);

    private static bool IsImage(string contentType)
    {
        return contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetFileExtension(string fileName)
    {
        if (string.IsNullOrEmpty(fileName))
            return "FILE";

        var extension = Path.GetExtension(fileName);
        return string.IsNullOrEmpty(extension) ? "FILE" : extension.TrimStart('.');
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
            return $"{bytes} B";
        if (bytes < 1024 * 1024)
            return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}
