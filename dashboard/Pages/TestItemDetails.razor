    // Tooltip methods
    private async void ShowTooltip(MouseEventArgs e, TestHistoryItemDto historyItem)
    {
        _tooltipData = historyItem;

        // Use JavaScript to get element position
        try
        {
            var element = await JS.InvokeAsync<JsonElement>("eval", $@"
                (function() {{
                    var badges = document.querySelectorAll('.history-status-block');
                    var targetBadge = null;
                    for (var i = 0; i < badges.length; i++) {{
                        if (badges[i].textContent.trim() === '#{historyItem.LaunchNumber}') {{
                            targetBadge = badges[i];
                            break;
                        }}
                    }}
                    if (!targetBadge) return null;
                    var rect = targetBadge.getBoundingClientRect();
                    return {{ left: rect.left, top: rect.top, width: rect.width, height: rect.height }};
                }})()
            ");

            if (element.ValueKind != JsonValueKind.Null && element.ValueKind != JsonValueKind.Undefined)
            {
                var left = element.GetProperty("left").GetDouble();
                var top = element.GetProperty("top").GetDouble();
                var width = element.GetProperty("width").GetDouble();
                var height = element.GetProperty("height").GetDouble();

                // Position tooltip below the badge, centered horizontally
                var tooltipLeft = left + width / 2;
                var tooltipTop = top + height + 15; // 15px gap below badge (closer to history line)

                _tooltipStyle = $"position: fixed; left: {tooltipLeft}px; top: {tooltipTop}px; transform: translateX(-50%); z-index: 1050; display: block;";
                _tooltipVisible = true;
                StateHasChanged();
            }
            else
            {
                // Element not found, hide tooltip
                _tooltipVisible = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            // Log error and hide tooltip
            Logger.LogWarning(ex, "Failed to position tooltip for launch #{LaunchNumber}", historyItem.LaunchNumber);
            _tooltipVisible = false;
            StateHasChanged();
        }
    }

    private void HideTooltip()
    {
