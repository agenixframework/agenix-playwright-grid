    // Phase 2: Load Sibling Tests for Navigation
    private async Task LoadSiblingTestsAsync()
    {
        if (_testItem?.ParentItemId == null)
        {
            // Root level test, no siblings
            _siblingTests = null;
            _previousTestId = null;
            _nextTestId = null;
            return;
        }

        try
        {
            var http = HttpFactory.CreateClient(HttpClientNames.Hub);
            http.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);

            var response = await http.GetAsync(
                $"/api/test-items/{_testItem.ParentItemId}/children?itemType=Test"
            );

            if (response.IsSuccessStatusCode)
            {
                // Backend returns wrapper: { parentId, parentName, parentItemType, childCount, children }
                var wrapper = await response.Content
                    .ReadFromJsonAsync<ChildItemsResponse>();

                _siblingTests = wrapper?.Children ?? [];

                CalculatePreviousNextIds();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load sibling tests for parent {ParentItemId}", _testItem.ParentItemId);
            _siblingTests = null;
        }
    }

    private void CalculatePreviousNextIds()
    {
        if (_siblingTests == null || _testItem == null)
        {
            _previousTestId = null;
            _nextTestId = null;
            return;
        }

        // Sort to match UI display order: newest first (descending by StartTime)
        // This matches TestRunDetails default sort order
        var sortedTests = _siblingTests
            .OrderByDescending(t => t.StartTime)
            .ToList();

        var currentIndex = sortedTests.FindIndex(t => t.Id == _testItem.Id);

        if (currentIndex < 0)
        {
            // Current test not found in siblings list
            Logger.LogWarning("Current test {ItemId} not found in sibling list", _testItem.Id);
            _previousTestId = null;
            _nextTestId = null;
            return;
        }

        // Previous test (earlier in the list = newer test)
        _previousTestId = currentIndex > 0
            ? sortedTests[currentIndex - 1].Id
            : null;

        // Next test (later in the list = older test)
        _nextTestId = currentIndex < sortedTests.Count - 1
            ? sortedTests[currentIndex + 1].Id
            : null;

        Logger.LogInformation("Navigation: current={Current} (DbId={DbId}, {Index}/{Total}), previous={PrevDbId}, next={NextDbId}",
            _testItem.Name, _testItem.DbId ?? 0, currentIndex + 1, sortedTests.Count,
            sortedTests.ElementAtOrDefault(currentIndex - 1)?.DbId ?? 0,
            sortedTests.ElementAtOrDefault(currentIndex + 1)?.DbId ?? 0);
    }

    private void NavigateToPreviousTest()
    {
        if (_previousTestId.HasValue && _siblingTests != null)
        {
            var previousTest = _siblingTests.FirstOrDefault(t => t.Id == _previousTestId.Value);
            if (previousTest != null)
            {
                NavigateToTest(previousTest);
            }
        }
    }

    private void NavigateToNextTest()
    {
        if (_nextTestId.HasValue && _siblingTests != null)
        {
            var nextTest = _siblingTests.FirstOrDefault(t => t.Id == _nextTestId.Value);
            if (nextTest != null)
            {
                NavigateToTest(nextTest);
            }
        }
    }

    private void NavigateToTest(TestItemDto test)
    {
        // Preserve URL format: use hierarchical URL if we came via hierarchical route
        if (LaunchId.HasValue && test.DbId.HasValue && _launch?.DbId.HasValue == true && _suite?.DbId.HasValue == true)
        {
            // Use hierarchical URL format: /launches/{launchDbId}/suites/{suiteDbId}/tests/{testDbId}/test-item
            Navigation.NavigateTo($"/{ProjectKey}/launches/{_launch.DbId}/suites/{_suite.DbId}/tests/{test.DbId}/test-item");
        }
        else
        {
            // Fallback to GUID URL format
            Navigation.NavigateTo($"/{ProjectKey}/test-items/{test.Id}");
        }
    }

    private async Task RefreshAsync()
    {
        await LoadTestItem();
        StateHasChanged();
    }

    private void NavigateBack()
    {
        if (_suite != null && _launch != null)
        {
            // Navigate to parent suite/test runs page (prefer db_id URLs)
            var suiteUrl = _launch.DbId.HasValue && _suite.DbId.HasValue
                ? $"/{ProjectKey}/launches/{_launch.DbId}/suites/{_suite.DbId}/tests"  // Numeric URL (preferred)
                : $"/{ProjectKey}/launches/{_launch.Id}/suites/{_suite.Id}/runs";       // GUID URL (fallback)
            Navigation.NavigateTo(suiteUrl);
        }
        else if (_launch != null)
        {
            // Navigate to launch suites page (prefer db_id URL)
            var launchUrl = _launch.DbId.HasValue
                ? $"/{ProjectKey}/launches/{_launch.DbId}/suites"  // Numeric URL (preferred)
                : $"/{ProjectKey}/launches/{_launch.Id}/suites";    // GUID URL (fallback)
            Navigation.NavigateTo(launchUrl);
        }
        else
        {
            // Fallback to launches list
            Navigation.NavigateTo($"/{ProjectKey}/launches");
        }
    }

    private LaunchActionPanel.LaunchInfo GetLaunchInfo()
    {
        if (_testItem == null)
        {
            return new LaunchActionPanel.LaunchInfo
            {
                Name = "Loading...",
                LaunchNumber = null,
                StartTime = DateTimeOffset.UtcNow
            };
        }

        // Calculate duration if not provided
        double? duration = null;
        if (_testItem.FinishTime.HasValue)
        {
            duration = (_testItem.FinishTime.Value - _testItem.StartTime).TotalSeconds;
        }
        else if (_testItem.DurationMs.HasValue)
        {
            duration = _testItem.DurationMs.Value / 1000.0;
        }

        return new LaunchActionPanel.LaunchInfo
        {
            Name = _testItem.Name,
            LaunchNumber = _launch?.LaunchNumber, // Null if launch unavailable
            Description = _testItem.Description,
            Attributes = _testItem.Attributes ?? Array.Empty<string>(),
            OwnerUsername = _launch?.OwnerUsername,
            StartTime = _testItem.StartTime,
            FinishTime = _testItem.FinishTime,
            DurationSeconds = duration
        };
    }

    private List<LaunchActionPanel.BreadcrumbItem> GetBreadcrumbs()
    {
        Logger.LogInformation("Building breadcrumbs: _launch={Launch}, _suite={Suite}, _testItem={TestItem}",
            _launch?.Name ?? "null", _suite?.Name ?? "null", _testItem?.Name ?? "null");

        var breadcrumbs = new List<LaunchActionPanel.BreadcrumbItem>
        {
            new() { Text = "All", Url = $"/{ProjectKey}/launches" }
        };

        // Add Launch breadcrumb (prefer numeric db_id URLs)
        if (_launch != null)
        {
            // Use db_id URL if launch has db_id value (preferred)
            var launchUrl = _launch.DbId.HasValue
                ? $"/{ProjectKey}/launches/{_launch.DbId}/suites"  // Numeric URL (preferred)
                : $"/{ProjectKey}/launches/{_launch.Id}/suites";    // GUID URL (fallback)

            breadcrumbs.Add(new LaunchActionPanel.BreadcrumbItem
            {
                Text = $"{_launch.Name} #{_launch.LaunchNumber}",
                Url = launchUrl
            });
        }
        else if (_testItem?.LaunchId != null)
        {
            // Launch data unavailable - show placeholder
            breadcrumbs.Add(new LaunchActionPanel.BreadcrumbItem
            {
                Text = "Unknown Launch",
                Url = null // No link since we don't have launch data
            });
        }

        // Add Suite/Parent Item breadcrumb (prefer numeric db_id URLs)
        if (_suite != null && _launch != null)
        {
            // Use db_id URLs if both launch and suite have db_id values (preferred)
            var suiteUrl = _launch.DbId.HasValue && _suite.DbId.HasValue
                ? $"/{ProjectKey}/launches/{_launch.DbId}/suites/{_suite.DbId}/tests"  // Numeric URL (preferred)
                : $"/{ProjectKey}/launches/{_launch.Id}/suites/{_suite.Id}/runs";       // GUID URL (fallback)

            breadcrumbs.Add(new LaunchActionPanel.BreadcrumbItem
            {
                Text = _suite.Name,
                ItemType = _suite.ItemType, // Display icon based on parent type
                Url = suiteUrl
            });
        }
        else if (_suite != null)
        {
            // Parent item available but no launch
            breadcrumbs.Add(new LaunchActionPanel.BreadcrumbItem
            {
                Text = _suite.Name,
                ItemType = _suite.ItemType,
                Url = null // No URL without launch context
            });
        }

        // Add current test item (no link - current page)
        if (_testItem != null)
        {
            breadcrumbs.Add(new LaunchActionPanel.BreadcrumbItem
            {
                Text = _testItem.Name,
                ItemType = _testItem.ItemType, // Display icon for test item type
                Url = null // Current page - no link
            });
        }

        return breadcrumbs;
    }

    private string GetItemDuration()
    {
        if (_testItem == null)
            return "N/A";

        double? durationMs = null;

        // Try to get duration from various sources
        if (_testItem.FinishTime.HasValue)
        {
            durationMs = (_testItem.FinishTime.Value - _testItem.StartTime).TotalMilliseconds;
        }
        else if (_testItem.DurationMs.HasValue)
        {
            durationMs = _testItem.DurationMs.Value;
        }

        if (!durationMs.HasValue)
            return "N/A";

        // Format duration
        if (durationMs.Value < 1000)
            return $"{durationMs.Value:F0}ms";
        if (durationMs.Value < 60000)
            return $"{durationMs.Value / 1000:F1}s";
        return $"{durationMs.Value / 60000:F1}m";
    }

    private static string RenderMarkdown(string text)
    {
        if (string.IsNullOrEmpty(text))
            return string.Empty;

        var html = text;

        // Escape HTML entities first
        html = WebUtility.HtmlEncode(html);

        // Bold: **text** or __text__
        html = Regex.Replace(html, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        html = Regex.Replace(html, @"__(.+?)__", "<strong>$1</strong>");

        // Italic: *text* or _text_
        html = Regex.Replace(html, @"\*(.+?)\*", "<em>$1</em>");
        html = Regex.Replace(html, @"(?<!\w)_(.+?)_(?!\w)", "<em>$1</em>");

        // Strikethrough: ~~text~~
        html = Regex.Replace(html, @"~~(.+?)~~", "<del>$1</del>");

        // Inline code: `code`
        html = Regex.Replace(html, @"`(.+?)`", "<code>$1</code>");

        // Links: [text](url)
        html = Regex.Replace(html, @"\[([^\]]+)\]\(([^\)]+)\)", "<a href=\"$2\" target=\"_blank\" rel=\"noopener noreferrer\">$1</a>");

        // Line breaks
        html = html.Replace("\r\n", "<br />").Replace("\n", "<br />");

        return html;
    }

