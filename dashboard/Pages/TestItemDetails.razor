    private void ToggleExpand(Guid stepId)
    {
        if (_expandedSteps.Contains(stepId))
        {
            // Collapsing: remove this step AND all its descendants
            _expandedSteps.Remove(stepId);
            CollapseAllChildren(stepId);
        }
        else
        {
            // Expanding: add this step
            _expandedSteps.Add(stepId);
        }
    }

    private void CollapseAllChildren(Guid parentId)
    {
        // Find all direct children of this parent
        var children = _logEntries
            .Where(e => e.IsStepHeader && e.ParentId == parentId)
            .ToList();

        foreach (var child in children)
        {
            // Remove child from expanded set
            _expandedSteps.Remove(child.Id);

            // Recursively collapse the child's children
            CollapseAllChildren(child.Id);
        }
    }

