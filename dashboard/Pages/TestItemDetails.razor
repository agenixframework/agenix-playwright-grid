    private async Task LoadLogEntriesAsync()
    {
        if (_testItem == null) return;

        try
        {
            var http = HttpFactory.CreateClient(HttpClientNames.Hub);
            var response = await http.GetAsync($"/api/test-items/{_testItem.Id}/logs/hierarchical?take=1000&maxDepth=5&useCache=true");

            if (response.IsSuccessStatusCode)
            {
                var hierarchicalResponse = await response.Content.ReadFromJsonAsync<HierarchicalLogsResponse>();
                var hierarchicalLogs = hierarchicalResponse?.Logs ?? new List<HierarchicalLogEntryDto>();
                _logEntries = hierarchicalLogs.Select(hl => new LogEntryDto
                {
                    Id = hl.Id,
                    ParentId = hl.ParentId,
                    IsStepHeader = hl.IsStepHeader,
                    IsNested = hl.IsNested,
                    NestLevel = hl.NestLevel,
                    Timestamp = hl.Timestamp,
                    Level = hl.Level,
                    Source = hl.Source,
                    Message = hl.Message,
                    Name = hl.Name,
                    Description = hl.Description,
                    Status = hl.Status,
                    DurationMs = hl.DurationMs,
                    AttachmentCount = hl.AttachmentCount,
                    HasAttachment = hl.HasAttachment,
                    AttachmentType = hl.AttachmentType,
                    AttachmentName = hl.AttachmentName,
                    ArtifactId = hl.ArtifactId
                }).ToList();

                // Sort log entries in hierarchical order: parent followed immediately by children
                _logEntries = SortLogEntriesHierarchically(_logEntries);

                var stepHeaders = _logEntries.Count(e => e.IsStepHeader);
                var logMessages = _logEntries.Count(e => !e.IsStepHeader);
                Logger.LogInformation("Loaded {Count} hierarchical log entries for test item {ItemId}: {StepHeaders} step headers, {LogMessages} log messages",
                    _logEntries.Count, _testItem.Id, stepHeaders, logMessages);

                // Debug: Log step header names
                foreach (var step in _logEntries.Where(e => e.IsStepHeader))
                {
                    Logger.LogDebug("Step header found: {Name} (ID: {Id}, IsNested: {IsNested}, NestLevel: {NestLevel}, ParentId: {ParentId})",
                        step.Name, step.Id, step.IsNested, step.NestLevel, step.ParentId);
                }

                // Debug: Log ERROR/FATAL entries specifically
                var errorLogs = _logEntries.Where(e => !e.IsStepHeader && (e.Level.ToLower() == "error" || e.Level.ToLower() == "fatal")).ToList();
                Logger.LogInformation("Found {ErrorCount} ERROR/FATAL log entries", errorLogs.Count);
                foreach (var errorLog in errorLogs)
                {
                    Logger.LogInformation("ERROR/FATAL Log: Level={Level}, ParentId={ParentId}, Message={MessagePreview}",
                        errorLog.Level, errorLog.ParentId, errorLog.Message.Length > 100 ? errorLog.Message.Substring(0, 100) + "..." : errorLog.Message);
                }

                // Extract stack trace entries from ERROR/FATAL logs
                ExtractStackTraceFromLogs();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load hierarchical log entries for test item {ItemId}", _testItem?.Id);
        }
    }

    private void ExtractStackTraceFromLogs()
    {
        _stackTraceEntries.Clear();

        // Get all ERROR and FATAL level logs (excluding step headers)
        var errorLogs = _logEntries
            .Where(e => !e.IsStepHeader && (e.Level.ToLower() == "error" || e.Level.ToLower() == "fatal"))
            .OrderBy(e => e.Timestamp)
            .ToList();

        foreach (var log in errorLogs)
        {
            // Split message into lines for stack trace parsing
            var lines = log.Message.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
                .Select(l => l.Trim())
                .Where(l => !string.IsNullOrWhiteSpace(l))
                .ToList();

            if (lines.Count == 0) continue;

            // First line is the error message (may contain exception class)
            var firstLine = lines[0];
            var exceptionClass = "";
            var errorMessageLines = new List<string>();

            // Try to extract exception class if message starts with a class name pattern
            // e.g., "System.InvalidOperationException: message" or "c.e.t.r.FailureLoggingListener - message"
            var colonIndex = firstLine.IndexOf(':');
            var dashIndex = firstLine.IndexOf(" - ");

            if (colonIndex > 0 && colonIndex < 100) // Exception format: "Class: message"
            {
                var potentialClass = firstLine.Substring(0, colonIndex).Trim();
                if (potentialClass.Contains('.') || potentialClass.Contains('$'))
                {
                    exceptionClass = potentialClass;
                    errorMessageLines.Add(firstLine.Substring(colonIndex + 1).Trim());
                }
                else
                {
                    errorMessageLines.Add(firstLine);
                }
            }
            else if (dashIndex > 0 && dashIndex < 100) // Logger format: "Class - message"
            {
                var potentialClass = firstLine.Substring(0, dashIndex).Trim();
                if (potentialClass.Contains('.'))
                {
                    exceptionClass = potentialClass;
                    errorMessageLines.Add(firstLine.Substring(dashIndex + 2).Trim());
                }
                else
                {
                    errorMessageLines.Add(firstLine);
                }
            }
            else
            {
                errorMessageLines.Add(firstLine);
            }

            // Separate exception messages from stack trace lines
            var exceptionMessages = new List<string>();
            var stackTraceLines = new List<string>();

            foreach (var line in lines.Skip(1))
            {
                // Stack trace line patterns: starts with "at " or contains file paths
                if (line.StartsWith("at ") || line.Contains(".cs:") || line.Contains(".java:") || line.Contains(".js:") || line.Contains(".ts:"))
                {
                    stackTraceLines.Add(line);
                }
                // Exception message patterns: "Caused by:", exception class names, or plain error messages
                else if (line.StartsWith("Caused by:") ||
                         line.Contains("Exception") ||
                         line.Contains("Error") ||
                         (line.Contains('.') && line.Contains(':')))
                {
                    exceptionMessages.Add(line);
                }
                // If it doesn't match above patterns but we haven't found stack traces yet, treat as exception message
                else if (stackTraceLines.Count == 0)
                {
                    exceptionMessages.Add(line);
                }
            }

            // Try to extract HTTP details from error message
            string? httpMethod = null;
            string? url = null;
            int? statusCode = null;
            string? statusMessage = null;

            // Combine errorMessageLines into single string for pattern matching
            var fullErrorMessage = string.Join(" ", errorMessageLines);

            // Look for HTTP method keywords
            var httpMethods = new[] { "GET", "POST", "PUT", "DELETE", "PATCH", "HEAD", "OPTIONS" };
            foreach (var method in httpMethods)
            {
                if (fullErrorMessage.Contains(method))
                {
                    httpMethod = method;
                    break;
                }
            }

            // Look for status codes (3-digit numbers in 200-599 range) and extract status message
            var statusCodeMatch = Regex.Match(fullErrorMessage, @"\b([2-5]\d{2})\b\s*(.*)");
            if (statusCodeMatch.Success)
            {
                statusCode = int.Parse(statusCodeMatch.Groups[1].Value);

                // Extract status message (text after status code)
                var remainingText = statusCodeMatch.Groups[2].Value.Trim();
                if (!string.IsNullOrEmpty(remainingText))
                {
                    // Common status messages
                    var statusMessages = new Dictionary<int, string>
                    {
                        { 200, "OK" }, { 201, "Created" }, { 204, "No Content" },
                        { 400, "Bad Request" }, { 401, "Unauthorized" }, { 403, "Forbidden" }, { 404, "Not Found" },
                        { 409, "Conflict" }, { 422, "Unprocessable Entity" },
                        { 500, "Internal Server Error" }, { 502, "Bad Gateway" }, { 503, "Service Unavailable" }
                    };

                    // Try to find known status message in remaining text
                    foreach (var kvp in statusMessages)
                    {
                        if (remainingText.Contains(kvp.Value, StringComparison.OrdinalIgnoreCase))
                        {
                            statusMessage = kvp.Value;
                            break;
                        }
                    }

                    // If no known status found, use first word(s) as status message
                    if (string.IsNullOrEmpty(statusMessage))
                    {
                        var words = remainingText.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        if (words.Length > 0)
                        {
                            statusMessage = string.Join(" ", words.Take(3)); // Take up to 3 words
                        }
                    }
                }
            }

            // Look for URLs (simplified)
            var urlMatch = Regex.Match(fullErrorMessage, @"https?://[^\s]+");
            if (urlMatch.Success)
            {
                url = urlMatch.Value;
            }

            // Determine context (thread name) from source or extract from message
            var context = log.Source;
            if (string.IsNullOrEmpty(context))
            {
                // Try to extract thread name from message (e.g., [thread-name])
                var threadMatch = Regex.Match(fullErrorMessage, @"\[([^\]]+)\]");
                if (threadMatch.Success)
                {
                    context = threadMatch.Groups[1].Value;
                }
            }

            _stackTraceEntries.Add(new StackTraceEntryDto
            {
                Id = Guid.NewGuid(),
                LogEntryId = log.Id,
                Timestamp = log.Timestamp,
                Context = context,
                Level = log.Level.ToUpper(),
                ExceptionClass = string.IsNullOrEmpty(exceptionClass) ? "Error" : exceptionClass,
                Message = string.Join("\n", errorMessageLines), // Store as multi-line string
                HttpMethod = httpMethod,
                Url = url,
                StatusCode = statusCode,
                StatusMessage = statusMessage,
                ExceptionMessages = exceptionMessages,
                StackTraceLines = stackTraceLines
            });
        }

        Logger.LogInformation("Extracted {Count} stack trace entries from error logs", _stackTraceEntries.Count);
    }

    private IEnumerable<LogEntryDto> FilteredLogEntries
    {
        get
        {
            var query = _logEntries.AsEnumerable();
            var beforeFilter = query.Count();

            Logger.LogDebug("FilteredLogEntries: Starting with {Count} entries (LogLevelFilter='{LogLevelFilter}', LogFilterText='{LogFilterText}', StatusFilter='{StatusFilter}')",
                beforeFilter, _logLevelFilter ?? "(none)", _logFilterText ?? "(none)", _statusFilter ?? "(none)");

            // Text filter: Search everywhere by contains
            // For step headers: search in Name and Description
            // For log entries: search in Message and Source
            if (!string.IsNullOrWhiteSpace(_logFilterText))
            {
                var filter = _logFilterText.ToLower();
                query = query.Where(e =>
                {
                    if (e.IsStepHeader)
                    {
                        // Search in step name and description
                        return e.Name.ToLower().Contains(filter) ||
                               (!string.IsNullOrEmpty(e.Description) && e.Description.ToLower().Contains(filter));
                    }

                    // Search in log message and source
                    return e.Message.ToLower().Contains(filter) ||
                           e.Source.ToLower().Contains(filter);
                });
                Logger.LogDebug("FilteredLogEntries: After text filter: {Count} entries", query.Count());
            }

            // Log level filter: Only applies to log entries, not step headers
            if (!string.IsNullOrWhiteSpace(_logLevelFilter))
            {
                query = _logLevelFilter.ToLower() switch
                {
                    "fatal" => query.Where(e => e.IsStepHeader || e.Level.ToLower() == "fatal"),
                    "error" => query.Where(e => e.IsStepHeader || e.Level.ToLower() == "error"),
                    "warn" => query.Where(e => e.IsStepHeader || e.Level.ToLower() is "warn" or "error" or "fatal"),
                    "info" => query.Where(e => e.IsStepHeader || e.Level.ToLower() is not "debug" and not "trace"),
                    _ => query
                };
                Logger.LogDebug("FilteredLogEntries: After level filter: {Count} entries", query.Count());
            }

            // Status filter: Applies to step headers (they have Status property)
            if (!string.IsNullOrWhiteSpace(_statusFilter))
            {
                query = query.Where(e => e.Status.ToLower() == _statusFilter.ToLower());
                Logger.LogDebug("FilteredLogEntries: After status filter: {Count} entries", query.Count());
            }

            // Attachment filter: Step headers may have AttachmentCount > 0
            if (_showOnlyWithAttachments)
            {
                query = query.Where(e => e.HasAttachment || (e.IsStepHeader && e.AttachmentCount > 0));
                Logger.LogDebug("FilteredLogEntries: After attachment filter: {Count} entries", query.Count());
            }

            // Backend already returns data in correct hierarchical order
            // (step headers followed by their logs, then nested steps, etc.)
            // Don't re-sort - just apply pagination
            var result = query
                .Skip((_currentPage - 1) * _itemsPerPage)
                .Take(_itemsPerPage)
                .ToList();

            Logger.LogDebug("FilteredLogEntries: Final result after pagination (page {Page}, size {PageSize}): {Count} entries", _currentPage, _itemsPerPage, result.Count);

            // Debug: Log ERROR/FATAL entries in final result
            var errorLogsInResult = result.Where(e => !e.IsStepHeader && (e.Level.ToLower() == "error" || e.Level.ToLower() == "fatal")).ToList();
            if (errorLogsInResult.Any())
            {
                Logger.LogInformation("FilteredLogEntries: Final result contains {ErrorCount} ERROR/FATAL logs", errorLogsInResult.Count);
            }

            return result;
        }
    }

