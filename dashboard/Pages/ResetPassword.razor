@page "/reset-password/{Token}"
@using System.ComponentModel.DataAnnotations
@using System.Net
@attribute [AllowAnonymous]
@inject NavigationManager Nav
@inject IHttpClientFactory Http
@inject IJSRuntime JS

<div class="reset-password-page d-flex align-items-center justify-content-center">
    <div class="reset-password-container">
        <div class="reset-password-card card shadow-sm">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <div class="reset-icon-container mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor"
                             viewBox="0 0 16 16" style="color: #667eea;">
                            <path
                                d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                        </svg>
                    </div>
                    <h1 class="reset-title mb-2">Reset Your Password</h1>
                    <p class="reset-subtitle text-muted">Enter your new password below</p>
                </div>

                @if (tokenValidated && !resetSuccess)
                {
                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="alert alert-danger" role="alert">@error</div>
                    }

                    <EditForm Model="model" OnValidSubmit="OnSubmit" class="reset-form">
                        <DataAnnotationsValidator/>
                        <ValidationSummary class="validation-summary"/>

                        <div class="form-group mb-4">
                            <label for="password" class="form-label">New Password</label>
                            <div class="input-container">
                                <span class="input-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                                         viewBox="0 0 16 16">
                                        <path
                                            d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                                    </svg>
                                </span>
                                <div style="position: relative; flex: 1; display: flex;">
                                    <InputText id="password" type="@(_showPassword ? "text" : "password")"
                                               class="form-control form-control-enhanced" @bind-Value="model.Password"
                                               disabled="@resetting" placeholder="Enter new password"
                                               style="padding-right: 45px;"/>
                                    <button type="button" class="btn password-toggle-enhanced"
                                            aria-label="Toggle password visibility" @onclick="TogglePassword">
                                        @if (_showPassword)
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                 fill="currentColor" viewBox="0 0 16 16">
                                                <path
                                                    d="M13.359 11.238l1.147 1.147a.5.5 0 0 1-.708.707l-1.2-1.2A9.681 9.681 0 0 1 8 13.5c-3.592 0-6.54-2.23-7.938-5.5a10.92 10.92 0 0 1 3.122-4.104L.646 1.46a.5.5 0 1 1 .708-.707l13.2 13.2a.5.5 0 0 1-.708.707l-1.487-1.487z"/>
                                                <path
                                                    d="M11.297 9.176l-1.124-1.124A3 3 0 0 1 7.948 6.53L6.824 5.406a3 3 0 0 0 4.473 3.77z"/>
                                                <path
                                                    d="M3.35 4.36A9.67 9.67 0 0 1 8 2.5c3.592 0 6.54 2.23 7.938 5.5a10.93 10.93 0 0 1-2.382 3.356l-1.062-1.062A9.066 9.066 0 0 0 15.5 8c-1.273-2.7-3.889-4.5-7.5-4.5a8.17 8.17 0 0 0-3.768.921L3.35 4.36z"/>
                                            </svg>
                                        }
                                        else
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18"
                                                 fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8z"/>
                                                <path d="M8 5a3 3 0 1 1 0 6 3 3 0 0 1 0-6z"/>
                                            </svg>
                                        }
                                    </button>
                                </div>
                            </div>
                            <ValidationMessage For="() => model.Password"/>
                        </div>

                        <div class="form-group mb-4">
                            <label for="confirmPassword" class="form-label">Confirm Password</label>
                            <div class="input-container">
                                <span class="input-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                                         viewBox="0 0 16 16">
                                        <path
                                            d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                                    </svg>
                                </span>
                                <InputText id="confirmPassword" type="@(_showPassword ? "text" : "password")"
                                           class="form-control form-control-enhanced"
                                           @bind-Value="model.ConfirmPassword" disabled="@resetting"
                                           placeholder="Confirm new password"/>
                            </div>
                            <ValidationMessage For="() => model.ConfirmPassword"/>
                        </div>

                        <div class="password-requirements mb-4">
                            <p class="small text-muted mb-2"><strong>Password must contain:</strong></p>
                            <ul class="requirements-list">
                                <li class="@(model.Password?.Length >= 8 ? "valid" : "")">At least 8 characters</li>
                                <li class="@(model.Password?.Any(char.IsLetter) == true ? "valid" : "")">At least one
                                    letter
                                </li>
                                <li class="@(model.Password?.Any(char.IsDigit) == true ? "valid" : "")">At least one
                                    number
                                </li>
                            </ul>
                        </div>

                        <button type="submit"
                                class="btn btn-primary btn-enhanced w-100 d-flex align-items-center justify-content-center"
                                disabled="@resetting">
                            @if (resetting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                <span>Resetting Password…</span>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                                     class="me-2" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd"
                                          d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                </svg>
                                <span>Reset Password</span>
                            }
                        </button>
                    </EditForm>
                }
                else if (resetSuccess)
                {
                    <div class="success-state text-center py-4">
                        <div class="success-icon mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor"
                                 viewBox="0 0 16 16" style="color: #10b981;">
                                <path
                                    d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                            </svg>
                        </div>
                        <h3 class="mb-3">Password Reset Successfully!</h3>
                        <p class="text-muted mb-4">Your password has been changed. You can now log in with your new
                            password.</p>
                        <p class="small text-muted mb-3">Redirecting to login page in @countdown seconds...</p>
                        <button type="button" class="btn btn-primary" @onclick="NavigateToLogin">Go to Login</button>
                    </div>
                }
                else if (validating)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary mb-3" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="text-muted">Validating reset link...</p>
                    </div>
                }
                else
                {
                    <div class="error-state text-center py-4">
                        <div class="error-icon mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor"
                                 viewBox="0 0 16 16" style="color: #ef4444;">
                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                <path
                                    d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
                            </svg>
                        </div>
                        <h3 class="mb-3">Invalid or Expired Link</h3>
                        <p class="text-muted mb-4">@error</p>
                        <button type="button" class="btn btn-primary" @onclick="NavigateToLogin">Back to Login</button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Token { get; set; } = string.Empty;

    private ResetPasswordModel model = new();
    private bool validating = true;
    private bool tokenValidated;
    private bool resetting;
    private bool resetSuccess;
    private string? error;
    private bool _showPassword;
    private int countdown = 5;
    private Timer? redirectTimer;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            error = "No reset token provided";
            validating = false;
            return;
        }

        try
        {
            var client = Http.CreateClient(HttpClientNames.Hub);
            var response = await client.GetAsync($"/admin/auth/reset-password/{Token}");

            if (response.IsSuccessStatusCode)
            {
                tokenValidated = true;
            }
            else if (response.StatusCode == HttpStatusCode.NotFound)
            {
                error = "This password reset link is invalid or has already been used.";
            }
            else if (response.StatusCode == HttpStatusCode.BadRequest)
            {
                error = "This password reset link has expired. Please request a new one.";
            }
            else
            {
                error = "Unable to validate reset link. Please try again.";
            }
        }
        catch (Exception ex)
        {
            error = $"An error occurred: {ex.Message}";
        }
        finally
        {
            validating = false;
        }
    }

    private void TogglePassword()
    {
        _showPassword = !_showPassword;
    }

    private async Task OnSubmit()
    {
        if (model.Password != model.ConfirmPassword)
        {
            error = "Passwords do not match";
            return;
        }

        resetting = true;
        error = null;
        StateHasChanged();

        try
        {
            var client = Http.CreateClient(HttpClientNames.Hub);
            var request = new ResetPasswordRequest
            {
                Password = model.Password ?? string.Empty,
                ConfirmPassword = model.ConfirmPassword ?? string.Empty
            };

            var response = await client.PostAsJsonAsync($"/admin/auth/reset-password/{Token}", request);

            if (response.IsSuccessStatusCode)
            {
                resetSuccess = true;
                StartCountdown();
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                if (errorText.Contains("expired", StringComparison.OrdinalIgnoreCase))
                {
                    error = "This reset link has expired. Please request a new one.";
                }
                else if (errorText.Contains("match", StringComparison.OrdinalIgnoreCase))
                {
                    error = "Passwords do not match";
                }
                else if (errorText.Contains("8 characters", StringComparison.OrdinalIgnoreCase))
                {
                    error = "Password must be at least 8 characters long";
                }
                else
                {
                    error = "Failed to reset password. Please try again.";
                }
            }
        }
        catch (Exception ex)
        {
            error = $"An error occurred: {ex.Message}";
        }
        finally
        {
            resetting = false;
            StateHasChanged();
        }
    }

    private void StartCountdown()
    {
        redirectTimer = new Timer(async _ =>
        {
            countdown--;
            if (countdown <= 0)
            {
                redirectTimer?.Dispose();
                await InvokeAsync(() => NavigateToLogin());
            }
            else
            {
                await InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    private void NavigateToLogin()
    {
        redirectTimer?.Dispose();
        Nav.NavigateTo("/login", true);
    }

    public void Dispose()
    {
        redirectTimer?.Dispose();
    }

    public class ResetPasswordModel
    {
        [Required(ErrorMessage = "Password is required")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters")]
        public string? Password { get; set; }

        [Required(ErrorMessage = "Confirm password is required")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match")]
        public string? ConfirmPassword { get; set; }
    }

}
