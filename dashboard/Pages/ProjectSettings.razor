@page "/{projectKey}/settings/"
@attribute [Authorize]
@inject NavigationManager Nav
@inject IHttpClientFactory HttpFactory
@inject ILogger<ProjectSettings> Logger
@inject IJSRuntime JS

<link href="css/project-settings.css" rel="stylesheet"/>

<!-- Page Header -->
<div class="page-header">
    <div class="container-fluid" style="padding-left: 24px;">
        <div class="header-content">
            <div class="header-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" aria-hidden="true">
                    <path
                        d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z"/>
                    <path
                        d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52l-.094-.319z"/>
                </svg>
            </div>
            <div>
                <h3>Project Settings</h3>
                <div class="subtitle">Configure project preferences and options</div>
            </div>
        </div>
    </div>
</div>

<!-- Settings Layout (Sidebar + Content) -->
<div class="settings-layout">
    <!-- Navigation Sidebar -->
    <aside class="settings-sidebar">
        <h5 class="settings-sidebar-title">NAVIGATION</h5>
        <nav>
            <ul class="settings-nav">
                <li>
                    <a href="/@ProjectKey/settings/" class="settings-nav-item active">
                        <i class="bi bi-gear"></i>
                        <span>General</span>
                    </a>
                </li>
                <li>
                    <span class="settings-nav-item disabled">
                        <i class="bi bi-plug"></i>
                        <span>Integrations</span>
                        <span class="badge bg-secondary">Soon</span>
                    </span>
                </li>
                <li>
                    <span class="settings-nav-item disabled">
                        <i class="bi bi-bell"></i>
                        <span>Notifications</span>
                        <span class="badge bg-secondary">Soon</span>
                    </span>
                </li>
            </ul>
        </nav>
    </aside>

    <!-- Main Content Area -->
    <main class="settings-main">
        <div class="settings-content">
            <!-- Info Banner -->
            <div class="info-banner">
                <i class="bi bi-info-circle-fill"></i>
                <div class="info-banner-content">
                    <strong>Configuration Notice</strong>
                    <p>Changes to these settings will affect data retention and cleanup schedules. Make sure you
                        understand the implications before saving.</p>
                </div>
            </div>

            <!-- Project Information Card -->
            <div class="settings-card">
                <div class="settings-card-header">
                    <div class="settings-card-icon blue">
                        <i class="bi bi-folder2-open"></i>
                    </div>
                    <div class="settings-card-title">
                        <h3>Project Information</h3>
                        <p class="description">Basic project details and identification</p>
                    </div>
                </div>
                <div class="setting-item">
                    <label class="setting-label">
                        Project Name
                        <i class="bi bi-info-circle info-icon"
                           title="The project key is immutable and cannot be changed"></i>
                    </label>
                    <div class="setting-help">This is your project's unique identifier</div>
                    <input type="text" class="readonly-input" value="@ProjectKey" readonly disabled/>
                </div>
            </div>

            <!-- Launch Management Card -->
            <div class="settings-card">
                <div class="settings-card-header">
                    <div class="settings-card-icon yellow">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div class="settings-card-title">
                        <h3>Launch Management</h3>
                        <p class="description">Control launch lifecycle and inactivity policies</p>
                    </div>
                </div>
                <div class="setting-item">
                    <label class="setting-label" for="launchInactivityTimeout">
                        Launch Inactivity Timeout
                        <i class="bi bi-info-circle info-icon"
                           title="Inactive launches will be automatically interrupted after this period"></i>
                    </label>
                    <div class="setting-help">
                        Schedule time for background jobs to interrupt launches with no activity.
                        <strong>Current default:</strong> 1 hour
                    </div>
                    <div class="custom-select-wrapper">
                        <select id="launchInactivityTimeout" class="custom-select" @bind="LaunchInactivityTimeout"
                                @bind:after="OnSettingChanged">
                            <option value="1h">1 hour</option>
                            <option value="3h">3 hours</option>
                            <option value="6h">6 hours</option>
                            <option value="12h">12 hours</option>
                            <option value="1d">1 day</option>
                            <option value="3d">3 days</option>
                            <option value="7d">7 days</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Data Retention Card -->
            <div class="settings-card">
                <div class="settings-card-header">
                    <div class="settings-card-icon green">
                        <i class="bi bi-archive"></i>
                    </div>
                    <div class="settings-card-title">
                        <h3>Data Retention Controls</h3>
                        <p class="description">Independent retention periods for launches, logs, and attachments</p>
                    </div>
                </div>

                <!-- Retention Rules Info -->
                <div class="alert alert-info d-flex align-items-start gap-3 mb-4" role="alert">
                    <i class="bi bi-info-circle-fill" style="font-size: 20px; flex-shrink: 0;"></i>
                    <div>
                        <strong>Retention Hierarchy:</strong> Attachments ≤ Logs ≤ Launches
                        <p class="mb-0 mt-1">Lower-level data cannot be retained longer than higher-level data. Invalid
                            selections will be auto-cleared.</p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(ValidationMessage))
                {
                    <div class="alert alert-warning d-flex align-items-start gap-3 mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill" style="font-size: 20px; flex-shrink: 0;"></i>
                        <div>
                            <strong>Validation:</strong> @ValidationMessage
                        </div>
                    </div>
                }

                <!-- Reset to Recommended Button -->
                <div class="mb-4">
                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="ResetToRecommended">
                        <i class="bi bi-arrow-counterclockwise"></i>
                        Reset to Recommended Defaults
                    </button>
                    <small class="text-muted d-block mt-2">
                        <i class="bi bi-lightbulb"></i> Recommended: Launches 30d, Logs 7d, Attachments 7d (minimizes
                        storage costs)
                    </small>
                </div>

                <!-- Keep Launches -->
                <div class="setting-item mb-4">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <label class="setting-label mb-0" for="keepLaunches">
                            Keep Launches
                            <i class="bi bi-info-circle info-icon"
                               title="Includes all descendants: suites, tests, steps, and logs"></i>
                        </label>
                        <span class="badge @GetStorageBadgeClass(KeepLaunches)"
                              title="@GetStorageBadgeTooltip(KeepLaunches)">@GetStorageBadge(KeepLaunches)</span>
                    </div>
                    <div class="setting-help mb-2">
                        How long to keep completed launches. Launch data including all suites, tests, and steps will be
                        permanently removed after this period.
                    </div>
                    <div class="custom-select-wrapper">
                        <select id="keepLaunches"
                                class="custom-select @(string.IsNullOrEmpty(KeepLaunches) ? "is-invalid" : "")"
                                @bind="KeepLaunches"
                                @bind:after="OnLaunchesChanged"
                                aria-describedby="keepLaunchesHelp">
                            <option value="">-- Select retention period --</option>
                            @foreach (var opt in AllowedDays)
                            {
                                var disabled = IsLaunchesDisabled(opt);
                                <option value="@opt" disabled="@disabled"
                                        aria-disabled="@disabled.ToString().ToLower()">
                                    @FormatDays(opt)
                                </option>
                            }
                        </select>
                    </div>
                    @if (!string.IsNullOrEmpty(KeepLogs))
                    {
                        <small class="form-text text-muted" id="keepLaunchesHelp">
                            Must be ≥ Logs (@FormatDays(KeepLogs))
                        </small>
                    }
                </div>

                <!-- Keep Logs -->
                <div class="setting-item mb-4">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <label class="setting-label mb-0" for="keepLogs">
                            Keep Logs
                            <i class="bi bi-info-circle info-icon"
                               title="Logs are deleted independently of launch structure"></i>
                        </label>
                        <span class="badge @GetStorageBadgeClass(KeepLogs)"
                              title="@GetStorageBadgeTooltip(KeepLogs)">@GetStorageBadge(KeepLogs)</span>
                    </div>
                    <div class="setting-help mb-2">
                        How long to keep log entries. Only log data is deleted; the launch structure remains intact.
                    </div>
                    <div class="custom-select-wrapper">
                        <select id="keepLogs"
                                class="custom-select @(string.IsNullOrEmpty(KeepLogs) ? "is-invalid" : "")"
                                @bind="KeepLogs"
                                @bind:after="OnLogsChanged"
                                aria-describedby="keepLogsHelp">
                            <option value="">-- Select retention period --</option>
                            @foreach (var opt in AllowedDays)
                            {
                                var disabled = IsLogsDisabled(opt);
                                <option value="@opt" disabled="@disabled"
                                        aria-disabled="@disabled.ToString().ToLower()">
                                    @FormatDays(opt)
                                </option>
                            }
                        </select>
                    </div>
                    <small class="form-text text-muted" id="keepLogsHelp">
                        @if (!string.IsNullOrEmpty(KeepLaunches))
                        {
                            <span>Must be ≤ Launches (@FormatDays(KeepLaunches))</span>
                        }
                        @if (!string.IsNullOrEmpty(KeepAttachments))
                        {
                            <span> and ≥ Attachments (@FormatDays(KeepAttachments))</span>
                        }
                    </small>
                    @if (ShowLogsCostWarning())
                    {
                        <div class="alert alert-warning mt-2 mb-0 p-2" role="alert">
                            <i class="bi bi-exclamation-circle"></i>
                            <small>Higher retention may increase processing costs. Recommended: Logs ≤ 30 days.</small>
                        </div>
                    }
                </div>

                <!-- Keep Attachments -->
                <div class="setting-item">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <label class="setting-label mb-0" for="keepAttachments">
                            Keep Attachments
                            <i class="bi bi-info-circle info-icon"
                               title="Includes screenshots, videos, and other uploaded files"></i>
                        </label>
                        <span class="badge @GetStorageBadgeClass(KeepAttachments)"
                              title="@GetStorageBadgeTooltip(KeepAttachments)">@GetStorageBadge(KeepAttachments)</span>
                    </div>
                    <div class="setting-help mb-2">
                        How long to keep file attachments (screenshots, videos, reports). Attachments can consume
                        significant storage.
                    </div>
                    <div class="custom-select-wrapper">
                        <select id="keepAttachments"
                                class="custom-select @(string.IsNullOrEmpty(KeepAttachments) ? "is-invalid" : "")"
                                @bind="KeepAttachments"
                                @bind:after="OnAttachmentsChanged"
                                aria-describedby="keepAttachmentsHelp">
                            <option value="">-- Select retention period --</option>
                            @foreach (var opt in AllowedDays)
                            {
                                var disabled = IsAttachmentsDisabled(opt);
                                <option value="@opt" disabled="@disabled"
                                        aria-disabled="@disabled.ToString().ToLower()">
                                    @FormatDays(opt)
                                </option>
                            }
                        </select>
                    </div>
                    @if (!string.IsNullOrEmpty(KeepLogs))
                    {
                        <small class="form-text text-muted" id="keepAttachmentsHelp">
                            Must be ≤ Logs (@FormatDays(KeepLogs))
                        </small>
                    }
                    @if (ShowAttachmentsCostWarning())
                    {
                        <div class="alert alert-warning mt-2 mb-0 p-2" role="alert">
                            <i class="bi bi-exclamation-circle"></i>
                            <small>Higher retention may increase storage costs. Recommended: Attachments ≤ 7
                                days.</small>
                        </div>
                    }
                </div>
            </div>

            <!-- Danger Zone Card (Future) -->
            <div class="settings-card">
                <div class="settings-card-header">
                    <div class="settings-card-icon red">
                        <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <div class="settings-card-title">
                        <h3>Danger Zone</h3>
                        <p class="description">Destructive actions that require careful consideration</p>
                    </div>
                </div>
                <div class="setting-item">
                    <div class="alert alert-warning d-flex align-items-center gap-3 mb-0" role="alert">
                        <i class="bi bi-info-circle-fill" style="font-size: 24px;"></i>
                        <div>
                            <strong>Future Feature:</strong> Dangerous operations like project deletion or data purge
                            will be available here in a future release.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Fixed Action Bar (appears when settings change) -->
<div class="action-bar @(HasUnsavedChanges ? "" : "hidden")" id="actionBar">
    <div class="action-bar-content">
        <div class="action-bar-info">
            <i class="bi bi-exclamation-circle-fill"></i>
            <span>
                @if (!CanSave)
                {
                    <span>Please complete all required selections</span>
                }
                else
                {
                    <span>You have unsaved changes</span>
                }
            </span>
        </div>
        <div class="action-bar-buttons">
            <button type="button" class="btn-modern btn-secondary" @onclick="ResetSettings" disabled="@IsSaving">
                <i class="bi bi-arrow-counterclockwise"></i>
                Reset
            </button>
            <button type="button" class="btn-modern btn-primary" @onclick="SaveSettings"
                    disabled="@(IsSaving || !CanSave)">
                @if (IsSaving)
                {
                    <span class="spinner"></span>
                    <span>Saving...</span>
                }
                else
                {
                    <i class="bi bi-check-circle"></i>
                    <span>Save Changes</span>
                }
            </button>
        </div>
    </div>
</div>

<!-- Toast Notification -->
@if (ShowToast)
{
    <div class="toast-notification show @ToastType">
        <div class="toast-icon">
            @if (ToastType == "success")
            {
                <i class="bi bi-check-circle-fill"></i>
            }
            else if (ToastType == "error")
            {
                <i class="bi bi-x-circle-fill"></i>
            }
            else
            {
                <i class="bi bi-info-circle-fill"></i>
            }
        </div>
        <div class="toast-content">
            <strong>@ToastTitle</strong>
            <p>@ToastMessage</p>
        </div>
        <button type="button" class="toast-close" @onclick="() => ShowToast = false">
            <i class="bi bi-x"></i>
        </button>
    </div>
}

@code {
    [Parameter] public string ProjectKey { get; set; } = string.Empty;

    private string LaunchInactivityTimeout { get; set; } = "1d";
    private string KeepLaunches { get; set; } = string.Empty;
    private string KeepLogs { get; set; } = string.Empty;
    private string KeepAttachments { get; set; } = string.Empty;

    private string OriginalLaunchInactivityTimeout { get; set; } = "1d";
    private string OriginalKeepLaunches { get; set; } = string.Empty;
    private string OriginalKeepLogs { get; set; } = string.Empty;
    private string OriginalKeepAttachments { get; set; } = string.Empty;

    private bool IsSaving { get; set; }
    private bool ShowToast { get; set; }
    private string ToastTitle { get; set; } = string.Empty;
    private string ToastMessage { get; set; } = string.Empty;
    private string ToastType { get; set; } = "success";
    private string ValidationMessage { get; set; } = string.Empty;

    // Allowed values: 7, 14, 30, 90, 180 days
    private readonly string[] AllowedDays = { "7d", "14d", "30d", "90d", "180d" };

    private bool HasUnsavedChanges =>
        LaunchInactivityTimeout != OriginalLaunchInactivityTimeout ||
        KeepLaunches != OriginalKeepLaunches ||
        KeepLogs != OriginalKeepLogs ||
        KeepAttachments != OriginalKeepAttachments;

    private bool CanSave =>
        !string.IsNullOrEmpty(KeepLaunches) &&
        !string.IsNullOrEmpty(KeepLogs) &&
        !string.IsNullOrEmpty(KeepAttachments);

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        try
        {
            var httpClient = HttpFactory.CreateClient(HttpClientNames.Hub);
            httpClient.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);

            var response = await httpClient.GetAsync($"/api/projects/{ProjectKey}/settings");

            if (response.IsSuccessStatusCode)
            {
                var settings = await response.Content.ReadFromJsonAsync<SettingsResponse>();
                if (settings != null)
                {
                    // Normalize values to ensure "d" suffix (handles both "30" and "30d" from Redis)
                    LaunchInactivityTimeout = NormalizeRetentionValue(settings.LaunchInactivityTimeout ?? "1d");
                    KeepLaunches = NormalizeRetentionValue(settings.KeepLaunches ?? "30d");
                    KeepLogs = NormalizeRetentionValue(settings.KeepLogs ?? "7d");
                    KeepAttachments = NormalizeRetentionValue(settings.KeepAttachments ?? "7d");

                    // Store originals
                    OriginalLaunchInactivityTimeout = LaunchInactivityTimeout;
                    OriginalKeepLaunches = KeepLaunches;
                    OriginalKeepLogs = KeepLogs;
                    OriginalKeepAttachments = KeepAttachments;
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load project settings for {ProjectKey}", ProjectKey);
        }
    }

    // Convert days string to integer for comparison
    // Supports: "30d", "30", "0.003" (fractional days for testing), etc.
    // Also normalizes the input value to always have "d" suffix for consistency
    private int DaysToInt(string days)
    {
        if (string.IsNullOrEmpty(days)) return 0;

        // Remove 'd' suffix if present
        var trimmed = days.TrimEnd('d').Trim();

        // Try parsing as double first (handles fractional days like "0.003")
        if (double.TryParse(trimmed, out var daysDouble))
        {
            // Floor to nearest integer (0.003 → 0, 30.5 → 30)
            return (int)Math.Floor(daysDouble);
        }

        // Fallback: return 0 for invalid formats (prevents 500 errors)
        return 0;
    }

    // Normalize retention value to always have "d" suffix (e.g., "30" → "30d", "30d" → "30d")
    private string NormalizeRetentionValue(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return value;

        var trimmed = value.Trim();

        // Already has suffix
        if (trimmed.EndsWith("d") || trimmed.EndsWith("h"))
            return trimmed;

        // Numeric value without suffix - add "d"
        if (int.TryParse(trimmed, out _) || double.TryParse(trimmed, out _))
            return $"{trimmed}d";

        // Invalid format - return as-is
        return value;
    }

    // Format days for display
    private string FormatDays(string days)
    {
        var d = DaysToInt(days);

        // Check if original value was fractional (for testing mode)
        var trimmed = days.TrimEnd('d').Trim();
        if (double.TryParse(trimmed, out var daysDouble) && daysDouble > 0 && daysDouble < 1)
        {
            return "< 1 day (testing mode)";
        }

        return d switch
        {
            7 => "7 days",
            14 => "14 days",
            30 => "30 days",
            90 => "90 days",
            180 => "180 days",
            _ => $"{d} days"
        };
    }

    // Validation: Launches must be >= Logs
    private bool IsLaunchesDisabled(string option)
    {
        if (string.IsNullOrEmpty(KeepLogs)) return false;
        return DaysToInt(option) < DaysToInt(KeepLogs);
    }

    // Validation: Logs must be <= Launches and >= Attachments
    private bool IsLogsDisabled(string option)
    {
        var optDays = DaysToInt(option);
        if (!string.IsNullOrEmpty(KeepLaunches) && optDays > DaysToInt(KeepLaunches))
            return true;
        if (!string.IsNullOrEmpty(KeepAttachments) && optDays < DaysToInt(KeepAttachments))
            return true;
        return false;
    }

    // Validation: Attachments must be <= Logs
    private bool IsAttachmentsDisabled(string option)
    {
        if (string.IsNullOrEmpty(KeepLogs)) return false;
        return DaysToInt(option) > DaysToInt(KeepLogs);
    }

    // Storage badge calculation (3-level indicator)
    private string GetStorageBadge(string days)
    {
        if (string.IsNullOrEmpty(days)) return "";
        var d = DaysToInt(days);
        return d switch
        {
            <= 14 => "Low",
            <= 30 => "Medium",
            _ => "High"
        };
    }

    private string GetStorageBadgeClass(string days)
    {
        if (string.IsNullOrEmpty(days)) return "";
        var d = DaysToInt(days);
        return d switch
        {
            <= 14 => "bg-success",
            <= 30 => "bg-warning",
            _ => "bg-danger"
        };
    }

    private string GetStorageBadgeTooltip(string days)
    {
        if (string.IsNullOrEmpty(days)) return "";
        var d = DaysToInt(days);
        return d switch
        {
            <= 14 => "Low storage impact - minimal costs for retention up to 14 days",
            <= 30 => "Medium storage impact - moderate costs for retention up to 30 days",
            _ => "High storage impact - significant costs for long-term retention"
        };
    }

    // Cost-aware nudges
    private bool ShowLogsCostWarning()
    {
        if (string.IsNullOrEmpty(KeepLogs)) return false;
        return DaysToInt(KeepLogs) >= 90;
    }

    private bool ShowAttachmentsCostWarning()
    {
        if (string.IsNullOrEmpty(KeepAttachments)) return false;
        return DaysToInt(KeepAttachments) >= 30;
    }

    // When Launches changes
    private void OnLaunchesChanged()
    {
        ValidationMessage = string.Empty;

        if (string.IsNullOrEmpty(KeepLaunches))
        {
            StateHasChanged();
            return;
        }

        var L = DaysToInt(KeepLaunches);

        // Clear Logs if > Launches
        if (!string.IsNullOrEmpty(KeepLogs) && DaysToInt(KeepLogs) > L)
        {
            ValidationMessage = $"Keep Logs was cleared because it exceeded Launches ({FormatDays(KeepLaunches)})";
            KeepLogs = string.Empty;
        }

        // Clear Attachments if > Logs or > Launches
        if (!string.IsNullOrEmpty(KeepAttachments))
        {
            var maxAllowed = string.IsNullOrEmpty(KeepLogs) ? L : Math.Min(L, DaysToInt(KeepLogs));
            if (DaysToInt(KeepAttachments) > maxAllowed)
            {
                ValidationMessage = $"Keep Attachments was cleared because it exceeded the maximum allowed ({maxAllowed} days)";
                KeepAttachments = string.Empty;
            }
        }

        StateHasChanged();
    }

    // When Logs changes
    private void OnLogsChanged()
    {
        ValidationMessage = string.Empty;

        if (string.IsNullOrEmpty(KeepLogs))
        {
            StateHasChanged();
            return;
        }

        var G = DaysToInt(KeepLogs);

        // Clear Launches if < Logs
        if (!string.IsNullOrEmpty(KeepLaunches) && DaysToInt(KeepLaunches) < G)
        {
            ValidationMessage = $"Keep Launches was cleared because it was less than Logs ({FormatDays(KeepLogs)})";
            KeepLaunches = string.Empty;
        }

        // Clear Attachments if > Logs
        if (!string.IsNullOrEmpty(KeepAttachments) && DaysToInt(KeepAttachments) > G)
        {
            ValidationMessage = $"Keep Attachments was cleared because it exceeded Logs ({FormatDays(KeepLogs)})";
            KeepAttachments = string.Empty;
        }

        StateHasChanged();
    }

    // When Attachments changes
    private void OnAttachmentsChanged()
    {
        ValidationMessage = string.Empty;

        if (string.IsNullOrEmpty(KeepAttachments))
        {
            StateHasChanged();
            return;
        }

        var A = DaysToInt(KeepAttachments);

        // Validate A <= Logs
        if (!string.IsNullOrEmpty(KeepLogs) && A > DaysToInt(KeepLogs))
        {
            ValidationMessage = $"Keep Attachments must be ≤ Logs ({FormatDays(KeepLogs)}). Selection cleared.";
            KeepAttachments = string.Empty;
        }

        StateHasChanged();
    }

    private void OnSettingChanged()
    {
        StateHasChanged();
    }

    private void ResetSettings()
    {
        LaunchInactivityTimeout = OriginalLaunchInactivityTimeout;
        KeepLaunches = OriginalKeepLaunches;
        KeepLogs = OriginalKeepLogs;
        KeepAttachments = OriginalKeepAttachments;
        ValidationMessage = string.Empty;
        StateHasChanged();
    }

    private void ResetToRecommended()
    {
        KeepLaunches = "30d";
        KeepLogs = "7d";
        KeepAttachments = "7d";
        ValidationMessage = "Reset to recommended defaults: Launches 30d, Logs 7d, Attachments 7d";
        StateHasChanged();
    }

    private async Task SaveSettings()
    {
        // Validate all fields are set
        if (!CanSave)
        {
            ValidationMessage = "Please complete all required selections before saving.";
            StateHasChanged();
            return;
        }

        IsSaving = true;
        StateHasChanged();

        try
        {
            var httpClient = HttpFactory.CreateClient(HttpClientNames.Hub);
            httpClient.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);

            var payload = new
            {
                launchInactivityTimeout = LaunchInactivityTimeout,
                keepLaunches = KeepLaunches,
                keepLogs = KeepLogs,
                keepAttachments = KeepAttachments
            };

            var response = await httpClient.PostAsJsonAsync($"/api/projects/{ProjectKey}/settings", payload);

            if (response.IsSuccessStatusCode)
            {
                // Update originals
                OriginalLaunchInactivityTimeout = LaunchInactivityTimeout;
                OriginalKeepLaunches = KeepLaunches;
                OriginalKeepLogs = KeepLogs;
                OriginalKeepAttachments = KeepAttachments;

                ValidationMessage = string.Empty;
                ToastType = "success";
                ToastTitle = "Settings Saved";
                ToastMessage = "Your project settings have been updated successfully.";
                ShowToast = true;
                StateHasChanged();

                // Hide toast after 4 seconds
                await Task.Delay(4000);
                ShowToast = false;
                StateHasChanged();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Logger.LogError("Failed to save settings: {StatusCode} - {Error}", response.StatusCode, error);

                ToastType = "error";
                ToastTitle = "Save Failed";
                ToastMessage = "Failed to save settings. Please try again.";
                ShowToast = true;
                StateHasChanged();

                await Task.Delay(4000);
                ShowToast = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving project settings for {ProjectKey}", ProjectKey);

            ToastType = "error";
            ToastTitle = "Error";
            ToastMessage = "An error occurred while saving settings.";
            ShowToast = true;
            StateHasChanged();

            await Task.Delay(4000);
            ShowToast = false;
            StateHasChanged();
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    private class SettingsResponse
    {
        public string LaunchInactivityTimeout { get; set; } = "1d";
        public string? KeepLaunches { get; set; }
        public string? KeepLogs { get; set; }
        public string? KeepAttachments { get; set; }
    }

}
