    private async Task ExecuteToggleImportant(Guid launchId, bool currentIsImportant)
    {
        try
        {
            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            var payload = new { isImportant = !currentIsImportant };
            var request = new HttpRequestMessage(HttpMethod.Put, $"/api/launches/{launchId}")
            {
                Content = JsonContent.Create(payload)
            };
            request.Headers.Add("X-Project-Key", ProjectKey);
            using var resp = await client.SendAsync(request);

            if (!resp.IsSuccessStatusCode)
            {
                var errorText = await resp.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("showToast", $"Failed to update launch: {errorText}", "error");
                return;
            }

            // Update local state
            if (LaunchList != null)
            {
                var launch = LaunchList.FirstOrDefault(l => l.LaunchId == launchId);
                if (launch != null)
                {
                    var updatedLaunch = launch with { IsImportant = !currentIsImportant };
                    var index = LaunchList.IndexOf(launch);
                    LaunchList[index] = updatedLaunch;
                }
            }

            var statusText = !currentIsImportant ? "marked as important" : "important flag removed";
            await JS.InvokeVoidAsync("showToast", $"Launch {statusText} successfully", "success");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Error: {ex.Message}", "error");
        }
    }

