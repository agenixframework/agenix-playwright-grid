    private void RemoveAttributePair(AttributePairInput pair)
    {
        _newAttributePairs.Remove(pair);
        if (_newAttributePairs.Count == 0)
        {
            _newAttributePairs.Add(new AttributePairInput());
        }
    }

    private void AddNewAttributes()
    {
        foreach (var pair in _newAttributePairs)
        {
            if (string.IsNullOrWhiteSpace(pair.Key)) continue;

            var attribute = string.IsNullOrWhiteSpace(pair.Value)
                ? pair.Key.Trim()
                : $"{pair.Key.Trim()}:{pair.Value.Trim()}";

            if (!_commonAttributes.Contains(attribute))
            {
                _commonAttributes.Add(attribute);
            }
        }

        _showAddAttributeInput = false;
        _newAttributePairs.Clear();
    }

    private void CancelBulkEdit()
    {
        ShowBulkEditModal = false;
        _commonAttributes.Clear();
        _uniqueAttributes.Clear();
        _descriptionMode = "none";
        _bulkDescription = string.Empty;
        _showAddAttributeInput = false;
        _newAttributePairs.Clear();
    }

    private async Task ConfirmBulkEdit()
    {
        ShowBulkEditModal = false;

        if (!SelectedLaunchIds.Any()) return;

        var countToUpdate = SelectedLaunchIds.Count;

        try
        {
            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            var updateCount = 0;

            foreach (var launchId in SelectedLaunchIds)
            {
                var updateRequest = new Dictionary<string, object>
                {
                    { "attributes", _commonAttributes.ToArray() }
                };

                // Handle description based on mode
                if (_descriptionMode != "none" && !string.IsNullOrWhiteSpace(_bulkDescription))
                {
                    var launch = LaunchList?.FirstOrDefault(l => l.LaunchId == launchId);
                    if (launch != null)
                    {
                        var finalDescription = _descriptionMode switch
                        {
                            "add" => string.IsNullOrWhiteSpace(launch.Description)
                                ? _bulkDescription
                                : $"{launch.Description}\n{_bulkDescription}",
                            "replace" => _bulkDescription,
                            _ => launch.Description ?? string.Empty
                        };
                        updateRequest["description"] = finalDescription;
                    }
                }

                var response = await client.PutAsJsonAsync($"/api/launches/{launchId}", updateRequest);
                if (response.IsSuccessStatusCode)
                {
                    updateCount++;
                }
            }

            if (updateCount > 0)
            {
                await JS.InvokeVoidAsync("showToast",
                    $"{updateCount} launch{(updateCount > 1 ? "es" : "")} updated successfully", "success");
            }

            SelectedLaunchIds.Clear();
            await LoadLaunchesAsync();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Error: {ex.Message}", "error");
        }

        CancelBulkEdit();
    }

    private bool ShouldTruncateDescription(string? description)
    {
        return !string.IsNullOrEmpty(description) && description.Length > DescriptionPreviewLength;
    }

    private string GetDisplayDescription(Guid launchId, string? description)
    {
        if (string.IsNullOrEmpty(description)) return string.Empty;

        if (!ShouldTruncateDescription(description) || IsDescriptionExpanded(launchId))
        {
            return description;
        }

        return description.Substring(0, DescriptionPreviewLength) + "...";
    }

