    private void CancelForceFinish()
    {
        if (_forceFinishInProgress) return; // Don't allow cancel during operation

        _showForceFinishModal = false;
        _pendingForceFinishLaunchId = Guid.Empty;
        _pendingForceFinishLaunchName = "";
        _bulkForceFinish = false;
        _forceFinishReason = "";
        _forceFinishProgress = 0;
        _forceFinishTotal = 0;
    }

    private async Task ConfirmForceFinish()
    {
        try
        {
            _forceFinishInProgress = true;
            StateHasChanged();

            var http = HttpFactory.CreateClient(HttpClientNames.Hub);
            var requestBody = new { reason = string.IsNullOrWhiteSpace(_forceFinishReason) ? null : _forceFinishReason };
            var content = new StringContent(JsonSerializer.Serialize(requestBody), Encoding.UTF8, "application/json");

            var successCount = 0;
            var failCount = 0;

            if (_bulkForceFinish)
            {
                // Force finish all active selected launches with progress tracking
                var activeLaunchIds = LaunchList?
                    .Where(l => SelectedLaunchIds.Contains(l.LaunchId) && l.Status == "InProgress")
                    .Select(l => l.LaunchId)
                    .ToList() ?? new List<Guid>();

                _forceFinishTotal = activeLaunchIds.Count;
                _forceFinishProgress = 0;

                foreach (var launchId in activeLaunchIds)
                {
                    var request = new HttpRequestMessage(HttpMethod.Post, $"/api/launches/{launchId}/force-finish")
                    {
                        Content = content
                    };
                    request.Headers.Add("X-Project-Key", ProjectKey);

                    var response = await http.SendAsync(request);
                    if (response.IsSuccessStatusCode)
                    {
                        successCount++;
                    }
                    else
                    {
                        failCount++;
                        var error = await response.Content.ReadAsStringAsync();
                        Console.WriteLine($"Failed to force finish launch {launchId}: {error}");
                    }

                    _forceFinishProgress++;
                    StateHasChanged(); // Update progress bar
                }

                // Clear selection after bulk action
                SelectedLaunchIds.Clear();

                // Show toast message for bulk operation
                if (successCount > 0 && failCount == 0)
                {
                    await JS.InvokeVoidAsync("showToast",
                        $"{successCount} launch{(successCount > 1 ? "es" : "")} force finished successfully", "success");
                }
                else if (successCount > 0 && failCount > 0)
                {
                    await JS.InvokeVoidAsync("showToast",
                        $"{successCount} succeeded, {failCount} failed", "warning");
                }
                else if (failCount > 0)
                {
                    await JS.InvokeVoidAsync("showToast",
                        $"Failed to force finish {failCount} launch{(failCount > 1 ? "es" : "")}", "error");
                }
            }
            else
            {
                // Force finish single launch
                var request = new HttpRequestMessage(HttpMethod.Post, $"/api/launches/{_pendingForceFinishLaunchId}/force-finish")
                {
                    Content = content
                };
                request.Headers.Add("X-Project-Key", ProjectKey);

                var response = await http.SendAsync(request);
                if (response.IsSuccessStatusCode)
                {
                    await JS.InvokeVoidAsync("showToast",
                        $"Launch '{_pendingForceFinishLaunchName}' force finished successfully", "success");
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    await JS.InvokeVoidAsync("showToast",
                        $"Failed to force finish launch: {error}", "error");
                }
            }

            // Close modal
            _showForceFinishModal = false;
            _pendingForceFinishLaunchId = Guid.Empty;
            _pendingForceFinishLaunchName = "";
            _bulkForceFinish = false;
            _forceFinishReason = "";
            _forceFinishInProgress = false;
            _forceFinishProgress = 0;
            _forceFinishTotal = 0;

            // Reload launches
            await LoadLaunchesAsync();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Error: {ex.Message}", "error");
            _showForceFinishModal = false;
            _forceFinishInProgress = false;
        }
    }

