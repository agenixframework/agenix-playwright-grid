@code {
    [Parameter] public string ProjectKey { get; set; } = string.Empty;

    private List<LaunchDto>? LaunchList { get; set; }
    private string SortBy { get; set; } = nameof(LaunchDto.StartTime);
    private bool SortAscending { get; set; }
    private string SelectedFilter { get; set; } = "ALL LAUNCHES";
    private string? ErrorMessage { get; set; }

    // SignalR connection
    private HubConnection? _hubConnection;

    // Selection State
    private HashSet<Guid> SelectedLaunchIds { get; set; } = new();
    private ElementReference HeaderCheckboxRef;
    private bool IsAllSelected => LaunchList?.Any() == true && SelectedLaunchIds.Count == LaunchList.Count;
    private bool IsPartiallySelected => SelectedLaunchIds.Any() && !IsAllSelected;
    private bool HasActiveSelectedLaunches => LaunchList?.Any(l => SelectedLaunchIds.Contains(l.LaunchId) && l.Status == "InProgress") == true;
    private string CurrentUserId { get; set; } = string.Empty;

    // Feature flags
    private bool ImportantLaunchesFeatureEnabled;

    // Description toggle state - tracks which launch IDs have expanded descriptions
    private readonly HashSet<Guid> _expandedDescriptions = new();
    private const int DescriptionPreviewLength = 100;

    // Launch menu state - tracks which launch menu is open
    private Guid? _openLaunchMenuId;

    // Important confirmation modal state
    private bool ShowImportantConfirmModal;
    private bool ShowUnmarkConfirmModal;
    private Guid _pendingImportantLaunchId = Guid.Empty;

    // Delete launch modal state
    private bool ShowDeleteLaunchModal;
    private Guid _pendingDeleteLaunchId = Guid.Empty;
    private string _pendingDeleteLaunchName = string.Empty;
    private bool _pendingDeleteLaunchIsImportant;

    // Compare launches modal state
    private bool _showCompareModal;
    private List<LaunchComparisonDto>? _comparisonData;
    private bool _isLoadingComparison;
    private string? _comparisonError;
    private bool _shouldRenderChart;

    // Bulk delete modal state
    private bool ShowBulkDeleteModal;

    // Force Finish modal state
    private bool _showForceFinishModal;
    private Guid _pendingForceFinishLaunchId;
    private string _pendingForceFinishLaunchName = "";
    private bool _bulkForceFinish;
    private string _forceFinishReason = "";
    private bool _forceFinishInProgress;
    private int _forceFinishProgress;
    private int _forceFinishTotal;

    // Bulk edit modal state
    private bool ShowBulkEditModal;
    private List<string> _commonAttributes = new();
    private List<string> _uniqueAttributes = new();
    private string _descriptionMode = "none"; // none, add, replace
    private string _bulkDescription = string.Empty;
    private bool _showAddAttributeInput;
    private List<AttributePairInput> _newAttributePairs = new();

    private class AttributePairInput
    {
        public string Key { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    // Pagination
    private int _skip;
    private int _take = 50;

    private List<LaunchDto> GetPaginatedLaunches()
    {
        if (LaunchList == null) return new List<LaunchDto>();

        IEnumerable<LaunchDto> filtered = LaunchList;

        // Apply filters with AND/OR logic
        if (ShowFilterPanel && FilterCriteria.Any())
        {
            // Filter only valid criteria (with non-empty values or valid attribute filters)
            var validCriteria = FilterCriteria.Where(c =>
                (c.Field == "attribute" && c.Attributes != null && c.Attributes.Count > 0) ||
                (c.Field != "attribute" && !string.IsNullOrWhiteSpace(c.Value))
            ).ToList();

            if (validCriteria.Any())
            {
                filtered = filtered.Where(launch => EvaluateFilters(launch, validCriteria));
            }
        }

        // Apply sorting
        if (SortBy == nameof(LaunchDto.Name))
        {
            filtered = SortAscending
                ? filtered.OrderBy(l => l.Name, StringComparer.OrdinalIgnoreCase).ThenBy(l => l.LaunchNumber)
                : filtered.OrderByDescending(l => l.Name, StringComparer.OrdinalIgnoreCase).ThenByDescending(l => l.LaunchNumber);
        }
        else if (SortBy == nameof(LaunchDto.StartTime))
        {
            filtered = SortAscending
                ? filtered.OrderBy(l => l.StartTime)
                : filtered.OrderByDescending(l => l.StartTime);
        }

        return filtered.Skip(_skip).Take(_take).ToList();
    }

    private bool EvaluateFilters(LaunchDto launch, List<FilterCriterion> criteria)
    {
        if (!criteria.Any()) return true;

        // Start with the first criterion
        var result = EvaluateSingleCriterion(launch, criteria[0]);

        // Process remaining criteria with their logical operators
        for (var i = 1; i < criteria.Count; i++)
        {
            var criterion = criteria[i];
            var criterionResult = EvaluateSingleCriterion(launch, criterion);

            if (criterion.LogicalOperator == "OR")
            {
                result = result || criterionResult;
            }
            else // AND
            {
                result = result && criterionResult;
            }
        }

        return result;
    }

    private bool EvaluateSingleCriterion(LaunchDto launch, FilterCriterion criterion)
    {
        return criterion.Field switch
        {
            "name" => EvaluateStringFilter(launch.Name, criterion.Operator, criterion.Value),
            "owner" => EvaluateStringFilter(launch.OwnerUsername ?? "", criterion.Operator, criterion.Value),
            "description" => EvaluateStringFilter(launch.Description ?? "", criterion.Operator, criterion.Value),
            "launch_number" => EvaluateNumberFilter(launch.LaunchNumber, criterion.Operator, criterion.Value),
            "start_time" => EvaluateDateTimeFilter(launch.StartTime, criterion.Operator, criterion.Value),
            "attribute" => EvaluateAttributeFilter(launch.AttributesArray, criterion.Operator, criterion.Attributes),
            "total" => EvaluateNumberFilter(launch.TotalTestRuns, criterion.Operator, criterion.Value),
            "finished" => EvaluateNumberFilter(launch.FinishedTestRuns, criterion.Operator, criterion.Value),
            "running" => EvaluateNumberFilter(launch.RunningTestRuns, criterion.Operator, criterion.Value),
            "error" => EvaluateNumberFilter(launch.ErroredTestRuns, criterion.Operator, criterion.Value),
            "stopped" => EvaluateNumberFilter(launch.StoppedTestRuns, criterion.Operator, criterion.Value),
            _ => true
        };
    }

    private bool EvaluateStringFilter(string fieldValue, string op, string filterValue)
    {
        return op switch
        {
            "contains" => fieldValue.Contains(filterValue, StringComparison.OrdinalIgnoreCase),
            "not_contains" => !fieldValue.Contains(filterValue, StringComparison.OrdinalIgnoreCase),
            "equals" => fieldValue.Equals(filterValue, StringComparison.OrdinalIgnoreCase),
            "not_equals" => !fieldValue.Equals(filterValue, StringComparison.OrdinalIgnoreCase),
            _ => true
        };
    }

    private bool EvaluateNumberFilter(int fieldValue, string op, string filterValue)
    {
        if (!int.TryParse(filterValue, out var numValue))
            return true;

        return op switch
        {
            "equals" => fieldValue == numValue,
            "gte" => fieldValue >= numValue,
            "lte" => fieldValue <= numValue,
            _ => true
        };
    }

    private bool EvaluateDateTimeFilter(DateTimeOffset fieldValue, string op, string filterValue)
    {
        if (op == "range" && filterValue.Contains('|'))
        {
            var parts = filterValue.Split('|');
            if (parts.Length == 2 &&
                DateTimeOffset.TryParse(parts[0], out var fromDate) &&
                DateTimeOffset.TryParse(parts[1], out var toDate))
            {
                // Compare dates only (ignore time)
                var fieldDate = fieldValue.Date;
                var fromDateOnly = fromDate.Date;
                var toDateOnly = toDate.Date;
                return fieldDate >= fromDateOnly && fieldDate <= toDateOnly;
            }

            return true;
        }

        if (!DateTimeOffset.TryParse(filterValue, out var dateValue))
            return true;

        return op switch
        {
            "equals" => fieldValue.Date == dateValue.Date,
            "before" => fieldValue < dateValue,
            "after" => fieldValue > dateValue,
            _ => true
        };
    }

    private bool EvaluateAttributeFilter(string[] launchAttributes, string op, List<AttributePair> filterAttributes)
    {
        // If no filter attributes specified, pass all launches
        if (filterAttributes == null || filterAttributes.Count == 0)
            return true;

        return op switch
        {
            // "all" - launch must have ALL filter attributes
            "all" => filterAttributes.All(fa => MatchesLaunchAttribute(launchAttributes, fa)),
            // "without_all" - launch must NOT have ALL filter attributes (missing at least one)
            "without_all" => !filterAttributes.All(fa => MatchesLaunchAttribute(launchAttributes, fa)),
            // "any" - launch must have AT LEAST ONE filter attribute
            "any" => filterAttributes.Any(fa => MatchesLaunchAttribute(launchAttributes, fa)),
            // "without_any" - launch must NOT have ANY filter attributes (missing all)
            "without_any" => !filterAttributes.Any(fa => MatchesLaunchAttribute(launchAttributes, fa)),
            _ => true
        };
    }

    private bool MatchesLaunchAttribute(string[] launchAttributes, AttributePair filterAttr)
    {
        // Build the search string from filter attribute
        var searchAttribute = string.IsNullOrWhiteSpace(filterAttr.Value)
            ? filterAttr.Key
            : $"{filterAttr.Key}:{filterAttr.Value}";

        // Check if any launch attribute exactly matches the filter attribute
        return launchAttributes.Any(attr => attr.Equals(searchAttribute, StringComparison.OrdinalIgnoreCase));
    }

    private void ApplyFilters()
    {
        // Reset to first page when filters change
        _skip = 0;
        StateHasChanged();
    }

    private void OnFilterModified()
    {
        // Called when user manually modifies filter criteria
        IsFilterSaved = false;
        ApplyFilters();
    }

    private void OnFilterSortByChanged()
    {
        // Synchronize filter's sort dropdown with table's sort state
        if (FilterSortBy == "name")
        {
            SortBy = nameof(LaunchDto.Name);
            SortAscending = true; // A-Z by default
        }
        else if (FilterSortBy == "start_time")
        {
            SortBy = nameof(LaunchDto.StartTime);
            SortAscending = false; // Latest first by default
        }

        IsFilterSaved = false;
        ApplyFilters();
    }

    private void OnFieldChange(FilterCriterion filter)
    {
        // Set default operators based on field type
        switch (filter.Field)
        {
            case "name":
            case "owner":
            case "description":
                filter.Operator = "contains";
                break;
            case "launch_number":
            case "total":
            case "finished":
            case "running":
            case "error":
            case "stopped":
                filter.Operator = "gte";
                break;
            case "start_time":
                filter.Operator = "range";
                filter.DateRangePreset = "today";
                SetDateRangePreset(filter, "today");
                break;
            case "attribute":
                filter.Operator = "all";
                break;
        }

        OnFilterModified();
    }

    private string GetDateRangeDisplay(FilterCriterion filter)
    {
        if (filter.DateRangePreset == "custom" && !string.IsNullOrEmpty(filter.FromDate) && !string.IsNullOrEmpty(filter.ToDate))
        {
            return $"{filter.FromDate} - {filter.ToDate}";
        }

        return filter.DateRangePreset switch
        {
            "today" => "Today",
            "last_2_days" => "Last 2 days",
            "last_7_days" => "Last 7 days",
            "last_30_days" => "Last 30 days",
            "custom" => "Custom range",
            _ => "Select range"
        };
    }

    private void SetDateRangePreset(FilterCriterion filter, string preset)
    {
        filter.DateRangePreset = preset;
        var today = DateTimeOffset.UtcNow.Date;

        switch (preset)
        {
            case "today":
                filter.FromDate = today.ToString("yyyy-MM-dd");
                filter.ToDate = today.ToString("yyyy-MM-dd");
                break;
            case "last_2_days":
                filter.FromDate = today.AddDays(-2).ToString("yyyy-MM-dd");
                filter.ToDate = today.ToString("yyyy-MM-dd");
                break;
            case "last_7_days":
                filter.FromDate = today.AddDays(-7).ToString("yyyy-MM-dd");
                filter.ToDate = today.ToString("yyyy-MM-dd");
                break;
            case "last_30_days":
                filter.FromDate = today.AddDays(-30).ToString("yyyy-MM-dd");
                filter.ToDate = today.ToString("yyyy-MM-dd");
                break;
            case "custom":
                // Keep existing dates or set to today
                if (string.IsNullOrEmpty(filter.FromDate))
                    filter.FromDate = today.ToString("yyyy-MM-dd");
                if (string.IsNullOrEmpty(filter.ToDate))
                    filter.ToDate = today.ToString("yyyy-MM-dd");
                break;
        }

        filter.Value = $"{filter.FromDate}|{filter.ToDate}";

        if (preset != "custom")
        {
            filter.ShowDateRangePicker = false;
        }

        OnFilterModified();
    }

    private void UpdateCustomDateRange(FilterCriterion filter)
    {
        filter.Value = $"{filter.FromDate}|{filter.ToDate}";
        OnFilterModified();
    }

    private void PrevPage()
    {
        if (_skip > 0)
        {
            _skip = Math.Max(0, _skip - _take);
        }
    }

    private void NextPage()
    {
        if (LaunchList != null && _skip + _take < LaunchList.Count)
        {
            _skip += _take;
        }
    }

    private void OnTakeChanged(int newTake)
    {
        _take = newTake;
        _skip = 0; // Reset to first page when changing page size
    }

    protected override async Task OnInitializedAsync()
    {
        // Get current user ID from authentication
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        CurrentUserId = authState.User?.FindFirst("preferred_username")?.Value ?? string.Empty;

        if (string.IsNullOrEmpty(CurrentUserId))
        {
            ErrorMessage = "Unable to determine current user. Please log in.";
            return;
        }

        // Parse query parameters
        var uri = new Uri(Nav.Uri);
        var query = HttpUtility.ParseQueryString(uri.Query);

        // Load feature flags
        await LoadFeatureFlagsAsync();

        // Load saved filters from API
        await LoadFiltersFromApiAsync();

        // Handle filterId query parameter (from Filters page)
        if (!string.IsNullOrEmpty(query["filterId"]) && Guid.TryParse(query["filterId"], out var filterId))
        {
            SelectedSavedFilter = filterId.ToString();
            ShowFilterPanel = true;
            LoadSavedFilter(); // This will populate FilterCriteria and apply the filter
        }
        // Handle showFilter query parameter (from other sources)
        else if (query["showFilter"] == "true")
        {
            ShowFilterPanel = true;
        }
        else
        {
            // Load filter preference from API (normal flow)
            await LoadFilterPreferenceFromApiAsync();
        }

        await LoadLaunchesAsync();

        // Initialize SignalR connection
        await InitializeSignalRAsync();
    }

    private async Task InitializeSignalRAsync()
    {
        try
        {
            var hubUrl = Config["HUB_SIGNALR"] ?? "http://hub:5000/ws";
            var uri = new Uri(hubUrl);
            var scheme = uri.Scheme switch { "ws" => "http", "wss" => "https", _ => uri.Scheme };
            var launchesWs = $"{scheme}://{uri.Authority}/launches-ws";

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(launchesWs)
                .WithAutomaticReconnect()
                .Build();

            // Subscribe to launch updates
            _hubConnection.On<string, Guid>("LaunchUpdated", async (projectKey, launchId) =>
            {
                // Only refresh if the update is for our current project
                if (projectKey == ProjectKey)
                {
                    await InvokeAsync(async () =>
                    {
                        // Refresh the launch in the list without full page reload
                        await RefreshLaunchAsync(launchId);
                    });
                }
            });

            // Subscribe to launch deletions
            _hubConnection.On<string, Guid>("LaunchDeleted", async (projectKey, launchId) =>
            {
                if (projectKey == ProjectKey)
                {
                    await InvokeAsync(() =>
                    {
                        // Remove the launch from the list
                        if (LaunchList != null)
                        {
                            LaunchList.RemoveAll(l => l.LaunchId == launchId);
                            StateHasChanged();
                        }

                        return Task.CompletedTask;
                    });
                }
            });

            await _hubConnection.StartAsync();

            // Join the project-specific group
            await _hubConnection.InvokeAsync("JoinProject", ProjectKey);
        }
        catch (Exception ex)
        {
            // Silently fail - SignalR is optional enhancement
            Console.WriteLine($"Failed to initialize SignalR: {ex.Message}");
        }
    }

    private async Task RefreshLaunchAsync(Guid launchId)
    {
        try
        {
            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            var response = await client.GetAsync($"/api/launches/{launchId}");

            if (response.IsSuccessStatusCode)
            {
                var updatedLaunch = await response.Content.ReadFromJsonAsync<LaunchDto>();
                if (updatedLaunch != null && LaunchList != null)
                {
                    // Find and update the launch in the list
                    var index = LaunchList.FindIndex(l => l.LaunchId == launchId);
                    if (index >= 0)
                    {
                        // Update existing launch
                        LaunchList[index] = updatedLaunch;
                    }
                    else
                    {
                        // New launch - insert it into the list
                        LaunchList.Insert(0, updatedLaunch); // Add at the beginning (most recent)

                        // If we're on a page other than the first, jump to first page to show the new launch
                        if (_skip > 0)
                        {
                            _skip = 0;
                        }
                    }

                    StateHasChanged();
                }
            }
        }
        catch
        {
            // Silently ignore refresh errors
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Render the comparison chart after DOM is ready
        if (_shouldRenderChart && _comparisonData != null)
        {
            _shouldRenderChart = false;

            // Try to render the chart, with retries if element not yet in DOM
            for (var i = 0; i < 10; i++)
            {
                var success = await JS.InvokeAsync<bool>("renderComparisonChart", "compare-chart", _comparisonData);
                if (success)
                {
                    break;
                }

                // Wait a bit and try again
                await Task.Delay(50);
            }
        }
    }

    private async Task LoadFeatureFlagsAsync()
    {
        try
        {
            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            var response = await client.GetAsync("/admin/features");

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var doc = JsonDocument.Parse(json);

                if (doc.RootElement.TryGetProperty("importantLaunchesEnabled", out var featureEl))
                {
                    ImportantLaunchesFeatureEnabled = featureEl.GetBoolean();
                }
            }
        }
        catch
        {
            // If loading fails, default to false (feature disabled)
            ImportantLaunchesFeatureEnabled = false;
        }
    }

    private async Task LoadFiltersFromApiAsync()
    {
        try
        {
            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            var response = await client.GetAsync($"/api/launch-filters?projectKey={Uri.EscapeDataString(ProjectKey)}&userId={Uri.EscapeDataString(CurrentUserId)}");

            if (response.IsSuccessStatusCode)
            {
                var filters = await response.Content.ReadFromJsonAsync<List<LaunchFilterDto>>();
                if (filters != null)
                {
                    // Convert API DTOs to local SavedFilter objects
                    SavedFilters = filters.Select(f => new SavedFilter
                    {
                        Id = f.Id,
                        Name = f.Name,
                        Description = f.Description,
                        ProjectKey = f.ProjectKey,
                        UserId = f.UserId,
                        Criteria = f.Criteria.Select(c => new FilterCriterion
                        {
                            Field = c.Field,
                            Operator = c.Operator,
                            Value = c.Value,
                            LogicalOperator = c.LogicalOperator,
                            DateRangePreset = c.DateRangePreset ?? "today",
                            FromDate = c.FromDate ?? string.Empty,
                            ToDate = c.ToDate ?? string.Empty,
                            ShowDateRangePicker = false,
                            AttributeKey = c.AttributeKey ?? string.Empty,
                            AttributeValue = c.AttributeValue ?? string.Empty
                        }).ToList(),
                        SortBy = f.SortBy,
                        IsShared = f.IsShared,
                        DisplayOnLaunches = f.DisplayOnLaunches,
                        CreatedAt = f.CreatedAt
                    }).ToList();
                }
            }
        }
        catch
        {
            // Silently fail and use empty list
            SavedFilters = new List<SavedFilter>();
        }
    }

    private async Task LoadFilterPreferenceFromApiAsync()
    {
        try
        {
            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            var response = await client.GetAsync($"/api/launch-filters/preference?projectKey={Uri.EscapeDataString(ProjectKey)}&userId={Uri.EscapeDataString(CurrentUserId)}");

            if (response.IsSuccessStatusCode)
            {
                var preference = await response.Content.ReadFromJsonAsync<UserFilterPreferenceDto>();
                if (preference?.SelectedFilterId != null)
                {
                    SelectedSavedFilter = preference.SelectedFilterId.Value.ToString();
                    LoadSavedFilter();
                }
                else
                {
                    SelectedFilter = "ALL LAUNCHES";
                }
            }
        }
        catch
        {
            // Silently fail and use default
            SelectedFilter = "ALL LAUNCHES";
        }
    }

    private void LoadSavedFilter()
    {
        if (string.IsNullOrEmpty(SelectedSavedFilter))
        {
            // Clear filters
            FilterCriteria.Clear();
            ShowFilterPanel = false;
            IsFilterSaved = false;
        }
        else
        {
            // Load the selected saved filter
            var filter = SavedFilters.FirstOrDefault(f => f.Id.ToString() == SelectedSavedFilter);
            if (filter != null)
            {
                FilterCriteria = filter.Criteria.Select(c => new FilterCriterion
                {
                    Field = c.Field,
                    Operator = c.Operator,
                    Value = c.Value,
                    LogicalOperator = c.LogicalOperator,
                    DateRangePreset = c.DateRangePreset,
                    FromDate = c.FromDate,
                    ToDate = c.ToDate,
                    ShowDateRangePicker = false,
                    AttributeKey = c.AttributeKey,
                    AttributeValue = c.AttributeValue,
                    Attributes = c.Attributes?.Select(a => new AttributePair
                    {
                        Key = a.Key,
                        Value = a.Value
                    }).ToList() ?? new List<AttributePair>()
                }).ToList();

                FilterSortBy = filter.SortBy;
                ShowFilterPanel = true;
                IsFilterSaved = true;
                ApplyFilters();

                // Persist the selection to API
                _ = SaveFilterPreferenceAsync(filter.Id);
            }
        }
    }

    private async Task SaveFilterPreferenceAsync(Guid filterId)
    {
        try
        {
            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            var request = new UpdateFilterPreferenceRequest
            {
                ProjectKey = ProjectKey,
                SelectedFilterId = filterId
            };

            await client.PutAsJsonAsync($"/api/launch-filters/preference?userId={Uri.EscapeDataString(CurrentUserId)}", request);
        }
        catch
        {
            // Silently fail
        }
    }

    private async Task SetFilter(string filter)
    {
        SelectedFilter = filter;

        // Reset saved filter dropdown and clear any active filter criteria
        SelectedSavedFilter = string.Empty;
        FilterCriteria.Clear();
        ShowFilterPanel = false;
        IsFilterSaved = false;

        // Persist filter preference to API (save which filter is selected)
        try
        {
            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            var request = new UpdateFilterPreferenceRequest
            {
                ProjectKey = ProjectKey,
                SelectedFilterId = null // "ALL LAUNCHES" or "MY LAUNCHES" have no saved filter ID
            };

            await client.PutAsJsonAsync($"/api/launch-filters/preference?userId={Uri.EscapeDataString(CurrentUserId)}", request);
        }
        catch
        {
            // Silently fail if API is not available
        }

        await LoadLaunchesAsync();
    }

    private async Task LoadLaunchesAsync()
    {
        try
        {
            ErrorMessage = null;
            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            var filterParam = SelectedFilter == "LATEST LAUNCHES" ? "latest" : "all";
            var response = await client.GetAsync($"/api/launches?projectKey={Uri.EscapeDataString(ProjectKey)}&filter={filterParam}");

            if (response.IsSuccessStatusCode)
            {
                LaunchList = await response.Content.ReadFromJsonAsync<List<LaunchDto>>() ?? new List<LaunchDto>();
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                ErrorMessage = $"Failed to load launches: {response.StatusCode} - {content}";
                LaunchList = new List<LaunchDto>();
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error loading launches: {ex.Message}";
            LaunchList = new List<LaunchDto>();
        }
    }

