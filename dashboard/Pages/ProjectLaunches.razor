@* Force Finish Confirmation Modal *@
@if (_showForceFinishModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle"></i> Force Finish Launch
                    </h5>
                    <button type="button" class="btn-close btn-close-dark" @onclick="CancelForceFinish"></button>
                </div>
                <div class="modal-body">
                    @if (_bulkForceFinish)
                    {
                        <p class="mb-2">
                            <strong>Force finish @GetActiveSelectedCount() active launch(es)?</strong>
                        </p>
                        <p class="mb-2">This will:</p>
                        <ul class="mb-0">
                            <li>Stop all running test items</li>
                            <li>Cancel all in-progress tests</li>
                            <li>Release all borrowed browsers</li>
                            <li>Mark launch(es) as "Stopped"</li>
                        </ul>
                        <p class="text-danger mt-3 mb-0">
                            <i class="bi bi-exclamation-circle"></i> This action cannot be undone.
                        </p>
                    }
                    else
                    {
                        <p class="mb-2">
                            Force finish launch <strong>"@_pendingForceFinishLaunchName"</strong>?
                        </p>
                        <p class="mb-2">This will:</p>
                        <ul class="mb-0">
                            <li>Stop all running test items in this launch</li>
                            <li>Cancel all in-progress tests</li>
                            <li>Release all borrowed browsers</li>
                            <li>Mark launch as "Stopped"</li>
                        </ul>
                        <p class="text-danger mt-3 mb-0">
                            <i class="bi bi-exclamation-circle"></i> This action cannot be undone.
                        </p>
                    }

                    @* Reason field *@
                    <div class="mt-3">
                        <label for="forceFinishReason" class="form-label">Reason (optional)</label>
                        <textarea class="form-control" id="forceFinishReason" rows="3"
                                  placeholder="Why are you force finishing this launch?"
                                  @bind="_forceFinishReason"></textarea>
                        <small class="text-muted">This will be recorded in the audit log.</small>
                    </div>

                    @* Progress indicator for bulk operations *@
                    @if (_forceFinishInProgress && _bulkForceFinish)
                    {
                        <div class="mt-3">
                            <div class="progress">
                                <div class="progress-bar progress-bar-striped progress-bar-animated"
                                     role="progressbar"
                                     style="width: @(_forceFinishProgress / (double)_forceFinishTotal * 100)%">
                                    @_forceFinishProgress / @_forceFinishTotal
                                </div>
                            </div>
                            <small class="text-muted d-block mt-1">Force finishing launches...</small>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CancelForceFinish"
                            disabled="@_forceFinishInProgress">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-warning" @onclick="ConfirmForceFinish"
                            disabled="@_forceFinishInProgress">
                        @if (_forceFinishInProgress)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            <span>Force Finishing...</span>
                        }
                        else
                        {
                            <i class="bi bi-stop-circle"></i>
                            <span>Force Finish</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

