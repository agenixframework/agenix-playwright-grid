    private double CalculateElapsedSeconds(LaunchDto launch)
    {
        // If FinishTime exists, use it (launch is completed - backend sets this automatically)
        if (launch.FinishTime.HasValue)
        {
            return (launch.FinishTime.Value - launch.StartTime).TotalSeconds;
        }

        // Only use UtcNow for launches that are actually in progress
        var isInProgress = launch.Status.Equals("InProgress", StringComparison.OrdinalIgnoreCase) || launch.IsRunning;
        if (isInProgress)
        {
            return (DateTimeOffset.UtcNow - launch.StartTime).TotalSeconds;
        }

        // For completed launches without FinishTime, return 0 (shouldn't happen with backend fix)
        return 0;
    }

    private string GetDurationTooltip(LaunchDto launch)
    {
        if (launch.FinishTime.HasValue)
        {
            var startLocal = launch.StartTime.ToLocalTime();
            var finishLocal = launch.FinishTime.Value.ToLocalTime();
            return $"Started: {startLocal:MMM dd, yyyy hh:mm:ss tt}\nFinished: {finishLocal:MMM dd, yyyy hh:mm:ss tt}";
        }
        else
        {
            var startLocal = launch.StartTime.ToLocalTime();
            return $"Started: {startLocal:MMM dd, yyyy hh:mm:ss tt}\nIn Progress...";
        }
    }

    private static string GetDisplayStatus(LaunchDto launch)
    {
        // Priority: Infrastructure Error > Manual Stop > Computed Status from Test Results > Lifecycle Status

        // Infrastructure error (highest priority)
        if (launch.Status?.Equals("Error", StringComparison.OrdinalIgnoreCase) == true ||
            launch.Status?.Equals("Errored", StringComparison.OrdinalIgnoreCase) == true)
            return "Errored";

        // Manual stop/cancel (second highest priority - overrides everything else)
        if (launch.Status?.Equals("Stopped", StringComparison.OrdinalIgnoreCase) == true ||
            launch.Status?.Equals("Cancelled", StringComparison.OrdinalIgnoreCase) == true ||
            launch.Status?.Equals("AutoStopped", StringComparison.OrdinalIgnoreCase) == true)
            return "Cancelled";

        // Check if still running (no finish time)
        if (!launch.FinishTime.HasValue)
            return "InProgress";

        // Calculate status from test results if launch is finished and has test data
        if (launch.TotalTests > 0)
        {
            if (launch.FailedTests > 0)
                return "Failed";
            if (launch.PassedTests > 0)
                return "Passed";
            if (launch.SkippedTests > 0)
                return "Skipped";
            return "Finished";
        }

        // Use computed status from test results (if available)
        if (!string.IsNullOrEmpty(launch.ComputedStatus))
            return launch.ComputedStatus;

        // Fallback to lifecycle status
        if (!string.IsNullOrEmpty(launch.Status))
            return launch.Status;

        // Default: Finished but no test data
        return "Finished";
    }

    private static string GetStatusReason(LaunchDto launch, string status)
    {
        return status switch
        {
            "Failed" => GetFailedReason(launch),
            "Cancelled" => GetCancelledReason(launch),
            "Stopped" => GetCancelledReason(launch),
            "Passed" => GetPassedReason(launch),
            "Errored" or "Error" => GetErrorReason(launch),
            "Timedout" => $"⏱️ {launch.TimedoutTests} test(s) timed out - maybe they're searching for the meaning of life?",
            "Skipped" => $"⊝ All {launch.SkippedTests} test(s) were skipped - taking a day off!",
            "InProgress" => "🔄 Tests are running... patience, young grasshopper",
            "Finished" => "✨ Launch completed with no test results",
            _ => "Status: " + status
        };
    }

    private static string GetFailedReason(LaunchDto launch)
    {
        var failedCount = launch.FailedTests;
        var totalCount = launch.TotalTests;
        var percentage = totalCount > 0 ? failedCount * 100.0 / totalCount : 0;

        if (percentage >= 50)
        {
            return $"❌ {failedCount}/{totalCount} tests failed ({percentage:F1}%) - Houston, we have a problem!";
        }

        if (percentage >= 20)
        {
            return $"❌ {failedCount}/{totalCount} tests failed ({percentage:F1}%) - needs attention";
        }

        if (failedCount == 1)
        {
            return "❌ 1 test failed - so close to perfection!";
        }

        return $"❌ {failedCount} tests failed - almost there!";
    }

    private static string GetCancelledReason(LaunchDto launch)
    {
        if (launch.Status?.Equals("AutoStopped", StringComparison.OrdinalIgnoreCase) == true)
        {
            return "🛑 Launch auto-stopped due to inactivity - fell asleep on the job";
        }

        if (launch.RunningTestRuns > 0)
        {
            return $"🛑 Launch cancelled while {launch.RunningTestRuns} test(s) were still running";
        }

        if (launch.TotalTests > 0)
        {
            return $"🛑 Launch cancelled - {launch.PassedTests} passed, {launch.FailedTests} failed before stopping";
        }

        return "🛑 Launch cancelled by user - decided to quit while ahead";
    }

    private static string GetPassedReason(LaunchDto launch)
    {
        var passedCount = launch.PassedTests;
        var totalCount = launch.TotalTests;

        var funnyReasons = new[]
        {
            $"✅ All {totalCount} tests passed - perfection achieved! 🎉",
            $"✅ {totalCount}/{totalCount} tests passed - flawless victory! 🏆",
            "✅ All tests passed - the bugs are hiding really well today! 🐛",
            $"✅ {totalCount} tests, 0 failures - is this thing even working? 😄",
            $"✅ Perfect score! All {totalCount} tests passed - time for a coffee break! ☕",
            $"✅ {totalCount}/{totalCount} - the developer's dream came true! 🌟",
            "✅ All tests passed - someone's getting a raise! 💰",
            $"✅ Flawless execution - {totalCount} tests, 0 drama! 🎭",
            $"✅ All {totalCount} tests passed - the QA team is crying tears of joy! 😭",
            "✅ Perfect! Now let's not touch anything and call it a day! 🙌"
        };

        // Use launch ID hash to pick a consistent funny reason for each launch
        var index = Math.Abs(launch.LaunchId.GetHashCode()) % funnyReasons.Length;
        return funnyReasons[index];
    }

    private static string GetErrorReason(LaunchDto launch)
    {
        if (launch.ErroredTestRuns > 0)
        {
            return $"⚠️ {launch.ErroredTestRuns} test run(s) encountered infrastructure errors - blame the system!";
        }

        return "⚠️ Launch encountered an infrastructure error - not a test failure, but something went wrong";
    }

