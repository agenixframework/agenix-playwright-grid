            var response = await client.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<BulkUpdateResponse>();
                if (result != null)
                {
                    var message = result.FailureCount > 0
                        ? $"Marked {result.SuccessCount} launch(es) as important ({result.FailureCount} failed)"
                        : $"Marked {result.SuccessCount} launch(es) as important";

                    await JS.InvokeVoidAsync("showToast", message,
                        result.FailureCount > 0 ? "warning" : "success");
                }
            }
            else
            {
                var errorText = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("showToast",
                    $"Error: {response.StatusCode} - {errorText}", "error");
            }

            SelectedLaunchIds.Clear();
            await LoadLaunchesAsync();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("showToast", $"Error: {ex.Message}", "error");
        }
    }

