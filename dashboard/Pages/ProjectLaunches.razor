    private async Task SaveEditLaunch()
    {
        if (IsSavingLaunch) return;
        if (string.IsNullOrWhiteSpace(EditLaunchName))
        {
            EditLaunchError = "Launch name is required";
            return;
        }

        try
        {
            IsSavingLaunch = true;
            EditLaunchError = string.Empty;
            StateHasChanged();

            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            // Convert attributes back to string array format
            var attributesArray = EditLaunchAttributes
                .Where(a => !string.IsNullOrWhiteSpace(a.Key))
                .Select(a =>
                {
                    var key = a.Key?.Trim() ?? string.Empty;
                    var value = a.Value?.Trim();
                    return string.IsNullOrWhiteSpace(value) ? key : $"{key}:{value}";
                })
                .ToArray();

            var updateData = new
            {
                name = EditLaunchName.Trim(),
                description = EditLaunchDescription?.Trim(),
                attributes = attributesArray
            };

            var request = new HttpRequestMessage(HttpMethod.Put, $"/api/launches/{EditLaunchId}")
            {
                Content = JsonContent.Create(updateData)
            };
            request.Headers.Add("X-Project-Key", ProjectKey);
            var response = await client.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                // Update local list
                var launch = LaunchList?.FirstOrDefault(l => l.LaunchId == EditLaunchId);
                if (launch != null)
                {
                    // Cannot directly update immutable record properties - would need to replace the launch
                    // For now, just close the modal and reload the list
                    await LoadLaunchesAsync();
                }

                // Show success toast
                await JS.InvokeVoidAsync("showToast", "Launch updated successfully", "success");

                EditLaunchModalOpen = false;
                StateHasChanged();
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                EditLaunchError = $"Failed to update launch: {response.StatusCode} - {content}";
            }
        }
        catch (Exception ex)
        {
            EditLaunchError = $"Error updating launch: {ex.Message}";
        }
        finally
        {
            IsSavingLaunch = false;
            StateHasChanged();
        }
    }

