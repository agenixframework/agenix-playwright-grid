    // Bulk Edit Methods
    private void EditSelected()
    {
        if (!SelectedLaunchIds.Any()) return;
        AnalyzeSelectedLaunchesAttributes();
        ShowBulkEditModal = true;
    }

    private void AnalyzeSelectedLaunchesAttributes()
    {
        if (LaunchList == null) return;

        var selectedLaunches = LaunchList.Where(l => SelectedLaunchIds.Contains(l.LaunchId)).ToList();
        if (!selectedLaunches.Any()) return;

        // Find common attributes (present in ALL selected launches)
        var allAttributeSets = selectedLaunches.Select(l => l.AttributesArray.ToHashSet()).ToList();
        if (allAttributeSets.Count == 1)
        {
            _commonAttributes = allAttributeSets.First().OrderBy(a => a).ToList();
            _uniqueAttributes = new List<string>();
        }
        else
        {
            _commonAttributes = allAttributeSets
                .Skip(1)
                .Aggregate(
                    new HashSet<string>(allAttributeSets.First()),
                    (h, e) =>
                    {
                        h.IntersectWith(e);
                        return h;
                    }
                )
                .OrderBy(a => a)
                .ToList();

            // Find unique attributes (present in some but not all)
            var allAttributes = selectedLaunches.SelectMany(l => l.AttributesArray).Distinct().OrderBy(a => a);
            _uniqueAttributes = allAttributes.Except(_commonAttributes).ToList();
        }
    }

    private void RemoveCommonAttribute(string attribute)
    {
        _commonAttributes.Remove(attribute);
    }

