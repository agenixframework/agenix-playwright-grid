    private static string RenderMarkdown(string text)
    {
        if (string.IsNullOrEmpty(text))
            return string.Empty;

        var html = text;

        // Escape HTML entities first
        html = WebUtility.HtmlEncode(html);

        // Bold: **text** or __text__
        html = Regex.Replace(html, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        html = Regex.Replace(html, @"__(.+?)__", "<strong>$1</strong>");

        // Italic: *text* or _text_
        html = Regex.Replace(html, @"\*(.+?)\*", "<em>$1</em>");
        html = Regex.Replace(html, @"(?<!\w)_(.+?)_(?!\w)", "<em>$1</em>");

        // Strikethrough: ~~text~~
        html = Regex.Replace(html, @"~~(.+?)~~", "<del>$1</del>");

        // Inline code: `code`
        html = Regex.Replace(html, @"`(.+?)`", "<code>$1</code>");

        // Links: [text](url)
        html = Regex.Replace(html, @"\[([^\]]+)\]\(([^\)]+)\)", "<a href=\"$2\" target=\"_blank\" rel=\"noopener noreferrer\">$1</a>");

        // Images: ![alt](url)
        html = Regex.Replace(html, @"!\[([^\]]*)\]\(([^\)]+)\)", "<img src=\"$2\" alt=\"$1\" style=\"max-width: 100%; height: auto;\" />");

        // Line breaks
        html = html.Replace("\r\n", "<br />").Replace("\n", "<br />");

        // Bullet lists: - item or * item
        var lines = html.Split(new[] { "<br />" }, StringSplitOptions.None);
        var inList = false;
        var result = new StringBuilder();

        foreach (var line in lines)
        {
            var trimmed = line.Trim();
            if (trimmed.StartsWith("- ") || trimmed.StartsWith("* "))
            {
                if (!inList)
                {
                    result.Append("<ul>");
                    inList = true;
                }

                result.Append($"<li>{trimmed.Substring(2)}</li>");
            }
            else if (Regex.IsMatch(trimmed, @"^\d+\.\s"))
            {
                if (!inList)
                {
                    result.Append("<ol>");
                    inList = true;
                }

                var content = Regex.Replace(trimmed, @"^\d+\.\s", "");
                result.Append($"<li>{content}</li>");
            }
            else
            {
                if (inList)
                {
                    // Check if previous list was ul or ol
                    var listType = result.ToString().LastIndexOf("<ul>") > result.ToString().LastIndexOf("<ol>") ? "</ul>" : "</ol>";
                    result.Append(listType);
                    inList = false;
                }

                if (!string.IsNullOrWhiteSpace(trimmed))
                {
                    result.Append(line).Append("<br />");
                }
            }
        }

        if (inList)
        {
            var listType = result.ToString().LastIndexOf("<ul>") > result.ToString().LastIndexOf("<ol>") ? "</ul>" : "</ol>";
            result.Append(listType);
        }

        // Blockquotes: > text
        html = result.ToString();
        html = Regex.Replace(html, @"&gt;\s(.+?)<br />", "<blockquote>$1</blockquote>");

        return html;
    }

    private static string FormatDuration(double seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        if (ts.TotalSeconds < 1) return $"{(int)ts.TotalMilliseconds}ms";
        if (ts.TotalMinutes < 1) return $"{ts.Seconds}s";
        if (ts.TotalHours < 1) return $"{ts.Minutes}m {ts.Seconds}s";
        return $"{(int)ts.TotalHours}h {ts.Minutes}m";
    }

    private static string? GetRelativeTime(DateTimeOffset startTime)
    {
        var now = DateTimeOffset.UtcNow;
        var diff = now - startTime.ToUniversalTime();

        if (diff.TotalMinutes < 1)
        {
            return "Just now";
        }

        if (diff.TotalMinutes < 60)
        {
            var minutes = (int)diff.TotalMinutes;
            return $"{minutes} {(minutes == 1 ? "minute" : "minutes")} ago";
        }

        if (diff.TotalHours < 24)
        {
            var hours = (int)diff.TotalHours;
            return $"{hours} {(hours == 1 ? "hour" : "hours")} ago";
        }

        if (diff.TotalDays < 7)
        {
            var days = (int)diff.TotalDays;
            return $"{days} {(days == 1 ? "day" : "days")} ago";
        }

        // For anything older than 7 days, return null to use the full date format
        return null;
    }

    private static int GetPercentage(int count, int total)
