    {
        LaunchList = null;
        await LoadLaunchesAsync();
    }

    // Filter panel state
    private bool ShowFilterPanel;
    private bool IsFilterSaved;
    private string FilterSortBy = "start_time";
    private List<FilterCriterion> FilterCriteria = new();

    // Save filter modal state
    private bool ShowSaveFilterModal;
    private bool IsEditingFilter;
    private Guid? EditingFilterId;
    private string SaveFilterName = string.Empty;
    private string SaveFilterDescription = string.Empty;
    private bool SaveFilterIsShared;
    private string SaveFilterError = string.Empty;
    private bool IsSavingFilter;

    // Saved filters
    private List<SavedFilter> SavedFilters = new();
    private string SelectedSavedFilter = string.Empty;

    private void ToggleFilterPanel()
    {
        // Clear everything to start a new filter from scratch
        FilterCriteria.Clear();
        SelectedSavedFilter = string.Empty;
        IsFilterSaved = false;

        // Open the panel (always open, don't toggle)
        ShowFilterPanel = true;

        // Add initial empty filter criterion
        AddNewFilter();
    }

    private void AddNewFilter()
    {
        FilterCriteria.Add(new FilterCriterion
        {
            Field = "name",
            Operator = "contains",
            Value = string.Empty
        });
        IsFilterSaved = false;
    }

    private void RemoveFilter(int index)
    {
        if (index >= 0 && index < FilterCriteria.Count)
        {
            FilterCriteria.RemoveAt(index);
            IsFilterSaved = false;
        }
    }

    private void AddAttribute(FilterCriterion filter)
    {
        if (!string.IsNullOrWhiteSpace(filter.TempAttributeKey))
        {
            filter.Attributes.Add(new AttributePair
            {
                Key = filter.TempAttributeKey.Trim(),
                Value = filter.TempAttributeValue?.Trim() ?? string.Empty
            });
            filter.TempAttributeKey = string.Empty;
            filter.TempAttributeValue = string.Empty;
            IsFilterSaved = false;
            StateHasChanged();
        }
    }

    private void RemoveAttribute(FilterCriterion filter, AttributePair attr)
    {
        filter.Attributes.Remove(attr);
        IsFilterSaved = false;
        StateHasChanged();
    }

    private void DiscardFilters()
    {
        // Clear all filters and hide the panel
        FilterCriteria.Clear();
        ShowFilterPanel = false;
        IsFilterSaved = false;
    }

    private void SaveFilters()
    {
        // Open save filter modal for creating new filter
        IsEditingFilter = false;
        EditingFilterId = null;
        SaveFilterName = $"New_filter_{SavedFilters.Count + 1}";
        SaveFilterDescription = string.Empty;
        SaveFilterIsShared = false;
        SaveFilterError = string.Empty;
        ShowSaveFilterModal = true;
    }

    private void EditCurrentFilter()
    {
        if (string.IsNullOrEmpty(SelectedSavedFilter))
            return;

        var filter = SavedFilters.FirstOrDefault(f => f.Id.ToString() == SelectedSavedFilter);
        if (filter == null || filter.UserId != CurrentUserId)
            return;

        // Open modal in edit mode
        IsEditingFilter = true;
        EditingFilterId = filter.Id;
        SaveFilterName = filter.Name;
        SaveFilterDescription = filter.Description ?? string.Empty;
        SaveFilterIsShared = filter.IsShared;
        SaveFilterError = string.Empty;
        ShowSaveFilterModal = true;
    }

    private bool CanEditCurrentFilter()
    {
        if (string.IsNullOrEmpty(SelectedSavedFilter))
            return false;

        var filter = SavedFilters.FirstOrDefault(f => f.Id.ToString() == SelectedSavedFilter);
        return filter != null && filter.UserId == CurrentUserId;
    }

    private void CloneCurrentFilter()
    {
        if (string.IsNullOrEmpty(SelectedSavedFilter))
            return;

        var filter = SavedFilters.FirstOrDefault(f => f.Id.ToString() == SelectedSavedFilter);
        if (filter == null)
            return;

        // Open modal in create mode (not edit mode) with pre-filled data from current filter
        IsEditingFilter = false;
        EditingFilterId = null;
        SaveFilterName = $"{filter.Name} (Copy)";
        SaveFilterDescription = filter.Description ?? string.Empty;
        SaveFilterIsShared = false; // Personal copy by default
        SaveFilterError = string.Empty;
        ShowSaveFilterModal = true;

        // Note: FilterCriteria already contains the current filter's criteria
        // so no need to copy them - they're already loaded
    }

    private async Task ConfirmSaveFilter()
    {
        if (string.IsNullOrWhiteSpace(SaveFilterName))
        {
            SaveFilterError = "Filter name is required";
            return;
        }

        // Check for duplicate filter name (case-insensitive), excluding current filter when editing
        if (SavedFilters.Any(f => f.Name.Equals(SaveFilterName, StringComparison.OrdinalIgnoreCase) &&
                                  (!IsEditingFilter || f.Id != EditingFilterId)))
        {
            SaveFilterError = "A filter with this name already exists";
            return;
        }

        try
        {
            IsSavingFilter = true;
            StateHasChanged();

            // Create request to save or update filter via API
            // Filter out invalid criteria (empty values or empty attributes)
            var validCriteria = FilterCriteria.Where(c =>
                (c.Field == "attribute" && c.Attributes != null && c.Attributes.Count > 0) ||
                (c.Field != "attribute" && !string.IsNullOrWhiteSpace(c.Value))
            ).ToList();

            var request = new SaveLaunchFilterRequest
            {
                Name = SaveFilterName.Trim(),
                Description = SaveFilterDescription?.Trim(),
                ProjectKey = ProjectKey,
                Criteria = validCriteria.Select(c => new FilterCriterionDto
                {
                    Field = c.Field,
                    Operator = c.Operator,
                    Value = c.Value,
                    LogicalOperator = c.LogicalOperator,
                    DateRangePreset = c.DateRangePreset,
                    FromDate = c.FromDate,
                    ToDate = c.ToDate,
                    AttributeKey = c.AttributeKey,
                    AttributeValue = c.AttributeValue,
                    Attributes = c.Attributes?.Select(a => new AttributePairDto
                    {
                        Key = a.Key,
                        Value = a.Value
                    }).ToList()
                }).ToList(),
                SortBy = FilterSortBy,
                IsShared = SaveFilterIsShared
            };

            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            HttpResponseMessage response;

            if (IsEditingFilter && EditingFilterId.HasValue)
            {
                // Update existing filter
                response = await client.PutAsJsonAsync($"/api/launch-filters/{EditingFilterId.Value}?userId={Uri.EscapeDataString(CurrentUserId)}", request);
            }
            else
            {
                // Create new filter
                response = await client.PostAsJsonAsync($"/api/launch-filters?userId={Uri.EscapeDataString(CurrentUserId)}", request);
            }

            if (response.IsSuccessStatusCode)
            {
                var savedFilter = await response.Content.ReadFromJsonAsync<LaunchFilterDto>();
                if (savedFilter != null)
                {
                    var localFilter = new SavedFilter
                    {
                        Id = savedFilter.Id,
                        Name = savedFilter.Name,
                        Description = savedFilter.Description,
                        ProjectKey = savedFilter.ProjectKey,
                        UserId = savedFilter.UserId,
                        Criteria = savedFilter.Criteria.Select(c => new FilterCriterion
                        {
                            Field = c.Field,
                            Operator = c.Operator,
                            Value = c.Value,
                            LogicalOperator = c.LogicalOperator,
                            DateRangePreset = c.DateRangePreset ?? "today",
                            FromDate = c.FromDate ?? string.Empty,
                            ToDate = c.ToDate ?? string.Empty,
                            ShowDateRangePicker = false,
                            AttributeKey = c.AttributeKey ?? string.Empty,
                            AttributeValue = c.AttributeValue ?? string.Empty
                        }).ToList(),
                        SortBy = savedFilter.SortBy,
                        IsShared = savedFilter.IsShared,
                        CreatedAt = savedFilter.CreatedAt
                    };

                    if (IsEditingFilter)
                    {
                        // Update existing filter in list
                        var index = SavedFilters.FindIndex(f => f.Id == EditingFilterId);
                        if (index >= 0)
                        {
                            SavedFilters[index] = localFilter;
                        }
                    }
                    else
                    {
                        // Add to local list
                        SavedFilters.Add(localFilter);
                    }

                    // Mark filters as saved
                    IsFilterSaved = true;

                    // Select the newly saved/updated filter in the dropdown
                    SelectedSavedFilter = savedFilter.Id.ToString();

                    // Close modal
                    ShowSaveFilterModal = false;

                    // Show toast notification
                    var message = IsEditingFilter ? "Filter updated successfully" : "Filter saved successfully";
                    await JS.InvokeVoidAsync("showToast", message, "success");
                }
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                SaveFilterError = $"Error saving filter: {response.StatusCode} - {errorContent}";
            }
        }
        catch (Exception ex)
        {
