                                      @bind="EditLaunchDescription" @bind:event="oninput"
                                      disabled="@IsSavingLaunch"></textarea>
                        }
                    </div>
                    <div class="editor-hint">Change of description and attributes can affect your filtering results,
                        widgets, trends.
                    </div>
                </div>
            </div>
        </div>

        <div class="pg-modal-footer">
            <button type="button" class="btn btn-secondary" @onclick="CloseEditLaunchModal" disabled="@IsSavingLaunch">
                Cancel
            </button>
            <button type="button" class="btn btn-primary" @onclick="SaveEditLaunch" disabled="@IsSavingLaunch">
                @if (IsSavingLaunch)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    <span>Saving...</span>
                }
                else
                {
                    <span>Save</span>
                }
            </button>
        </div>
    </div>
}

