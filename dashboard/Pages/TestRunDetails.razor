            _expandedStackTraces.Add(errorIndex);

            // Load affected tests asynchronously when expanding
            if (!_loadedAffectedTests.ContainsKey(errorIndex) && _uniqueErrors != null && errorIndex < _uniqueErrors.Count)
            {
                var error = _uniqueErrors[errorIndex];
