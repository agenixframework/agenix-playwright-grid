    private async Task<Guid?> ResolveLaunchDbIdToUuidAsync(long dbId)
    {
        try
        {
            var httpClient = HttpFactory.CreateClient(HttpClientNames.Hub);
            httpClient.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);

            var url = $"/api/launches/by-db-id/{ProjectKey}/{dbId}";
            Logger.LogInformation("Resolving launch db_id {DbId} via: {Url}", dbId, url);

            var response = await httpClient.GetAsync(url);

            if (response.IsSuccessStatusCode)
            {
                var launchDto = await response.Content.ReadFromJsonAsync<LaunchDto>();
                Logger.LogInformation("Resolved launch db_id {DbId} to UUID {Uuid}", dbId, launchDto?.Id);
                return launchDto?.Id;
            }

            var errorBody = await response.Content.ReadAsStringAsync();
            Logger.LogWarning("Failed to resolve launch db_id {DbId}: {StatusCode} - {Error}",
                dbId, response.StatusCode, errorBody);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Exception resolving launch db_id {DbId}", dbId);
        }

        return null;
    }

    private async Task<Guid?> ResolveSuiteDbIdToUuidAsync(Guid launchId, long dbId)
    {
        try
        {
            var httpClient = HttpFactory.CreateClient(HttpClientNames.Hub);
            httpClient.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);

            // Query test_items table for the suite by db_id within the launch
            var url = $"/api/test-items/by-number/{launchId}/{dbId}";
            Logger.LogInformation("Resolving suite db_id {DbId} (launch {LaunchId}) via: {Url}", dbId, launchId, url);

            var response = await httpClient.GetAsync(url);

            if (response.IsSuccessStatusCode)
            {
                var testItem = await response.Content.ReadFromJsonAsync<TestItemDto>();
                if (testItem?.ItemType == "Suite")
                {
                    Logger.LogInformation("Resolved suite db_id {DbId} to UUID {Uuid}", dbId, testItem.Id);
                    return testItem.Id;
                }

                Logger.LogWarning("Test item db_id {DbId} is not a Suite (ItemType={ItemType})",
                    dbId, testItem?.ItemType);
            }
            else
            {
                var errorBody = await response.Content.ReadAsStringAsync();
                Logger.LogWarning("Failed to resolve suite db_id {DbId}: {StatusCode} - {Error}",
                    dbId, response.StatusCode, errorBody);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Exception resolving suite db_id {DbId} for launch {LaunchId}", dbId, launchId);
        }

        return null;
    }

    // Toast notification state
    private string? _toastMessage;
    private string _toastClass = "";
    private bool _showToast;

    private async Task UpdateTestRunStatusAsync(string runId, string newStatus)
    {
        try
        {
            var http = HttpFactory.CreateClient(HttpClientNames.Hub);

            // Use HttpRequestMessage for PATCH since PatchAsJsonAsync may not be available
            var request = new HttpRequestMessage(HttpMethod.Patch, $"/api/test-items/{runId}/status")
            {
                Content = JsonContent.Create(new { ComputedStatus = newStatus })
            };

            var response = await http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                // Update the local run object
                if (_runs != null)
                {
                    var run = _runs.FirstOrDefault(r => r.RunId == runId);
                    if (run != null)
                    {
                        var updatedRun = run with { ComputedStatus = newStatus };
                        var index = _runs.IndexOf(run);
                        _runs[index] = updatedRun;
                    }
                }

                // Reload launch data to get updated aggregations
                await LoadLaunchDetailsAsync();

                // Show success toast
                _toastMessage = $"Status updated to {newStatus}";
                _toastClass = "toast-success";
                _showToast = true;
                StateHasChanged();

                // Hide toast after 3 seconds
                await Task.Delay(3000);
                _showToast = false;
                StateHasChanged();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Logger.LogError("Failed to update status for run {RunId}: {StatusCode} - {Error}",
                    runId, response.StatusCode, errorContent);

                // Show error toast
                _toastMessage = $"Failed to update status: {response.StatusCode}";
                _toastClass = "toast-error";
                _showToast = true;
                StateHasChanged();

                await Task.Delay(3000);
                _showToast = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating status for run {RunId}", runId);

            // Show error toast
            _toastMessage = $"Error updating status: {ex.Message}";
            _toastClass = "toast-error";
            _showToast = true;
            StateHasChanged();

            await Task.Delay(3000);
            _showToast = false;
            StateHasChanged();
        }
    }

