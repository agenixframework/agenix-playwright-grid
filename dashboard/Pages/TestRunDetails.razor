    // Description truncation logic for individual run descriptions
    private bool ShouldTruncateRunDescription(string? description)
    {
        return !string.IsNullOrEmpty(description) && description.Length > DescriptionPreviewLength;
    }

    private string GetDisplayRunDescription(string runId, string? description)
    {
        if (string.IsNullOrEmpty(description)) return string.Empty;

        if (!ShouldTruncateRunDescription(description) || IsRunDescriptionExpanded(runId))
        {
            return description;
        }

        // Strip markdown for truncated view to avoid broken syntax
        var plainText = StripMarkdown(description);
        if (plainText.Length > DescriptionPreviewLength)
        {
            return plainText.Substring(0, DescriptionPreviewLength) + "...";
        }

        return plainText;
    }

    private static string StripMarkdown(string text)
    {
        if (string.IsNullOrEmpty(text))
            return string.Empty;

        var plain = text;

        // Remove bold: **text** or __text__
        plain = Regex.Replace(plain, @"\*\*(.+?)\*\*", "$1");
        plain = Regex.Replace(plain, @"__(.+?)__", "$1");

        // Remove italic: *text* or _text_
        plain = Regex.Replace(plain, @"\*(.+?)\*", "$1");
        plain = Regex.Replace(plain, @"_(.+?)_", "$1");

        // Remove strikethrough: ~~text~~
        plain = Regex.Replace(plain, @"~~(.+?)~~", "$1");

        // Remove inline code: `code`
        plain = Regex.Replace(plain, @"`(.+?)`", "$1");

        // Remove links: [text](url) -> text
        plain = Regex.Replace(plain, @"\[([^\]]+)\]\(([^\)]+)\)", "$1");

        // Remove images: ![alt](url) -> alt
        plain = Regex.Replace(plain, @"!\[([^\]]*)\]\(([^\)]+)\)", "$1");

        return plain;
    }

