@code {
    [Parameter] public string? ProjectKey { get; set; }

    [Parameter] public Guid LaunchId { get; set; }

    [Parameter] public Guid SuiteId { get; set; }

    [Parameter] public long? LaunchNumber { get; set; }

    [Parameter] public long? SuiteNumber { get; set; }

    [CascadingParameter] private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private LaunchDto? _launch;
    private SuiteSummaryDto? _suite;
    private List<ResultRunSummaryDto>? _runs;
    private string? _openRunMenuId;
    private string? _errorMessage;

    // SignalR connection
    private HubConnection? _hubConnection;

    // Header attributes expansion state

    // Stub data generation
    private bool _showStubDataModal;
    private bool _generatingStubData;
    private string? _stubDataError;
    private int _stubRunsCount = 10;

    // Tab state
    private string _activeTab = "list";

    // Test items state
    private List<TestItemDto>? _testItems;
    private readonly string _selectedItemType = ""; // Empty = all types
    private bool _loadingTestItems;

    // Unique Errors state
    private List<UniqueErrorDto>? _uniqueErrors;
    private readonly HashSet<int> _expandedStackTraces = new();
    private readonly Dictionary<int, List<TestItemDto>> _loadedAffectedTests = new();
    private readonly Dictionary<Guid, TestItemDto> _affectedTestsCache = new();

    // Filters
    private bool _showFilterPanel; // Start collapsed by default
    private bool _hidePassedTests; // Toggle to hide passed tests
    private readonly List<FilterCriterion> _filterCriteria = new();
    private string _sortBy = "starttime_desc";

    // Pagination
    private int _skip;
    private int _take = 50;

    private IEnumerable<ResultRunSummaryDto> FilteredRuns
    {
        get
        {
            if (_runs == null) return Enumerable.Empty<ResultRunSummaryDto>();

            var filtered = _runs.AsEnumerable();

            // Apply clause-based filtering
            if (_filterCriteria.Any())
            {
                var firstClause = true;
                List<ResultRunSummaryDto>? currentResults = null;

                foreach (var criterion in _filterCriteria)
                {
                    var matchingRuns = filtered.Where(r => MatchesCriterion(r, criterion)).ToList();

                    if (firstClause)
                    {
                        currentResults = matchingRuns;
                        firstClause = false;
                    }
                    else if (criterion.LogicalOperator == "AND")
                    {
                        currentResults = currentResults!.Intersect(matchingRuns).ToList();
                    }
                    else // OR
                    {
                        currentResults = currentResults!.Union(matchingRuns).ToList();
                    }
                }

                filtered = currentResults ?? Enumerable.Empty<ResultRunSummaryDto>();
            }

            // Apply hide passed tests toggle
            if (_hidePassedTests)
            {
                filtered = filtered.Where(r =>
                {
                    var status = r.ComputedStatus ?? r.Status;
                    return !string.Equals(status, "Passed", StringComparison.OrdinalIgnoreCase);
                });
            }

            // Apply sorting
            filtered = _sortBy switch
            {
                "type_asc" => filtered.OrderBy(r => r.ItemType),
                "type_desc" => filtered.OrderByDescending(r => r.ItemType),
                "status_asc" => filtered.OrderBy(r => r.ComputedStatus ?? r.Status),
                "status_desc" => filtered.OrderByDescending(r => r.ComputedStatus ?? r.Status),
                "starttime_asc" => filtered.OrderBy(r => r.StartedAtUtc),
                "starttime_desc" => filtered.OrderByDescending(r => r.StartedAtUtc),
                "runname_asc" => filtered.OrderBy(r => r.RunName ?? r.RunId),
                "runname_desc" => filtered.OrderByDescending(r => r.RunName ?? r.RunId),
                _ => filtered.OrderByDescending(r => r.StartedAtUtc)
            };

            return filtered.ToList();
        }
    }

    private List<TestItemDto> FilteredTestItems
    {
        get
        {
            if (_testItems == null) return new List<TestItemDto>();

            // Apply item type filter if specified
            if (string.IsNullOrWhiteSpace(_selectedItemType))
                return _testItems;

            return _testItems
                .Where(item => item.ItemType == _selectedItemType)
                .ToList();
        }
    }

    private bool MatchesCriterion(ResultRunSummaryDto run, FilterCriterion criterion)
    {
        if (string.IsNullOrWhiteSpace(criterion.Value) && criterion.Field != "started_time" && criterion.Field != "attribute")
            return true;

        return criterion.Field switch
        {
            "run_name" => ApplyStringFilter(run.RunName, criterion.Operator, criterion.Value),
            "description" => ApplyStringFilter(run.Description ?? "", criterion.Operator, criterion.Value),
            "type" => MatchesTypeFilter(run, criterion.Value),
            "status" => MatchesStatusFilter(run, criterion.Value),
            "browser" => ApplyStringFilter(run.Browser, criterion.Operator, criterion.Value),
            "attribute" => ApplyAttributeFilter(run.Attributes, criterion.Attributes, criterion.Operator),
            "started_time" => ApplyDateRangeFilter(run.StartedAtUtc, criterion),
            "duration" => ApplyNumericFilter(GetDurationSeconds(run), criterion.Operator, criterion.Value),
            _ => true
        };
    }

    private bool ApplyStringFilter(string? value, string op, string filterValue)
    {
        if (string.IsNullOrWhiteSpace(value)) return false;

        return op switch
        {
            "contains" => value.Contains(filterValue, StringComparison.OrdinalIgnoreCase),
            "not_contains" => !value.Contains(filterValue, StringComparison.OrdinalIgnoreCase),
            "equals" => string.Equals(value, filterValue, StringComparison.OrdinalIgnoreCase),
            "not_equals" => !string.Equals(value, filterValue, StringComparison.OrdinalIgnoreCase),
            _ => true
        };
    }

    private bool ApplyNumericFilter(double value, string op, string filterValue)
    {
        if (!double.TryParse(filterValue, out var target)) return true;

        return op switch
        {
            "gte" => value >= target,
            "lte" => value <= target,
            "equals" => Math.Abs(value - target) < 0.01,
            _ => true
        };
    }

    private bool ApplyDateRangeFilter(DateTimeOffset date, FilterCriterion criterion)
    {
        if (string.IsNullOrEmpty(criterion.FromDate) && string.IsNullOrEmpty(criterion.ToDate))
            return true;

        var from = string.IsNullOrEmpty(criterion.FromDate) ? DateTimeOffset.MinValue : DateTimeOffset.Parse(criterion.FromDate);
        var to = string.IsNullOrEmpty(criterion.ToDate) ? DateTimeOffset.MaxValue : DateTimeOffset.Parse(criterion.ToDate).AddDays(1).AddSeconds(-1);

        return date >= from && date <= to;
    }

    private double GetDurationSeconds(ResultRunSummaryDto run)
    {
        var dur = run.CompletedAtUtc.HasValue
            ? run.CompletedAtUtc.Value - run.StartedAtUtc
            : DateTime.UtcNow - run.StartedAtUtc;
        return dur.TotalSeconds;
    }

    private bool MatchesStatusFilter(ResultRunSummaryDto run, string filterValue)
    {
        if (string.IsNullOrWhiteSpace(filterValue))
            return true;

        // Check ComputedStatus first (preferred), then fall back to legacy Status
        var statusToCheck = !string.IsNullOrWhiteSpace(run.ComputedStatus)
            ? run.ComputedStatus
            : run.Status;

        return !string.IsNullOrWhiteSpace(statusToCheck) &&
               string.Equals(statusToCheck, filterValue, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesTypeFilter(ResultRunSummaryDto run, string filterValue)
    {
        if (string.IsNullOrWhiteSpace(filterValue))
            return true;

        // Check ItemType field
        return !string.IsNullOrWhiteSpace(run.ItemType) &&
               string.Equals(run.ItemType, filterValue, StringComparison.OrdinalIgnoreCase);
    }

    private bool ApplyAttributeFilter(string[]? runAttributes, List<AttributePair> filterAttributes, string op)
    {
        // If no filter attributes specified, return true (no filtering)
        if (filterAttributes == null || !filterAttributes.Any())
            return true;

        // If run has no attributes, return false
        if (runAttributes == null || runAttributes.Length == 0)
            return false;

        // Build a list of matches for each filter attribute
        var matches = new List<bool>();

        foreach (var filterAttr in filterAttributes)
        {
            var found = false;

            foreach (var runAttr in runAttributes)
            {
                var parts = runAttr.Split(':', 2, StringSplitOptions.TrimEntries);

                // Match by key only (if value is empty in filter)
                if (!string.IsNullOrWhiteSpace(filterAttr.Key) && string.IsNullOrWhiteSpace(filterAttr.Value))
                {
                    if (parts.Length >= 1 && string.Equals(parts[0], filterAttr.Key, StringComparison.OrdinalIgnoreCase))
                    {
                        found = true;
                        break;
                    }
                }
                // Match by key and value
                else if (!string.IsNullOrWhiteSpace(filterAttr.Key) && !string.IsNullOrWhiteSpace(filterAttr.Value))
                {
                    if (parts.Length == 2 &&
                        string.Equals(parts[0], filterAttr.Key, StringComparison.OrdinalIgnoreCase) &&
                        string.Equals(parts[1], filterAttr.Value, StringComparison.OrdinalIgnoreCase))
                    {
                        found = true;
                        break;
                    }
                }
            }

            matches.Add(found);
        }

        // Apply operator logic
        return op switch
        {
            "all" => matches.All(m => m), // All filter attributes must be found
            "without_all" => !matches.All(m => m), // NOT all filter attributes are found
            "any" => matches.Any(m => m), // At least one filter attribute is found
            "without_any" => !matches.Any(m => m), // None of the filter attributes are found
            _ => true
        };
    }

    private int TotalCount => FilteredRuns.Count();
    private IEnumerable<ResultRunSummaryDto> PagedRuns => FilteredRuns.Skip(_skip).Take(_take);

    protected override async Task OnInitializedAsync()
    {
        // Resolve numeric db_id to UUIDs if using URLs
        if (LaunchNumber.HasValue)
        {
            Logger.LogInformation("Resolving launch db_id {DbId} to UUID for project {ProjectKey}", LaunchNumber.Value, ProjectKey);
            var launchUuid = await ResolveLaunchDbIdToUuidAsync(LaunchNumber.Value);
            if (launchUuid.HasValue)
            {
                LaunchId = launchUuid.Value;
                Logger.LogInformation("Resolved launch db_id {DbId} to UUID {LaunchId}", LaunchNumber.Value, LaunchId);
            }
            else
            {
                _errorMessage = $"Launch with db_id #{LaunchNumber} not found";
                return;
            }
        }

        if (SuiteNumber.HasValue)
        {
            Logger.LogInformation("Resolving suite db_id {DbId} to UUID for launch {LaunchId}", SuiteNumber.Value, LaunchId);
            var suiteUuid = await ResolveSuiteDbIdToUuidAsync(LaunchId, SuiteNumber.Value);
            if (suiteUuid.HasValue)
            {
                SuiteId = suiteUuid.Value;
                Logger.LogInformation("Resolved suite db_id {DbId} to UUID {SuiteId}", SuiteNumber.Value, SuiteId);
            }
            else
            {
                _errorMessage = $"Suite with db_id #{SuiteNumber} not found in launch #{LaunchNumber}";
                return;
            }
        }

        // Add default Name filter clause
        _filterCriteria.Add(new FilterCriterion
        {
            Field = "run_name",
            Operator = "contains",
            Value = string.Empty,
            LogicalOperator = "AND"
        });

        await LoadLaunchDetailsAsync();

        // Load unique errors for this suite
        await LoadUniqueErrorsAsync();

        // Restore tab state from SessionStorage
        await RestoreTabStateAsync();

        // Initialize SignalR connection
        await InitializeSignalRAsync();
    }

    private async Task InitializeSignalRAsync()
    {
        try
        {
            var hubUrl = Config["HUB_SIGNALR"] ?? "http://hub:5000/ws";
            var uri = new Uri(hubUrl);
            var scheme = uri.Scheme switch { "ws" => "http", "wss" => "https", _ => uri.Scheme };
            var launchesWs = $"{scheme}://{uri.Authority}/launches-ws";

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(launchesWs)
                .WithAutomaticReconnect()
                .Build();

            // Subscribe to launch updates
            _hubConnection.On<string, Guid>("LaunchUpdated", async (projectKey, launchId) =>
            {
                // Only refresh if this is our launch
                if (launchId == LaunchId)
                {
                    await InvokeAsync(async () => { await LoadLaunchDetailsAsync(); });
                }
            });

            await _hubConnection.StartAsync();

            // Join the launch-specific group
            await _hubConnection.InvokeAsync("JoinLaunch", LaunchId);
        }
        catch (Exception ex)
        {
            // Silently fail - SignalR is optional enhancement
            Logger.LogWarning($"Failed to initialize SignalR: {ex.Message}");
        }
    }

    private async Task LoadLaunchDetailsAsync()
    {
        try
        {
            _errorMessage = null;
            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            client.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);

            // Load launch details (now returns LaunchDto directly with Guid ID)
            var launchResponse = await client.GetAsync($"/api/launches/{LaunchId}");
            if (!launchResponse.IsSuccessStatusCode)
            {
                var error = await launchResponse.Content.ReadAsStringAsync();
                _errorMessage = $"Failed to load launch: {launchResponse.StatusCode} - {error}";
                StateHasChanged();
                return;
            }

            _launch = await launchResponse.Content.ReadFromJsonAsync<LaunchDto>();

            // Load suite details
            var suiteResponse = await client.GetAsync($"/api/suites/{SuiteId}");
            if (!suiteResponse.IsSuccessStatusCode)
            {
                var error = await suiteResponse.Content.ReadAsStringAsync();
                _errorMessage = $"Failed to load suite: {suiteResponse.StatusCode} - {error}";
                StateHasChanged();
                return;
            }

            _suite = await suiteResponse.Content.ReadFromJsonAsync<SuiteSummaryDto>();

            // Load test items (test runs) for this suite
            var testItemsResponse = await client.GetAsync($"/api/suites/{SuiteId}/runs");
            if (!testItemsResponse.IsSuccessStatusCode)
            {
                var error = await testItemsResponse.Content.ReadAsStringAsync();
                _errorMessage = $"Failed to load test items: {testItemsResponse.StatusCode} - {error}";
                StateHasChanged();
                return;
            }

            var testItems = await testItemsResponse.Content.ReadFromJsonAsync<List<TestItemDto>>();

            Logger.LogInformation("Loaded {Count} test items for suite {SuiteId}",
                testItems?.Count ?? 0, SuiteId);

            // Store test items for display
            _testItems = testItems ?? [];

            // Map test items to runs for table display (includes ItemType)
            _runs = _testItems.Select(item => new ResultRunSummaryDto
            {
                RunId = item.Id.ToString(),
                RunName = item.Name,
                Description = item.Description,
                Attributes = item.Attributes,
                CodeRef = item.CodeRef,
                TestCaseId = item.TestCaseId,
                ParentItemId = item.ParentItemId,
                Browser = item.BrowserType ?? "Unknown",
                BrowserVersion = item.BrowserVersion,
                PlaywrightVersion = item.PlaywrightVersion,
                Status = item.Status ?? item.SessionStatus ?? item.ComputedStatus ?? "Unknown",
                SessionStatus = item.SessionStatus,
                ComputedStatus = item.ComputedStatus,
                StartedAtUtc = item.StartTime.UtcDateTime,
                CompletedAtUtc = item.FinishTime?.UtcDateTime,
                ItemType = item.ItemType,
                WorkerNodeId = item.WorkerNodeId,
                DbId = item.DbId
            }).ToList();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load suite details for Suite {SuiteId} in Launch {LaunchId}", SuiteId, LaunchId);
            _errorMessage = $"Error: {ex.Message}";
            StateHasChanged();
        }
    }

