    // Phase 10: Load test items for grid/tree views
    private async Task LoadTestItemsAsync()
    {
        if (_loadingTestItems || _testItems != null) return; // Don't reload if already loaded

        _loadingTestItems = true;
        try
        {
            var http = HttpFactory.CreateClient(HttpClientNames.Hub);

            // Load all test items for this suite
            var response = await http.GetAsync($"/api/suites/{SuiteId}/test-items");
            if (response.IsSuccessStatusCode)
            {
                _testItems = await response.Content.ReadFromJsonAsync<List<TestItemDto>>() ?? new List<TestItemDto>();
            }
            else
            {
                // Suite-level endpoint might not exist yet, try loading individual items
                _testItems = new List<TestItemDto>();

                if (_runs != null)
                {
                    foreach (var run in _runs)
                    {
                        try
                        {
                            var itemResponse = await http.GetAsync($"/api/test-items/{run.RunId}/tree?maxDepth=5");
                            if (itemResponse.IsSuccessStatusCode)
                            {
                                var itemData = await itemResponse.Content.ReadFromJsonAsync<dynamic>();
                                if (itemData != null)
                                {
                                    var item = JsonSerializer.Deserialize<TestItemDto>(
                                        itemData.GetProperty("item").ToString() ?? "{}");
                                    if (item != null)
                                    {
                                        _testItems.Add(item);
                                    }
                                }
                            }
                        }
                        catch
                        {
                            // Ignore individual failures
                        }
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load test items for suite {SuiteId}", SuiteId);
            _testItems = new List<TestItemDto>();
        }
        finally
        {
            _loadingTestItems = false;
            StateHasChanged();
        }
    }

