    private double CalculateElapsedSeconds(LaunchDto launch)
    {
        // If FinishTime exists, use it (launch is completed - backend sets this automatically)
        if (launch.FinishTime.HasValue)
        {
            return (launch.FinishTime.Value - launch.StartTime).TotalSeconds;
        }

        // Only use UtcNow for launches that are actually in progress
        var isInProgress = launch.Status?.Equals("InProgress", StringComparison.OrdinalIgnoreCase) == true;
        if (isInProgress)
        {
            return (DateTimeOffset.UtcNow - launch.StartTime).TotalSeconds;
        }

        // For completed launches without FinishTime, return 0 (shouldn't happen with backend fix)
        return 0;
    }

    private string GetDurationTooltip(LaunchDto launch)
    {
        if (launch.FinishTime.HasValue)
        {
            var startLocal = launch.StartTime.ToLocalTime();
            var finishLocal = launch.FinishTime.Value.ToLocalTime();
            return $"Started: {startLocal:MMM dd, yyyy hh:mm:ss tt}\nFinished: {finishLocal:MMM dd, yyyy hh:mm:ss tt}";
        }
        else
        {
            var startLocal = launch.StartTime.ToLocalTime();
            return $"Started: {startLocal:MMM dd, yyyy hh:mm:ss tt}\nIn Progress...";
        }
    }

    private string GetRunDurationTooltip(ResultRunSummaryDto run)
    {
        var startLocal = run.StartedAtUtc.ToLocalTime();

        // Check if test is actually in progress by examining status fields
        var isRunning = run.SessionStatus?.Equals("Running", StringComparison.OrdinalIgnoreCase) == true ||
                        run.SessionStatus?.Equals("Queued", StringComparison.OrdinalIgnoreCase) == true ||
                        run.ComputedStatus?.Equals("InProgress", StringComparison.OrdinalIgnoreCase) == true;

        if (run.CompletedAtUtc.HasValue)
        {
            var finishLocal = run.CompletedAtUtc.Value.ToLocalTime();
            var duration = run.CompletedAtUtc.Value - run.StartedAtUtc;
            var durationText = duration.TotalMinutes < 1
                ? $"{duration.TotalSeconds:F1}s"
                : duration.TotalHours < 1
                    ? $"{duration.Minutes}m {duration.Seconds}s"
                    : $"{(int)duration.TotalHours}h {duration.Minutes}m";
            return $"Duration: {durationText}\nFinish time: {finishLocal:yyyy-MM-dd HH:mm:ss} UTC{finishLocal:zzz}";
        }

        if (isRunning)
        {
            return $"Start time: {startLocal:yyyy-MM-dd HH:mm:ss} UTC{startLocal:zzz}\nIn Progress...";
        }

        // Test completed but CompletedAtUtc not set - show start time only
        return $"Start time: {startLocal:yyyy-MM-dd HH:mm:ss} UTC{startLocal:zzz}";
    }

