    private async Task StopRunAsync(string? runId)
    {
        if (string.IsNullOrEmpty(runId)) return;

        try
        {
            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            await client.PutAsync($"/api/results/{runId}/stop", null);
            await LoadLaunchDetailsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to stop run {RunId}", runId);
        }
    }

    private async Task DeleteRunAsync(string? runId)
    {
        if (string.IsNullOrEmpty(runId)) return;

        try
        {
            var client = HttpFactory.CreateClient(HttpClientNames.Hub);
            await client.DeleteAsync($"/api/results/{runId}");
            await LoadLaunchDetailsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete run {RunId}", runId);
        }
    }

    private string FormatAgo(DateTimeOffset dt)
    {
        var span = DateTime.UtcNow - dt.UtcDateTime;
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays}d ago";
        return dt.ToLocalTime().ToString("MMM dd");
    }

    private string FormatDuration(double seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        if (ts.TotalMinutes < 1) return $"{ts.TotalSeconds:F0}s";
        if (ts.TotalHours < 1) return $"{ts.Minutes}m {ts.Seconds}s";
        return $"{(int)ts.TotalHours}h {ts.Minutes}m";
    }

    private string ShortId(string? id)
    {
        if (string.IsNullOrEmpty(id)) return "-";
        return id.Length > 8 ? id.Substring(0, 8) : id;
    }

    private void ShowStubDataModal()
    {
        _showStubDataModal = true;
        _stubDataError = null;
