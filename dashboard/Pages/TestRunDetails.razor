    private bool IsStackTraceExpanded(int errorIndex)
    {
        return _expandedStackTraces.Contains(errorIndex);
    }

    private async Task<List<TestItemDto>> GetAffectedTestsAsync(List<Guid> testItemIds)
    {
        var result = new List<TestItemDto>();
        var processedTestIds = new HashSet<Guid>(); // Track unique test items to avoid duplicates

        foreach (var itemId in testItemIds)
        {
            // Check cache first
            if (!_affectedTestsCache.TryGetValue(itemId, out var item))
            {
                // Load from API if not cached
                try
                {
                    var http = HttpFactory.CreateClient(HttpClientNames.Hub);
                    http.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);

                    var response = await http.GetAsync($"/api/test-items/{itemId}");
                    if (response.IsSuccessStatusCode)
                    {
                        item = await response.Content.ReadFromJsonAsync<TestItemDto>();
                        if (item != null)
                        {
                            _affectedTestsCache[itemId] = item;
                        }
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to load test item {ItemId}", itemId);
                    continue;
                }
            }

            if (item == null) continue;

            // If this is a Step, trace up to find the parent Test/Scenario
            var testItem = await FindParentTestAsync(item);

            if (testItem != null && !processedTestIds.Contains(testItem.Id))
            {
                result.Add(testItem);
                processedTestIds.Add(testItem.Id);
            }
        }

        return result;
    }

    private async Task<TestItemDto?> FindParentTestAsync(TestItemDto item)
    {
        // If this is already a Test or Scenario, return it
        if (item.ItemType == "Test" || item.ItemType == "Scenario")
        {
            return item;
        }

        // If this is a Step (or other nested type), trace up to find the parent Test
        var currentItem = item;
        var maxDepth = 10; // Prevent infinite loops
        var depth = 0;

        while (currentItem.ParentItemId.HasValue && depth < maxDepth)
        {
            var parentId = currentItem.ParentItemId.Value;

            // Check cache first
            if (!_affectedTestsCache.TryGetValue(parentId, out var parentItem))
            {
                // Load parent from API
                try
                {
                    var http = HttpFactory.CreateClient(HttpClientNames.Hub);
                    http.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);

                    var response = await http.GetAsync($"/api/test-items/{parentId}");
                    if (response.IsSuccessStatusCode)
                    {
                        parentItem = await response.Content.ReadFromJsonAsync<TestItemDto>();
                        if (parentItem != null)
                        {
                            _affectedTestsCache[parentId] = parentItem;
                        }
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to load parent item {ParentId}", parentId);
                    break;
                }
            }

            if (parentItem == null) break;

            // If we found a Test or Scenario, return it
            if (parentItem.ItemType == "Test" || parentItem.ItemType == "Scenario")
            {
                return parentItem;
            }

            // Continue traversing up the hierarchy
            currentItem = parentItem;
            depth++;
        }

        // If we couldn't find a Test parent, return null (will be filtered out)
        return null;
    }

    private string GetBrowserIcon(string browserType)
    {
        return browserType?.ToLowerInvariant() switch
        {
            "chromium" => "bi bi-browser-chrome",
            "firefox" => "bi bi-browser-firefox",
            "webkit" => "bi bi-browser-safari",
            _ => "bi bi-browser-edge"
        };
    }

    // Helper class for grouping tests by suite
    private class SuiteTestGroup
    {
        public string SuiteName { get; set; } = "Unknown Suite";
        public Guid? SuiteId { get; set; }
        public List<TestItemDto> Tests { get; set; } = new();
    }

    private List<SuiteTestGroup> GroupTestsBySuite(List<TestItemDto> allItems)
    {
        // Filter to only Test and Scenario items (not Steps)
        var testItems = allItems
            .Where(item => item.ItemType == "Test" || item.ItemType == "Scenario")
            .ToList();

        // Group by ParentItemId (suite)
        var groupedBySuite = testItems
            .GroupBy(test => test.ParentItemId ?? Guid.Empty)
            .ToList();

        var suiteGroups = new List<SuiteTestGroup>();

        foreach (var group in groupedBySuite)
        {
            var suiteId = group.Key != Guid.Empty ? group.Key : (Guid?)null;
            var suiteName = "Unknown Suite";

            // Try to get suite name from cache
            if (suiteId.HasValue && _affectedTestsCache.TryGetValue(suiteId.Value, out var suiteItem))
            {
                suiteName = suiteItem.Name ?? "Unknown Suite";
            }
            else if (suiteId.HasValue)
            {
                // Load suite from API
                try
                {
                    var http = HttpFactory.CreateClient(HttpClientNames.Hub);
                    http.DefaultRequestHeaders.Add("X-Project-Key", ProjectKey);
                    var response = http.GetAsync($"/api/test-items/{suiteId.Value}").Result;
                    if (response.IsSuccessStatusCode)
                    {
                        var suite = response.Content.ReadFromJsonAsync<TestItemDto>().Result;
                        if (suite != null)
                        {
                            _affectedTestsCache[suiteId.Value] = suite;
                            suiteName = suite.Name ?? "Unknown Suite";
                        }
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to load suite {SuiteId}", suiteId);
                }
            }

            suiteGroups.Add(new SuiteTestGroup
            {
                SuiteName = suiteName,
                SuiteId = suiteId,
                Tests = group.OrderBy(t => t.StartTime).ToList()
            });
        }

        // Sort suite groups by suite name
        return suiteGroups.OrderBy(g => g.SuiteName).ToList();
    }

    private long? GetSuiteDbId(Guid suiteId)
    {
        // Try to get suite db_id from cache
        if (_affectedTestsCache.TryGetValue(suiteId, out var suiteItem))
        {
            return suiteItem.DbId;
        }

        // If not in cache, we can't determine db_id - return null to fallback to UUID URL
        return null;
    }

    // Tab state persistence helpers
    private string GetPageKey()
    {
        return $"testrun_{ProjectKey}_{LaunchId}_{SuiteId}";
    }

    private async Task RestoreTabStateAsync()
    {
        try
        {
            var pageKey = GetPageKey();
            var savedTab = await JS.InvokeAsync<string>("getTabState", pageKey, "list");
            _activeTab = savedTab ?? "list";
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to restore tab state");
            _activeTab = "list"; // Fallback to default
        }
    }

    private async void SwitchTab(string tabName)
    {
        _activeTab = tabName;
        try
        {
            var pageKey = GetPageKey();
            await JS.InvokeVoidAsync("saveTabState", pageKey, tabName);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to save tab state");
        }

        StateHasChanged();
    }

