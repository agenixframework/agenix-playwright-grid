    private void OpenEditRunModal(ResultRunSummaryDto run)
    {
        EditRunId = run.RunId;
        EditRunName = run.RunName ?? string.Empty;
        EditRunDescription = run.Description ?? string.Empty;
        EditRunCodeRef = run.CodeRef ?? string.Empty;
        EditRunTestCaseId = run.TestCaseId ?? string.Empty;

        // Parse attributes from string array (format: "key:value" or just "tag")
        EditRunAttributes = run.Attributes?
            .Select(a =>
            {
                var parts = a.Split(':', 2);
                return new RunAttributeDto
                {
                    Key = parts.Length > 0 ? parts[0] : string.Empty,
                    Value = parts.Length > 1 ? parts[1] : string.Empty
                };
            })
            .ToList() ?? new List<RunAttributeDto>();

        EditRunError = string.Empty;
        EditRunModalOpen = true;
    }

    private void CloseEditRunModal()
    {
        if (!IsSavingRun)
        {
            EditRunModalOpen = false;
            EditRunId = string.Empty;
            EditRunName = string.Empty;
            EditRunDescription = string.Empty;
            EditRunAttributes = new List<RunAttributeDto>();
            EditRunError = string.Empty;
            ShowRunPreview = false;
        }
    }

    private async Task SaveEditRun()
    {
        if (IsSavingRun) return;
        if (string.IsNullOrWhiteSpace(EditRunName))
        {
            EditRunError = "Run name is required";
            return;
        }

        try
        {
            IsSavingRun = true;
            EditRunError = string.Empty;
            StateHasChanged();

            var client = HttpFactory.CreateClient(HttpClientNames.Hub);

            // Convert attributes back to string array format
            var attributesArray = EditRunAttributes
                .Where(a => !string.IsNullOrWhiteSpace(a.Key))
                .Select(a =>
                {
                    var key = a.Key?.Trim() ?? string.Empty;
                    var value = a.Value?.Trim();
                    return string.IsNullOrWhiteSpace(value) ? key : $"{key}:{value}";
                })
                .ToArray();

            var updateData = new
            {
                name = EditRunName.Trim(),
                description = EditRunDescription?.Trim(),
                attributes = attributesArray,
                codeRef = string.IsNullOrWhiteSpace(EditRunCodeRef) ? null : EditRunCodeRef.Trim(),
                testCaseId = string.IsNullOrWhiteSpace(EditRunTestCaseId) ? null : EditRunTestCaseId.Trim()
            };

            var request = new HttpRequestMessage(HttpMethod.Put, $"/api/test-items/{EditRunId}")
            {
                Content = JsonContent.Create(updateData)
            };
            request.Headers.Add("X-Project-Key", ProjectKey);
            var response = await client.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                // Refresh the runs list to get updated data
                await LoadLaunchDetailsAsync();

                EditRunModalOpen = false;
                await JS.InvokeVoidAsync("showToast", "Run updated successfully", "success");
                StateHasChanged();
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                EditRunError = $"Failed to update run: {response.StatusCode} - {content}";
            }
        }
        catch (Exception ex)
        {
            EditRunError = $"Error updating run: {ex.Message}";
            Logger.LogError(ex, "Failed to update test run {RunId}", EditRunId);
        }
        finally
        {
            IsSavingRun = false;
            StateHasChanged();
        }
    }

