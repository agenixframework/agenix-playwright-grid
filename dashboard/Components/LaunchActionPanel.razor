@* Reusable Action Panel Component for Launch, Suite, and Test Run Details Pages *@
@namespace Dashboard.Components
@inject IJSRuntime JS

<div class="action-panel @(_isCollapsed ? "collapsed" : "")">
    <div class="breadcrumbs-section">
        @if (AllowCollapse)
        {
            <button class="collapse-btn" @onclick="ToggleCollapse"
                    title="@(_isCollapsed ? "Expand breadcrumbs" : "Collapse breadcrumbs")">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16">
                    <path fill-rule="evenodd"
                          d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"/>
                </svg>
            </button>
        }

        @if (_isCollapsed)
        {
            @* Collapsed breadcrumb: show only current item (full name, no truncation) *@
            <span class="breadcrumb-separator" style="margin: 0 0.5rem;">...</span>
            @if (BreadcrumbItems.Any())
            {
                var currentItem = BreadcrumbItems.Last();
                <span class="breadcrumb-current" title="@currentItem.Text">
                    @if (!string.IsNullOrEmpty(currentItem.GetIconSvg()))
                    {
                        <span class="breadcrumb-icon">@((MarkupString)currentItem.GetIconSvg())</span>
                    }
                    <span class="breadcrumb-text">@currentItem.Text</span>
                </span>
            }
        }
        else
        {
            @* Render full breadcrumb items *@
            @foreach (var (item, index) in BreadcrumbItems.Select((i, idx) => (i, idx)))
            {
                @if (index > 0)
                {
                    <span class="breadcrumb-separator">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40">
                            <path d="M14 29.17L22.657 20 14 10.83 16.672 8 28 20 16.672 32z"></path>
                        </svg>
                    </span>
                }

                var isLastItem = index == BreadcrumbItems.Count - 1;

                @if (item.IsLink)
                {
                    <a href="@item.Url" class="breadcrumb-link" title="@item.Text">
                        @if (!string.IsNullOrEmpty(item.GetIconSvg()))
                        {
                            <span class="breadcrumb-icon">@((MarkupString)item.GetIconSvg())</span>
                        }
                        <span
                            class="breadcrumb-text">@(item.Text.Length > 50 ? item.Text.Substring(0, 47) + "..." : item.Text)</span>
                    </a>
                }
                else
                {
                    <span class="breadcrumb-current" title="@item.Text">
                        @if (!string.IsNullOrEmpty(item.GetIconSvg()))
                        {
                            <span class="breadcrumb-icon">@((MarkupString)item.GetIconSvg())</span>
                        }
                        <span
                            class="breadcrumb-text">
                            @(isLastItem ? item.Text : item.Text.Length > 50 ? item.Text.Substring(0, 47) + "..." : item.Text)
                        </span>
                    </span>
                }
            }
        }
    </div>

    <div class="action-buttons">
        @* Duration Badge *@
        @{
            var calculatedDuration = Launch.DurationSeconds ?? CalculateElapsedSeconds(Launch);
            var durationTooltip = GetDurationTooltip(Launch);
        }
        <span class="launch-duration-badge" title="@durationTooltip">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 16 16">
                <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
            </svg>
            @FormatDuration(calculatedDuration)
        </span>

        @* Owner *@
        @if (!string.IsNullOrWhiteSpace(Launch.OwnerUsername))
        {
            <button class="launch-info-btn" type="button" data-tooltip="Launch Owner">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" class="btn-icon">
                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                    <path fill-rule="evenodd"
                          d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                </svg>
                <span class="btn-label">@Launch.OwnerUsername</span>
            </button>
        }

        @* Attributes *@
        @if (Launch.Attributes.Any())
        {
            var attrsToShow = _isAttributesExpanded ? Launch.Attributes : Launch.Attributes.Take(3).ToArray();

            foreach (var attr in attrsToShow)
            {
                var parts = attr.Split(':', 2, StringSplitOptions.TrimEntries);
                if (parts.Length == 2)
                {
                    <button class="launch-info-btn" type="button" data-tooltip="@parts[0]">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" class="btn-icon">
                            <path
                                d="M2.5 1A1.5 1.5 0 0 0 1 2.5v11A1.5 1.5 0 0 0 2.5 15h6.086a1.5 1.5 0 0 0 1.06-.44l4.915-4.914A1.5 1.5 0 0 0 15 8.586V2.5A1.5 1.5 0 0 0 13.5 1h-11zM2 2.5a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 .5.5V8H9.5A1.5 1.5 0 0 0 8 9.5V14H2.5a.5.5 0 0 1-.5-.5v-11zm7 11.293V9.5a.5.5 0 0 1 .5-.5h4.293L9 13.793z"/>
                        </svg>
                        <span class="btn-label">@parts[1]</span>
                    </button>
                }
                else
                {
                    <button class="launch-info-btn" type="button" data-tooltip="Attribute">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" class="btn-icon">
                            <path
                                d="M2.5 1A1.5 1.5 0 0 0 1 2.5v11A1.5 1.5 0 0 0 2.5 15h6.086a1.5 1.5 0 0 0 1.06-.44l4.915-4.914A1.5 1.5 0 0 0 15 8.586V2.5A1.5 1.5 0 0 0 13.5 1h-11zM2 2.5a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 .5.5V8H9.5A1.5 1.5 0 0 0 8 9.5V14H2.5a.5.5 0 0 1-.5-.5v-11zm7 11.293V9.5a.5.5 0 0 1 .5-.5h4.293L9 13.793z"/>
                        </svg>
                        <span class="btn-label">@attr</span>
                    </button>
                }
            }

            if (Launch.Attributes.Length > 3 && !_isAttributesExpanded)
            {
                <button class="launch-info-btn launch-more-btn" type="button" @onclick="ToggleAttributes"
                        @onclick:stopPropagation data-tooltip="Show all attributes">
                    <span class="btn-label">+@(Launch.Attributes.Length - 3) more</span>
                </button>
            }

            if (_isAttributesExpanded && Launch.Attributes.Length > 3)
            {
                <button class="launch-info-btn launch-more-btn" type="button" @onclick="ToggleAttributes"
                        @onclick:stopPropagation data-tooltip="Collapse attributes">
                    <span class="btn-label">Show less</span>
                </button>
            }
        }

        @* Description *@
        @if (!string.IsNullOrWhiteSpace(Launch.Description))
        {
            <button class="description-info-btn"
                    type="button"
                    title="@Launch.Description"
                    @onclick:stopPropagation>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                    <path
                        d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                </svg>
            </button>
        }

        <div style="margin-left: auto; display: flex; gap: 0.5rem;">
            @* Optional Add Stub Data Button *@
            @if (ShowStubDataButton)
            {
                <button class="btn btn-success btn-sm" @onclick="OnAddStubData" title="Add stub test data for testing">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                         viewBox="0 0 16 16"
                         style="margin-right: 4px;">
                        <path
                            d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                    </svg>
                    Add Stub Data
                </button>
            }

            @* Refresh Button *@
            <button class="action-icon-btn" @onclick="OnRefresh" title="Refresh data" data-tooltip="Refresh data">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2v1z"/>
                    <path
                        d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/>
                </svg>
            </button>
        </div>
    </div>
</div>

@code {

    /// <summary>
    ///     Launch data to display
    /// </summary>
    [Parameter][EditorRequired]
    public LaunchInfo Launch { get; set; } = null!;

    /// <summary>
    ///     Breadcrumb navigation items
    /// </summary>
    [Parameter][EditorRequired]
    public List<BreadcrumbItem> BreadcrumbItems { get; set; } = new();

    /// <summary>
    ///     Callback when back button is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnNavigateBack { get; set; }

    /// <summary>
    ///     Callback when refresh button is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnRefresh { get; set; }

    /// <summary>
    ///     Show/hide the Add Stub Data button
    /// </summary>
    [Parameter]
    public bool ShowStubDataButton { get; set; }

    /// <summary>
    ///     Callback when Add Stub Data button is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnAddStubData { get; set; }

    /// <summary>
    ///     Optional markdown renderer function
    /// </summary>
    [Parameter]
    public Func<string, string>? RenderMarkdown { get; set; }

    /// <summary>
    ///     Maximum description length before truncation (default: 150 chars)
    /// </summary>
    [Parameter]
    public int DescriptionTruncateLength { get; set; } = 150;

    /// <summary>
    ///     Allow breadcrumbs to be collapsed (default: false)
    /// </summary>
    [Parameter]
    public bool AllowCollapse { get; set; }

    private bool _isAttributesExpanded;
    private bool _isDescriptionExpanded;
    private bool _isCollapsed;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AllowCollapse)
        {
            var value = await JS.InvokeAsync<string?>("localStorage.getItem", "breadcrumb-collapsed");
            _isCollapsed = value == "true";
            StateHasChanged();
        }
    }

    private void ToggleAttributes()
    {
        _isAttributesExpanded = !_isAttributesExpanded;
    }

    private void ToggleDescription()
    {
        _isDescriptionExpanded = !_isDescriptionExpanded;
    }

    private async Task ToggleCollapse()
    {
        _isCollapsed = !_isCollapsed;
        await JS.InvokeVoidAsync("localStorage.setItem", "breadcrumb-collapsed", _isCollapsed);
    }

    private bool ShouldTruncateDescription()
    {
        return !string.IsNullOrWhiteSpace(Launch.Description) &&
               Launch.Description.Length > DescriptionTruncateLength;
    }

    private string GetDisplayDescription()
    {
        if (string.IsNullOrWhiteSpace(Launch.Description)) return string.Empty;

        if (_isDescriptionExpanded || Launch.Description.Length <= DescriptionTruncateLength)
        {
            return Launch.Description;
        }

        return Launch.Description.Substring(0, DescriptionTruncateLength) + "...";
    }

    private string FormatDuration(double? durationSeconds)
    {
        if (durationSeconds == null || durationSeconds.Value <= 0) return "0s";

        var duration = TimeSpan.FromSeconds(durationSeconds.Value);

        if (duration.TotalDays >= 1)
            return $"{(int)duration.TotalDays}d {duration.Hours}h {duration.Minutes}m";
        if (duration.TotalHours >= 1)
            return $"{(int)duration.TotalHours}h {duration.Minutes}m";
        if (duration.TotalMinutes >= 1)
            return $"{(int)duration.TotalMinutes}m {duration.Seconds}s";

        return $"{duration.Seconds}s";
    }

    private double CalculateElapsedSeconds(LaunchInfo launch)
    {
        var end = launch.FinishTime ?? DateTimeOffset.UtcNow;
        return (end - launch.StartTime).TotalSeconds;
    }

    private string GetDurationTooltip(LaunchInfo launch)
    {
        if (launch.FinishTime.HasValue)
        {
            return $"Started: {launch.StartTime:yyyy-MM-dd HH:mm:ss}\nFinished: {launch.FinishTime.Value:yyyy-MM-dd HH:mm:ss}";
        }

        return $"Started: {launch.StartTime:yyyy-MM-dd HH:mm:ss}\n(Still running)";
    }

    /// <summary>
    ///     Launch information DTO for the action panel
    /// </summary>
    public class LaunchInfo
    {
        public string Name { get; set; } = string.Empty;
        public int? LaunchNumber { get; set; }
        public string? Description { get; set; }
        public string[] Attributes { get; set; } = Array.Empty<string>();
        public string? OwnerUsername { get; set; }
        public DateTimeOffset StartTime { get; set; }
        public DateTimeOffset? FinishTime { get; set; }
        public double? DurationSeconds { get; set; }
    }

    /// <summary>
    ///     Breadcrumb navigation item
    /// </summary>
    public class BreadcrumbItem
    {
        public string Text { get; set; } = string.Empty;
        public string? Url { get; set; }
        public string? ItemType { get; set; } // Test, Step, Suite, Scenario, etc.
        public bool IsLink => !string.IsNullOrWhiteSpace(Url);

        /// <summary>
        ///     Get SVG icon markup for item type
        /// </summary>
        public string GetIconSvg()
        {
            return ItemType?.ToLowerInvariant() switch
            {
                "test" => "<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 16 16'><path d='M8.5 1.5A1.5 1.5 0 0 0 7 3v.5h2V3a.5.5 0 0 0-.5-.5zM10 4V3a2 2 0 1 0-4 0v1H4a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V5a1 1 0 0 0-1-1h-2zM4 5h8v8H4V5z'/></svg>",
                "step" => "<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 16 16'><path d='M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z'/></svg>",
                "suite" => "<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 16 16'><path d='M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5v-3zm8 0A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5v-3zm-8 8A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5v-3zm8 0A1.5 1.5 0 0 1 10.5 9h3a1.5 1.5 0 0 1 1.5 1.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 9 13.5v-3z'/></svg>",
                "scenario" => "<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 16 16'><path d='M1 2.5A1.5 1.5 0 0 1 2.5 1h11A1.5 1.5 0 0 1 15 2.5v11a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 1 13.5v-11zM2.5 2a.5.5 0 0 0-.5.5v11a.5.5 0 0 0 .5.5h11a.5.5 0 0 0 .5-.5v-11a.5.5 0 0 0-.5-.5h-11z'/><path d='M4 5.5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5z'/></svg>",
                "story" => "<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 16 16'><path d='M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811V2.828zm7.5-.141c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492V2.687zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783z'/></svg>",
                "beforetest" or "beforemethod" or "beforeclass" or "beforesuite" => "<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 16 16'><path d='M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z'/><path d='M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52l-.094-.319z'/></svg>",
                "aftertest" or "aftermethod" or "afterclass" or "aftersuite" => "<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 16 16'><path d='M2.5 1a1 1 0 0 0-1 1v1a1 1 0 0 0 1 1H3v9a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V4h.5a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H10a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1H2.5zm3 4a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 .5-.5zM8 5a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-1 0v-7A.5.5 0 0 1 8 5zm3 .5v7a.5.5 0 0 1-1 0v-7a.5.5 0 0 1 1 0z'/></svg>",
                _ => ""
            };
        }
    }

}
