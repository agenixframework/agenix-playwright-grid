@* Reusable compact elegant pager with Prev/Next, entry range, and editable per page. *@
@namespace Dashboard.Shared
@inject IJSRuntime JS

<div class="compact-pagination" role="navigation" aria-label="Pagination">
    <div class="pagination-info-left">
        <strong>@StartEntry - @EndEntry</strong> of <strong>@Total</strong> entries
    </div>
    <div class="pagination-controls">
        <button class="pagination-btn" disabled="@DisablePrev" @onclick="Prev" aria-label="Previous page">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd"
                      d="M12 8a.5.5 0 0 1-.5.5H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H11.5a.5.5 0 0 1 .5.5z"/>
            </svg>
            Previous
        </button>
        <button class="pagination-btn" disabled="@DisableNext" @onclick="Next" aria-label="Next page">
            Next
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd"
                      d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8z"/>
            </svg>
        </button>
    </div>
    <div class="pagination-info-right">
        <select class="per-page-select" @bind="CurrentTake" @bind:after="OnTakeChanged">
            <option value="10">10</option>
            <option value="25">25</option>
            <option value="50">50</option>
            <option value="100">100</option>
            <option value="200">200</option>
        </select>
        <span>per page</span>
    </div>
</div>

<style>
    .compact-pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background: #fafafa;
        border-top: 1px solid #e5e7eb;
        margin-top: 1.5rem;
        margin-bottom: 0;
    }

    .pagination-info-left,
    .pagination-info-right {
        color: #6b7280;
        font-size: 0.813rem;
    }

    .pagination-info-left strong,
    .pagination-info-right strong {
        color: #374151;
        font-weight: 600;
    }

    .pagination-controls {
        display: flex;
        gap: 0.375rem;
    }

    .pagination-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.375rem 0.75rem;
        font-size: 0.813rem;
        font-weight: 500;
        color: #6b7280;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .pagination-btn:hover:not(:disabled) {
        background: #f9fafb;
        border-color: #d1d5db;
        color: #374151;
    }

    .pagination-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .pagination-btn svg {
        flex-shrink: 0;
    }

    .per-page-select {
        padding: 0.25rem 0.5rem;
        font-size: 0.813rem;
        font-weight: 500;
        color: #374151;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.15s ease;
        margin-right: 0.375rem;
    }

    .per-page-select:hover {
        border-color: #d1d5db;
    }

    .per-page-select:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 2px rgba(102, 126, 234, 0.1);
    }

    .pagination-info-right {
        display: flex;
        align-items: center;
        gap: 0.375rem;
    }
</style>

@code {
    [Parameter] public int Total { get; set; }
    [Parameter] public int Skip { get; set; }
    [Parameter] public int Take { get; set; } = 50;
    [Parameter] public EventCallback<int> TakeChanged { get; set; }
    [Parameter] public EventCallback OnPrev { get; set; }
    [Parameter] public EventCallback OnNext { get; set; }

    private int CurrentTake { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Load from localStorage
        try
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "pager-take");
            if (!string.IsNullOrEmpty(stored) && int.TryParse(stored, out var take))
            {
                CurrentTake = take;
                if (TakeChanged.HasDelegate)
                {
                    await TakeChanged.InvokeAsync(take);
                }
            }
            else
            {
                CurrentTake = Take;
            }
        }
        catch
        {
            CurrentTake = Take;
        }
    }

    protected override void OnParametersSet()
    {
        if (CurrentTake == 0)
        {
            CurrentTake = Take;
        }
    }

    private async Task OnTakeChanged()
    {
        // Save to localStorage
        await JS.InvokeVoidAsync("localStorage.setItem", "pager-take", CurrentTake.ToString());

        if (TakeChanged.HasDelegate)
        {
            await TakeChanged.InvokeAsync(CurrentTake);
        }
    }

    private int StartEntry => Total == 0 ? 0 : Skip + 1;
    private int EndEntry => Math.Min(Skip + Take, Total);
    private bool DisablePrev => Skip <= 0;
    private bool DisableNext => Skip + Take >= Total;

    private async Task Prev()
    {
        if (!DisablePrev) await OnPrev.InvokeAsync();
    }

    private async Task Next()
    {
        if (!DisableNext) await OnNext.InvokeAsync();
    }

}
