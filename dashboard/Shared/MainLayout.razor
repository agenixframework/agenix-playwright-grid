@using Microsoft.AspNetCore.Components.Routing
@inherits LayoutComponentBase

<nav class="navbar navbar-expand navbar-light bg-light border-bottom mb-3">
    <div class="container d-flex align-items-center">
        <a class="navbar-brand d-flex align-items-center" href="/">
            <img src="images/logo.svg" alt="Logo" class="brand-logo me-2"/>
            <span>Playwright Grid</span>
        </a>
        <div class="navbar-nav ms-auto me-3">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Live Pool</NavLink>
            <NavLink class="nav-link" href="/results">Test Results</NavLink>
            <NavLink class="nav-link" href="/diagnostics">Diagnostics</NavLink>
            @* Login temporarily hidden *@
        </div>
        <img src="images/avatar.svg" alt="Profile" class="nav-avatar"/>
    </div>
</nav>

<div class="container">
    @Body
</div>
