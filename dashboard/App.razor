@using Microsoft.AspNetCore.Components.Authorization
<ErrorBoundary>
    <ChildContent>
        <CascadingAuthenticationState>
            <Router AppAssembly="@typeof(Program).Assembly">
                <Found Context="routeData">
                    @if (routeData.PageType == typeof(Login))
                    {
                        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)"/>
                    }
                    else
                    {
                        <AuthorizeView>
                            <Authorized>
                                <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)"/>
                            </Authorized>
                            <NotAuthorized>
                                <RedirectToLogin/>
                            </NotAuthorized>
                        </AuthorizeView>
                    }
                </Found>
                <NotFound>
                    <AuthorizeView>
                        <Authorized>
                            <NotFound/>
                        </Authorized>
                        <NotAuthorized>
                            <RedirectToLogin/>
                        </NotAuthorized>
                    </AuthorizeView>
                </NotFound>
            </Router>
        </CascadingAuthenticationState>
    </ChildContent>
    <ErrorContent>
        <div class="container mt-3">
            <div class="alert alert-danger">
                <strong>Something went wrong.</strong> The dashboard encountered an error.
                <button class="btn btn-sm btn-light ms-2" onclick="window.location.reload()">Reload</button>
            </div>
        </div>
    </ErrorContent>
</ErrorBoundary>
