{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Agenix.PlaywrightGrid.Shared"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "ChunkedConsole",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:l}{NewLine}{Exception}",
          "maxEventsPerChunk": 1000,
          "maxAgeSeconds": 60
        }
      },
      {
        "Name": "ChunkedFile",
        "Args": {
          "path": "/tmp/pg-worker-%AGENIX_WORKER_NODE_ID%.log",
          "retainedFileCountLimit": 3,
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:l}{NewLine}{Exception}",
          "maxEventsPerChunk": 1000,
          "maxAgeSeconds": 60
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithOperationContext",
      "WithEventCode",
      "WithCodeContext"
    ]
  },
  "AllowedHosts": "*"
}
