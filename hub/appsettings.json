{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Expressions",
      "Agenix.PlaywrightGrid.Shared"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "Filter": [
              {
                "Name": "ByExcluding",
                "Args": {
                  "expression": "SourceContext like 'PlaywrightHub.Infrastructure.Adapters.Background%'"
                }
              }
            ],
            "WriteTo": [
              {
                "Name": "ChunkedConsole",
                "Args": {
                  "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:l}{NewLine}{Exception}",
                  "maxEventsPerChunk": 1000,
                  "maxAgeSeconds": 60
                }
              },
              {
                "Name": "ChunkedFile",
                "Args": {
                  "path": "/tmp/pg-hub.log",
                  "retainedFileCountLimit": 3,
                  "fileSizeLimitBytes": 52428800,
                  "rollOnFileSizeLimit": true,
                  "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:l}{NewLine}{Exception}",
                  "maxEventsPerChunk": 1000,
                  "maxAgeSeconds": 60
                }
              }
            ]
          }
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "Filter": [
              {
                "Name": "ByIncludingOnly",
                "Args": {
                  "expression": "SourceContext like 'PlaywrightHub.Infrastructure.Adapters.Background%'"
                }
              }
            ],
            "WriteTo": [
              {
                "Name": "ChunkedFile",
                "Args": {
                  "path": "/tmp/pg-hub-background.log",
                  "retainedFileCountLimit": 3,
                  "fileSizeLimitBytes": 52428800,
                  "rollOnFileSizeLimit": true,
                  "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:l}{NewLine}{Exception}",
                  "maxEventsPerChunk": 1000,
                  "maxAgeSeconds": 60
                }
              }
            ]
          }
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithOperationContext",
      "WithEventCode",
      "WithCodeContext"
    ]
  },
  "AllowedHosts": "*"
}
