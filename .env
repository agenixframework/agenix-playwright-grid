# ==============================================================================
# Agenix Playwright Grid - Local Development Environment Configuration
# ==============================================================================
# This file is used by the startup script (scripts/run-local-dev-inline.sh) to run
# Hub, Dashboard, and 3 Workers locally while infrastructure runs in Docker.
#
# Prerequisites:
#   docker compose up redis postgres prometheus grafana -d
#
# Start all services:
#   bash scripts/run-local-dev-inline.sh  (macOS/Linux)
#
# Documentation: See docs/ENVIRONMENT-VARIABLES.md for complete reference
# ==============================================================================

# ==============================================================================
# INFRASTRUCTURE (Docker Compose services - standard naming, no AGENIX prefix)
# ==============================================================================
PLAYWRIGHT_VERSION=1.54.2
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agenix_reportportal

# PostgreSQL Connection String (used by Hub and Ingestion)
# Note: Use 127.0.0.1 instead of localhost to force IPv4 connection
POSTGRES_CONNECTION_STRING=Host=127.0.0.1;Port=5432;Username=postgres;Password=postgres;Database=agenix_reportportal;Pooling=true;Minimum Pool Size=5;Maximum Pool Size=100;Connection Idle Lifetime=300;Connection Pruning Interval=10;Multiplexing=true;Max Auto Prepare=20;Auto Prepare Min Usages=1

# Redis (used by Hub, Workers, and Ingestion)
REDIS_URL=localhost:6379

# RabbitMQ (event-driven architecture - Hub publishes, Ingestion consumes)
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PREFETCH_COUNT=100

# ==============================================================================
# GATEWAY CONFIGURATION (Reverse Proxy & Load Balancer)
# ==============================================================================
# Gateway (Traefik) provides unified domain-based routing instead of port-based access.
# Documentation: docs/traefik/README.md
#
# Quick Start:
#   docker compose --profile infrastructure up -d
#   Access services via: http://hub.localhost:8080, http://dashboard.localhost:8080, etc.
#   Gateway Dashboard: http://localhost:8081
# ==============================================================================

# Core Configuration
AGENIX_GATEWAY_ENABLED=true
# Main application traffic (services)
AGENIX_GATEWAY_HTTP_PORT=8080
AGENIX_GATEWAY_HTTPS_PORT=8443
# Traefik dashboard
AGENIX_GATEWAY_DASHBOARD_PORT=8081
# Allow dashboard without auth (dev only!)
AGENIX_GATEWAY_DASHBOARD_INSECURE=true
# DEBUG, INFO, WARN, ERROR
AGENIX_GATEWAY_LOG_LEVEL=INFO
# Enable HTTP request/response logging
AGENIX_GATEWAY_ACCESS_LOGS=false

# Domain Configuration (Local Development)
# Uses *.localhost domains which resolve to 127.0.0.1 automatically
AGENIX_GATEWAY_DOMAIN_HUB=hub.localhost
AGENIX_GATEWAY_DOMAIN_DASHBOARD=dashboard.localhost
AGENIX_GATEWAY_DOMAIN_GRAFANA=grafana.localhost
AGENIX_GATEWAY_DOMAIN_PROMETHEUS=prometheus.localhost
AGENIX_GATEWAY_DOMAIN_MINIO=minio.localhost
AGENIX_GATEWAY_DOMAIN_RABBITMQ=rabbitmq.localhost
AGENIX_GATEWAY_DOMAIN_MAILPIT=mailpit.localhost
AGENIX_GATEWAY_DOMAIN_INGESTION=ingestion.localhost
AGENIX_GATEWAY_DOMAIN_HOUSEKEEPING=housekeeping.localhost

# Production HTTPS (Let's Encrypt) - Uncomment for production deployment
# AGENIX_GATEWAY_ACME_EMAIL=admin@your-domain.com
# AGENIX_GATEWAY_ACME_STAGING=false  # Use production Let's Encrypt (true = staging)

# ==============================================================================
# HUB SERVICE CONFIGURATION (runs on localhost:5100)
# ==============================================================================
# NOTE: Changed from port 5000 to 5100 to avoid conflict with macOS AirPlay Receiver.
# macOS Monterey+ uses port 5000 for AirPlay Receiver by default.
# The startup scripts will set 11=http://localhost:5100 for the Hub.
# ==============================================================================

# Core Configuration
AGENIX_HUB_URL=http://localhost:5100
AGENIX_HUB_NODE_SECRET=node-secret

# Bootstrap Configuration (automatic admin user creation on first startup)
AGENIX_HUB_BOOTSTRAP_ENABLED=1
AGENIX_HUB_BOOTSTRAP_ADMIN_USER=admin
AGENIX_HUB_BOOTSTRAP_ADMIN_PASSWORD=agenix-admin
AGENIX_HUB_BOOTSTRAP_DEFAULT_PROJECT=admin_default
AGENIX_HUB_BOOTSTRAP_ADMIN_EMAIL=agenix.admin@domain.com

# ==============================================================================
# HUB BACKGROUND SERVICES CONFIGURATION
# ==============================================================================

# NodeSweeperService: Sweeps stale nodes and prunes stale available entries
AGENIX_HUB_NODE_SWEEP_INTERVAL_SECONDS=20
# Remove expired nodes from Redis (production mode)
AGENIX_HUB_SWEEPER_EXPIRE=true

# RedisPoolStateBroadcastService: Broadcasts pool state to SignalR clients
AGENIX_HUB_POOL_BROADCAST_INTERVAL_SECONDS=2

# BorrowTtlSweeperService: Auto-returns borrowed sessions whose TTL/lease expired
AGENIX_HUB_BORROW_TTL_SWEEP_SECONDS=10

# BrowserAutoStopService: Auto-stops inactive test items and releases browsers
AGENIX_HUB_CLEANUP_INTERVAL_MINUTES=5
AGENIX_HUB_INACTIVITY_THRESHOLD_MINUTES=30
AGENIX_HUB_MAX_RUN_DURATION_HOURS=3
AGENIX_HUB_CLEANUP_BATCH_SIZE=50

# LaunchAutoStopService: Auto-stops inactive launches
AGENIX_HUB_LAUNCH_CLEANUP_INTERVAL_MINUTES=1
AGENIX_HUB_LAUNCH_CLEANUP_BATCH_SIZE=20
AGENIX_HUB_LAUNCH_CLEANUP_DEBUG=false

# ==============================================================================
# LOGGING & OBSERVABILITY
# ==============================================================================

# Chunked Logging Configuration (Phase 2)
# Operation-based chunked logging with event codes and visual chunks
AGENIX_LOGGING_CHUNKED_ENABLED=true
AGENIX_LOGGING_CHUNK_MAX_EVENTS=1000
AGENIX_LOGGING_CHUNK_MAX_AGE_SECONDS=60
AGENIX_LOGGING_EVENT_CODE_PREFIX=true
AGENIX_LOGGING_INCLUDE_SOURCE_LOCATION=false

# ==============================================================================
# WORKER SERVICE CONFIGURATION
# ==============================================================================

# Core Configuration
AGENIX_WORKER_NODE_SECRET=node-secret
AGENIX_WORKER_NODE_NODE_SECRET=node-node-secret

# Registration Verification
# Interval (seconds) for periodic worker registration verification.
# Detects if worker was removed from hub's worker list (e.g., after hub restart).
# Default: 300 (5 minutes). Complements fast-path gap detection in heartbeat.
AGENIX_WORKER_REGISTRATION_VERIFICATION_INTERVAL_SECONDS=300

# Browser Health Checks
# Enable browser health checks via Playwright protocol (opt-in)
# When enabled, worker periodically checks if browsers are responsive via WebSocket commands.
# Default: false (disabled - health checks are opt-in)
AGENIX_WORKER_HEALTH_CHECK_ENABLED=true

# Health check interval in seconds. How often to check browser health.
# Default: 30. Range: 10-300. Minimum 10s to avoid excessive overhead.
AGENIX_WORKER_HEALTH_CHECK_INTERVAL_SECONDS=10

# Health check timeout in seconds. How long to wait for browser response.
# Default: 5. Range: 1-30. Should be < interval to avoid overlapping checks.
AGENIX_WORKER_HEALTH_CHECK_TIMEOUT_SECONDS=5

# Consecutive failures before triggering browser recycle.
# Default: 3. Range: 1-10. Higher values reduce false positives from transient errors.
AGENIX_WORKER_HEALTH_CHECK_FAILURE_THRESHOLD=3

# WebSocket Configuration
AGENIX_WORKER_PUBLIC_WS_SCHEME=ws
AGENIX_WORKER_PUBLIC_WS_HOST=127.0.0.1

# Browser Arguments
AGENIX_WORKER_CHROMIUM_ARGS="--disable-dev-shm-usage --no-sandbox --disable-setuid-sandbox --no-proxy-server --disable-ipv6 --disable-quic --disable-http2 --disable-features=UseDNSHttpsSvcb"

# ==============================================================================
# WORKER SCALING CONFIGURATION (Phase 2: Heterogeneous Worker Pools)
# ==============================================================================
# Workers scale horizontally per browser type (Chromium, Firefox, WebKit).
# Each browser type has independent scaling and configuration.
# Workers auto-generate unique NodeId from container hostname.
# ==============================================================================

# Chromium Workers (Primary browser - high demand)
# Reduced for local dev (was 5)
WORKER_CHROMIUM_REPLICAS=2
# WebSocket port range start
WORKER_CHROMIUM_PORT_START=5200
# WebSocket port range end (supports up to 100 workers)
WORKER_CHROMIUM_PORT_END=5299
# Reduced pool size (was 3)
AGENIX_WORKER_CHROMIUM_POOL_CONFIG=AppB:Chromium:UAT=2
AGENIX_WORKER_CHROMIUM_ARGS="--disable-dev-shm-usage --no-sandbox --disable-setuid-sandbox --no-proxy-server --disable-ipv6 --disable-quic --disable-http2 --disable-features=UseDNSHttpsSvcb"

# Firefox Workers (Standards compliance - medium demand)
# Reduced for local dev (was 3)
WORKER_FIREFOX_REPLICAS=1
# WebSocket port range start
WORKER_FIREFOX_PORT_START=5300
# WebSocket port range end (supports up to 100 workers)
WORKER_FIREFOX_PORT_END=5399
AGENIX_WORKER_FIREFOX_POOL_CONFIG=AppB:Firefox:UAT=2
AGENIX_WORKER_FIREFOX_ARGS="--no-sandbox"

# WebKit Workers (iOS/Safari testing - low demand)
# Reduced for local dev (was 2)
WORKER_WEBKIT_REPLICAS=1
# WebSocket port range start
WORKER_WEBKIT_PORT_START=5400
# WebSocket port range end (supports up to 100 workers)
WORKER_WEBKIT_PORT_END=5499
AGENIX_WORKER_WEBKIT_POOL_CONFIG=AppB:Webkit:UAT=2
AGENIX_WORKER_WEBKIT_ARGS="--no-sandbox"

# ==============================================================================
# WORKER INSTANCES (3 workers for local development)
# ==============================================================================

# Worker 1 (Chromium, WebSocket port 5200, HTTP port 5200)
WORKER1_NODE_ID=worker1
WORKER1_PUBLIC_WS_PORT=5200
WORKER1_HTTP_PORT=5200
WORKER1_POOL_CONFIG=AppB:Chromium:UAT=3

# Worker 2 (Chromium, WebSocket port 5201, HTTP port 5201)
WORKER2_NODE_ID=worker2
WORKER2_PUBLIC_WS_PORT=5201
WORKER2_HTTP_PORT=5201
WORKER2_POOL_CONFIG=AppB:Chromium:UAT=3

# Worker 3 (Firefox, WebSocket port 5202, HTTP port 5202)
WORKER3_NODE_ID=worker3
WORKER3_PUBLIC_WS_PORT=5202
WORKER3_HTTP_PORT=5202
WORKER3_POOL_CONFIG=AppB:Firefox:UAT=2
WORKER3_FIREFOX_ARGS=--headless
WORKER3_FIREFOX_PREFS='{"network.dns.disablePrefetch":true,"browser.cache.disk.enable":false}'

# Worker 4 (WebKit, WebSocket port 5203, HTTP port 5203)
WORKER4_NODE_ID=worker4
WORKER4_PUBLIC_WS_PORT=5203
WORKER4_HTTP_PORT=5203
WORKER4_POOL_CONFIG=AppB:Webkit:UAT=2

# ==============================================================================
# DASHBOARD SERVICE CONFIGURATION (runs on localhost:3001)
# ==============================================================================
AGENIX_DASHBOARD_HUB_SIGNALR_URL=http://localhost:5100/ws
AGENIX_DASHBOARD_PUBLIC_URL=http://localhost:3001

# ==============================================================================
# INGESTION SERVICE CONFIGURATION (runs on localhost:8082)
# ==============================================================================
# The ingestion service processes events from RabbitMQ and writes to PostgreSQL
# Handles test items, commands, and log items with Redis-based deduplication
# ==============================================================================
AGENIX_INGESTION_PORT=8082

# Log Token Optimization (90%+ storage reduction)
# Reduces log storage through message deduplication with SHA256 hashing
AGENIX_INGESTION_LOG_TOKEN_OPTIMIZATION_ENABLED=true
AGENIX_INGESTION_LOG_TOKEN_TTL_SECONDS=604800
AGENIX_INGESTION_LOG_TOKEN_CACHE_ENABLED=false
AGENIX_INGESTION_LOG_TOKEN_CACHE_MAX_SIZE=10000

# Command Token Optimization (90%+ storage reduction)
# Reduces command storage through message deduplication with SHA256 hashing
AGENIX_INGESTION_COMMAND_TOKEN_OPTIMIZATION_ENABLED=true
AGENIX_INGESTION_COMMAND_TOKEN_TTL_SECONDS=604800
AGENIX_INGESTION_COMMAND_TOKEN_CACHE_ENABLED=false
AGENIX_INGESTION_COMMAND_TOKEN_CACHE_MAX_SIZE=10000

# Audit Event Processing
AGENIX_INGESTION_AUDIT_BATCH_SIZE=500
AGENIX_INGESTION_AUDIT_BATCH_TIMEOUT_MS=750

# Batching Configuration (performance tuning)
AGENIX_INGESTION_BATCH_SIZE_TEST_ITEMS=200
AGENIX_INGESTION_BATCH_SIZE_COMMANDS=500
AGENIX_INGESTION_BATCH_SIZE_LOG_ITEMS=300
AGENIX_INGESTION_BATCH_TIMEOUT_MS=1000

# Consumer Configuration (always enabled - ingestion service purpose is to consume events)
AGENIX_INGESTION_CONSUMER_CONCURRENCY=4
AGENIX_INGESTION_MAX_RETRY_ATTEMPTS=3
AGENIX_INGESTION_RETRY_DELAY_MS=1000

# ==============================================================================
# ARTIFACT STORAGE CONFIGURATION
# ==============================================================================

# Storage Backend Configuration
AGENIX_ARTIFACTS_STORAGE_BACKEND=minio
AGENIX_ARTIFACTS_STORAGE_PATH=./data/artifacts
AGENIX_ARTIFACTS_MAX_SIZE_MB=100
# NOTE: Artifact retention is configured per-project in Redis (project:{key}:settings)
# See housekeeping service documentation for retention policy configuration

# ==============================================================================
# Artifact Caching Configuration (Redis-based distributed cache)
# ==============================================================================
# Enable Redis-based caching for frequently accessed artifacts
# Dramatically reduces database queries, disk I/O, and network bandwidth
AGENIX_ARTIFACTS_CACHE_ENABLED=true

# Enable Gzip compression for artifact bytes before storing in Redis
# Provides 2-5x size reduction (more for text/JSON, less for images)
# Default: true (recommended for memory efficiency)
AGENIX_ARTIFACTS_CACHE_COMPRESSION_ENABLED=true

# Maximum artifact content size to cache in Redis (MB)
# Artifacts larger than this use pre-signed URLs (MinIO) or streaming (local)
# Default: 5MB (caches screenshots/images, streams videos)
AGENIX_ARTIFACTS_CACHE_MAX_CONTENT_SIZE_MB=1

# TTL for cached artifact bytes in Redis (seconds)
# Cached content expires after this duration (LRU eviction)
# Default: 1 hour (3600 seconds)
AGENIX_ARTIFACTS_CACHE_CONTENT_TTL_SECONDS=900

# TTL for cached artifact metadata in Redis (seconds)
# Metadata is lightweight (< 1KB) so can have longer TTL
# Default: 1 hour (3600 seconds)
AGENIX_ARTIFACTS_CACHE_METADATA_TTL_SECONDS=3600

# TTL for cached MinIO pre-signed URLs in Redis (seconds)
# Should be slightly less than MinIO URL expiry to avoid serving expired URLs
# MinIO URLs expire in 3600s, cache for 3000s (50 minutes)
AGENIX_ARTIFACTS_CACHE_PRESIGNED_URL_TTL_SECONDS=3000

# Browser-level caching via Cache-Control headers
# Enables 304 Not Modified responses for repeated requests
AGENIX_ARTIFACTS_RESPONSE_CACHE_ENABLED=true

# ==============================================================================
# Artifact Prefetching Configuration (Proactive cache warming)
# ==============================================================================
# Enable proactive prefetching of artifact bytes when test items are loaded
# Eliminates first-access cache misses by warming the Redis cache in background
# Default: true (recommended for better user experience)
AGENIX_ARTIFACTS_PREFETCH_ENABLED=true

# Maximum concurrent prefetch operations across all test items
# Higher values = faster prefetching but more storage/network load
# Default: 5 (balance between performance and resource usage)
AGENIX_ARTIFACTS_PREFETCH_MAX_CONCURRENCY=5

# Maximum artifacts to prefetch per test item
# Limits memory usage for items with many attachments
# Default: 10 (typically enough for screenshots + small videos)
AGENIX_ARTIFACTS_PREFETCH_MAX_PER_ITEM=10

# ==============================================================================
# MinIO Configuration (S3-compatible object storage - standard naming)
# ==============================================================================
# MinIO is used for scalable, distributed artifact storage (screenshots, videos, logs)
# Local development: Start with 'docker compose up minio -d'
# Web Console: http://localhost:9001 (login: minioadmin/minioadmin)
# S3 API: http://localhost:9000
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_REGION=eu-central-1
MINIO_BUCKET_NAME=playwright-artifacts
MINIO_PUBLIC_URL=http://localhost:9000

# ==============================================================================
# EMAIL/SMTP CONFIGURATION (for password reset emails - standard naming)
# ==============================================================================
# For local development with Mailpit (no real SMTP needed):
#   docker compose up mailpit -d
#   View emails at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=test@localhost
SMTP_PASSWORD=test
SMTP_FROM_EMAIL=noreply@agenix.testplatform.local
SMTP_FROM_NAME="Agenix Test Platform Service"
SMTP_USE_SSL=false

# For production with Gmail (requires App Password):
#   1. Enable 2FA on your Google account
#   2. Generate App Password: https://myaccount.google.com/apppasswords
#   3. Use the 16-character password below
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# SMTP_FROM_EMAIL=your-email@gmail.com
# SMTP_FROM_NAME=Agenix Playwright Grid
# SMTP_USE_SSL=true

# For production with SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# SMTP_FROM_EMAIL=noreply@your-domain.com
# SMTP_FROM_NAME=Agenix Playwright Grid
# SMTP_USE_SSL=true

# ==============================================================================
# LOGGING & OBSERVABILITY (standard naming)
# ==============================================================================
LOG_LEVEL=Information
LOG_LEVEL_OVERRIDES=Microsoft.AspNetCore=Warning,System.Net.Http.HttpClient=Warning

# OpenTelemetry (optional, for Prometheus/Grafana integration)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=hub

# ==============================================================================
# HOUSEKEEPING SERVICE CONFIGURATION (runs on localhost:8082)
# ==============================================================================
# The housekeeping service handles retention cleanup for launches, logs, artifacts, and audit entries
# Runs background workers with Redis leadership election for multi-instance deployment
# ==============================================================================
AGENIX_HOUSEKEEPING_PORT=8083

# Worker Intervals
AGENIX_HOUSEKEEPING_LAUNCH_RETENTION_CHECK_INTERVAL_HOURS=1
AGENIX_HOUSEKEEPING_LAUNCH_AUTO_STOP_INTERVAL_MINUTES=10
AGENIX_HOUSEKEEPING_LAUNCH_AUTO_STOP_BATCH_SIZE=20
AGENIX_HOUSEKEEPING_LOG_RETENTION_CHECK_INTERVAL_HOURS=1
AGENIX_HOUSEKEEPING_ATTACHMENT_RETENTION_CHECK_INTERVAL_HOURS=1
AGENIX_HOUSEKEEPING_AUDIT_RETENTION_CHECK_INTERVAL_HOURS=24

# Leadership Election (multi-instance deployment)
AGENIX_HOUSEKEEPING_LEADERSHIP=true
AGENIX_HOUSEKEEPING_LEASE_SECONDS=30
AGENIX_HOUSEKEEPING_INSTANCE_ID=housekeeping-1

# ==============================================================================
# INTEGRATION TESTS CONFIGURATION
# ==============================================================================
# Configuration for integration test environment (Agenix.PlaywrightGrid.Integration.Tests)
#
# DEPLOYMENT MODE:
#   Set AGENIX_TESTS_USE_LOCAL=true to test against local services (dotnet run)
#   Set AGENIX_TESTS_USE_LOCAL=false (default) to test against Docker containers
#
# Prerequisites for Docker Mode (default):
#   - Docker Compose infrastructure must be running before tests start
#   - Use: docker compose --profile infrastructure --profile core up -d
#   - Or use: ./scripts/run-docker-compose-test.sh
#
# Prerequisites for Local Mode (AGENIX_TESTS_USE_LOCAL=true):
#   - Start services manually: ./scripts/run-local-dev-inline.sh
#   - Or start hub: cd hub && dotnet run
#   - PostgreSQL must be running on localhost:5432
#   - Redis must be running on localhost:6379
# ==============================================================================

# Deployment Mode Flag
# Set to "true" to run tests against local services (dotnet run)
# Set to "false" or leave unset to run against Docker containers (default)
AGENIX_TESTS_USE_LOCAL=true

# Hub Health Check Configuration
AGENIX_TESTS_HEALTH_TIMEOUT_SECONDS=120
AGENIX_TESTS_HEALTH_POLL_INTERVAL_SECONDS=1.0

# Worker Pool Readiness Configuration
AGENIX_TESTS_WORKER_TIMEOUT_SECONDS=60
AGENIX_TESTS_EXPECTED_WORKERS=3

# ==============================================================================
# MONITORING
# ==============================================================================
# NOTE: ASPNETCORE_URLS is set by startup script per-service using port variables above
#       - Hub: 5100 (hardcoded in startup script)
#       - Dashboard: 3001 (hardcoded in startup script)
#       - Ingestion: $AGENIX_INGESTION_PORT (default: 8082)
#       - Housekeeping: $AGENIX_HOUSEKEEPING_PORT (default: 8083)
# Do NOT set ASPNETCORE_URLS here as it would apply to all services and cause port conflicts
